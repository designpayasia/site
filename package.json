{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "scripts": {
    "dev": "astro dev",
    "build:site": "astro build",
    "build": "pnpm run build:site && pnpm run search:index",
    "check": "astro check",
    "search:index": "pagefind --site dist",
    "check-links": "node ./scripts/check-links.mjs",
    "audit:tokens": "node ./scripts/check-token-usage.mjs",
    "audit:ops": "node ./scripts/check-ops-freshness.mjs",
    "audit:pii": "node ./scripts/audit-pii.mjs",
    "a11y:charts": "node ./scripts/a11y-charts.mjs",
    "redirects:sync": "node ./scripts/redirects.mjs",
    "redirects:check": "node ./scripts/redirects.mjs --check",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "astro": "^6.3.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.3.0",
    "zod": "^4.4.3"
  }
}
