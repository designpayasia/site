---
interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  steps: string[];
  links?: LinkItem[];
}

const { eyebrow, title, summary, steps, links = [] } = Astro.props;
---

<section class="guide-page">
  <div class="guide-page__inner">
    <p class="label-mono">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="prose">{summary}</p>

    <ol class="guide-page__steps">
      {steps.map((step) => (
        <li>{step}</li>
      ))}
    </ol>

    {links.length > 0 && (
      <div class="guide-page__links">
        {links.map((link) => (
          <a href={link.href} class="guide-page__link">
            {link.label}
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .guide-page {
    padding-inline: var(--space-8);
    padding-block: var(--space-24);
  }

  .guide-page__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
  }

  .guide-page__inner h1 {
    margin-block: var(--space-6);
    max-width: 16ch;
  }

  .guide-page__steps {
    max-width: 72ch;
    padding-left: 1.25rem;
    color: var(--color-ink-muted);
  }

  .guide-page__steps li + li {
    margin-top: var(--space-4);
  }

  .guide-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .guide-page__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding-inline: var(--space-6);
    border: 1px solid var(--color-border-strong);
    border-radius: 8px;
    color: var(--color-ink);
    text-decoration: none;
  }

  .guide-page__link:hover {
    color: var(--color-action);
  }
</style>
