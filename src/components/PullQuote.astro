---
interface Props {
  quote: string;
  attribution?: string;
  cite?: string;
  draftState?: 'ai-draft' | 'review' | 'final';
}

const {
  quote,
  attribution,
  cite,
  draftState = 'ai-draft',
} = Astro.props;
---

<figure
  class="pull-quote"
  data-editorial-state={draftState}
  data-ai-draft={draftState === 'ai-draft' ? 'true' : 'false'}
>
  <blockquote class="pull-quote__body">
    <p class="t-quote">{quote}</p>
  </blockquote>

  {(attribution || cite) && (
    <figcaption class="pull-quote__meta">
      {attribution && <span>{attribution}</span>}
      {attribution && cite && <span aria-hidden="true"> / </span>}
      {cite && <cite>{cite}</cite>}
    </figcaption>
  )}
</figure>

<style>
  .pull-quote {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    border-left: 3px solid var(--color-signal-text);
    padding-left: var(--space-6);
  }

  .pull-quote__body {
    margin: 0;
  }

  .pull-quote__body p {
    margin: 0;
    color: var(--color-workhorse);
  }

  .pull-quote__meta {
    color: var(--color-ink-muted);
  }

  .pull-quote__meta cite {
    font-style: normal;
    color: var(--color-ink);
  }
</style>
