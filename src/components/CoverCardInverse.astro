---
// CoverCardInverse — compact inverse cover card (Pattern 01, NEW per §0
// verdict on cover-full-bleed: "Add an inverse cover-card variant for report
// selection / archive listing.")
//
// Intended contexts:
//   - Year index grid: a report archive page listing every published year
//     (e.g. /reports) as a grid of these cards, one per report.
//   - Related-reports rail: a horizontal strip of 2-3 cards surfaced at the
//     end of a report section, pointing to other years' reports.
//
// The whole card is a single link (44px+ touch target). Inverse surface,
// following the DarkBeat pattern (data-theme="dark" + explicit
// --color-inverse-* tokens rather than the [data-theme=dark] cascade).

interface Stat {
  value: string;
  label: string;
  /** Optional explicit prefix override (e.g. "S$"). Falls back to the
   *  leading non-numeric run auto-parsed from `value` when omitted, so
   *  the existing `{ value, label }` shape keeps working unchanged. */
  affix?: string;
  /** Optional explicit trailing unit. Falls back to the trailing
   *  non-numeric run auto-parsed from `value` when omitted. */
  unit?: string;
}

interface Props {
  href: string;
  year: string | number;
  title: string;
  stat?: Stat;
}

const { href, year, title, stat } = Astro.props;

// Segment anatomy (DESIGN.md § Long values and currency): same parse
// BigStat.astro/DarkBeat.astro use, so a flat `stat.value` string still
// renders correctly with no call-site changes required.
const trimmedStatValue = stat?.value.trim();
const statValueMatch = trimmedStatValue?.match(/^([^0-9]*)(\d[\d,]*(?:\.\d+)?)(.*)$/);
const statAffix = stat?.affix ?? statValueMatch?.[1]?.trim();
const statCore = statValueMatch?.[2] ?? trimmedStatValue;
const statSuffix = stat?.unit ?? statValueMatch?.[3]?.trim();
---

<a class="cover-card-inverse" data-theme="dark" href={href} aria-label={`${title} — ${year}`}>
  <span class="cover-card-inverse__year label-mono">{year}</span>
  <span class="cover-card-inverse__title">{title}</span>
  {stat && (
    <span class="cover-card-inverse__stat">
      <span class="cover-card-inverse__stat-value">
        {statAffix && <span class="cover-card-inverse__stat-affix">{statAffix}</span>}
        <span class="cover-card-inverse__stat-core">{statCore}</span>
        {statSuffix && <span class="cover-card-inverse__stat-affix">{statSuffix}</span>}
      </span>
      <span class="cover-card-inverse__stat-label label-mono">{stat.label}</span>
    </span>
  )}
</a>

<style>
  .cover-card-inverse {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 44px;
    padding: var(--space-6);
    background: var(--color-inverse-surface);
    color: var(--color-inverse-text);
    border: 1px solid transparent;
    border-radius: var(--radius-blob-motif);
    text-decoration: none;
    transition:
      transform var(--transition-hover),
      border-color var(--transition-hover);
  }

  .cover-card-inverse:hover {
    transform: translateY(-0.25rem);
    border-color: var(--color-border-strong);
  }

  .cover-card-inverse:focus-visible {
    outline: 3px solid var(--color-signal-fill);
    outline-offset: 3px;
  }

  .cover-card-inverse__year {
    color: var(--color-inverse-signal-text);
  }

  .cover-card-inverse__title {
    font-family: var(--type-h2-face);
    font-size: clamp(1.375rem, 3vw, 2rem);
    line-height: 1.1;
    letter-spacing: var(--type-h2-tracking);
    color: var(--color-inverse-text);
    overflow-wrap: break-word;
  }

  .cover-card-inverse__stat {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    padding-top: var(--space-4);
    border-top: 1px solid color-mix(in srgb, var(--color-inverse-text) 20%, transparent);
    container-type: inline-size;
  }

  .cover-card-inverse__stat-value {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.12em;
    min-width: 0;
    max-width: 100%;
    font-family: var(--font-data);
    /* Safety net (A): cqi shrink, floor no lower than ~0.7x the 2rem
       locked ceiling, so overlap is impossible even in a tight card. */
    font-size: clamp(1.4rem, 20cqi, 2rem);
    font-weight: var(--weight-medium);
    line-height: 1;
    letter-spacing: var(--type-stat-tracking);
    color: var(--color-inverse-text);
  }

  .cover-card-inverse__stat-core {
    min-width: 0;
    font-variant-numeric: lining-nums;
  }

  .cover-card-inverse__stat-affix {
    min-width: 0;
    max-width: 100%;
    font-size: var(--type-stat-unit-size);
    line-height: 1;
    white-space: nowrap;
  }

  .cover-card-inverse__stat-label {
    color: color-mix(in srgb, var(--color-inverse-text) 70%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .cover-card-inverse {
      transition: none;
    }
  }

  @media (max-width: 480px) {
    .cover-card-inverse {
      padding: var(--space-5);
    }
  }
</style>
