---
import { isSelfHostedSource } from '../lib/evidence';
import ChartRangeRows, { type RangeRow } from './ChartRangeRows.astro';

interface TableRow {
  label: string;
  /** Legacy single-value shape — only valid alongside a 2-column table. */
  value?: string;
  /** N-column shape: one printed value per non-label fallbackColumns entry. */
  values?: string[];
}

interface Props {
  title: string;
  caption: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel: string;
  sourceUrl: string;
  reportPath?: string;
  /** 2–6 printed header cells: `[0]` is the row-label column. */
  fallbackColumns: string[];
  fallbackRows: TableRow[];
  rows: RangeRow[];
  /**
   * Tick text for the shared axis, paired with the fixed 0/25/50/75/100%
   * gridline positions (same positions as ChartBlock). Defaults to plain
   * percentages; pass domain-specific labels (e.g. salary bands) instead.
   */
  axisTickLabels?: [string, string, string, string, string];
  /** Optional mono methodology note rendered under the axis. */
  note?: string;
  /**
   * Controls how the fallback data table renders relative to the chart
   * visual. Defaults to `'collapsed'` so the table never competes with the
   * rendered chart.
   * - 'collapsed' — table sits inside a closed `<details>` disclosure.
   * - 'open' — prominent table, always expanded (table-only usage).
   * - 'hidden' — visually-hidden accessible alternative only.
   */
  tableMode?: 'collapsed' | 'open' | 'hidden';
}

const LABEL_COLUMN_WIDTH_PX = 140;
const DEFAULT_TICK_LABELS: [string, string, string, string, string] = ['0%', '25%', '50%', '75%', '100%'];

const {
  title,
  caption,
  summary,
  evidenceIds,
  sourceLabel,
  sourceUrl,
  reportPath,
  fallbackColumns,
  fallbackRows,
  rows,
  axisTickLabels,
  note,
  tableMode,
} = Astro.props;

const tickLabels = axisTickLabels ?? DEFAULT_TICK_LABELS;
const resolvedTableMode: 'collapsed' | 'open' | 'hidden' = tableMode ?? 'collapsed';

/**
 * Normalise the legacy single-`value` row shape into `values: string[]` so
 * the table below renders N columns the same way regardless of which shape
 * the source frontmatter used.
 */
const normalizeTableRows = (inputRows: TableRow[]) =>
  inputRows.map((row) => ({
    label: row.label,
    values: row.values ?? (row.value !== undefined ? [row.value] : []),
  }));

const normalizedFallbackRows = normalizeTableRows(fallbackRows);
const evidenceLabel = evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs';
const showSource = !isSelfHostedSource(sourceUrl, reportPath);
---

<figure class="chart-range">
  <figcaption class="chart-range__header">
    <p class="label-mono">Chart proof</p>
    <h2>{title}</h2>
    <p class="prose">{caption}</p>
  </figcaption>

  <div class="chart-range__layout">
    <div
      class="chart-range__visual"
      role="img"
      aria-label={summary}
      style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
    >
      <p class="chart-range__summary">{summary}</p>

      <ChartRangeRows rows={rows} axisTickLabels={tickLabels} />

      {note && <p class="chart-range__note">{note}</p>}

      <div class="chart-range__meta">
        {showSource && (
          <p class="chart-range__source">
            Source:{' '}
            <a href={sourceUrl} class="chart-range__source-link">
              {sourceLabel}
            </a>
          </p>
        )}

        <p class="chart-range__evidence">
          {evidenceLabel}: {evidenceIds.join(', ')}
        </p>
      </div>
    </div>

    <div class:list={['chart-range__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
      {resolvedTableMode === 'collapsed' ? (
        <details class="chart-range__table-disclosure">
          <summary class="label-mono chart-range__table-summary">View data table</summary>
          <div class="chart-range__table-wrap">
            <table class="chart-range__table">
              <thead>
                <tr>
                  {fallbackColumns.map((column) => (
                    <th scope="col">{column}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {normalizedFallbackRows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    {row.values.map((value) => (
                      <td class="chart-range__table-value">{value}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      ) : (
        <div class="chart-range__table-wrap">
          <table class="chart-range__table">
            <thead>
              <tr>
                {fallbackColumns.map((column) => (
                  <th scope="col">{column}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {normalizedFallbackRows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  {row.values.map((value) => (
                    <td class="chart-range__table-value">{value}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</figure>

<style>
  .chart-range {
    margin: 0;
  }

  .chart-range__header h2 {
    margin-block: var(--space-4);
    font-family: var(--type-h2-face);
    font-size: var(--type-h2-size);
    line-height: var(--type-h2-leading);
    letter-spacing: var(--type-h2-tracking);
    font-weight: var(--weight-regular);
    text-rendering: auto;
  }

  .chart-range__layout {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .chart-range__visual {
    display: grid;
    gap: var(--space-5);
    container-type: inline-size;
  }

  .chart-range__summary {
    margin: 0;
    color: var(--color-ink-muted);
    overflow-wrap: anywhere;
  }

  .chart-range__note {
    margin: 0;
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    line-height: var(--leading-ui);
    border-left: 1.5px solid var(--color-border-strong);
    padding-left: var(--space-3);
  }

  .chart-range__meta {
    display: grid;
    gap: var(--space-2);
  }

  .chart-range__source,
  .chart-range__evidence {
    margin: 0;
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    line-height: var(--leading-ui);
    overflow-wrap: anywhere;
  }

  .chart-range__source-link {
    display: inline-flex;
    color: var(--color-action);
    text-decoration: none;
    width: fit-content;
  }

  .chart-range__source-link:hover {
    text-decoration: underline;
  }

  .chart-range__support {
    display: grid;
    gap: var(--space-6);
  }

  /* Horizontal scroll lives on the wrapper only, never the page — a wide
     N-column fallback table (e.g. min/median/max/n) must never force the
     document itself to scroll sideways. */
  .chart-range__table-wrap {
    overflow-x: auto;
  }

  .chart-range__table {
    width: fit-content;
    max-width: 100%;
    border-collapse: collapse;
  }

  .chart-range__table th,
  .chart-range__table td {
    padding-block: var(--space-3);
    padding-inline: 0 var(--space-8);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: left;
    vertical-align: top;
    overflow-wrap: break-word;
  }

  .chart-range__table th:last-child,
  .chart-range__table td:last-child {
    padding-inline-end: 0;
  }

  /* Value columns are numeric (counts, medians, percentages) — right-align
     and set in the data face, tabular so digits line up down the column. */
  .chart-range__table td.chart-range__table-value {
    font-family: var(--font-data);
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Align column headers (except first, the row-label column) right to match
     their value cells below — headers sit over right-aligned numbers. */
  .chart-range__table th[scope='col']:not(:first-child) {
    text-align: right;
  }

  /* Accessible table alternative — removed from the visual flow only. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Collapsed table disclosure — quiet by default so it never competes with
     the chart visual above it. Native <details>/<summary>, no JS. */
  .chart-range__table-disclosure {
    border-top: 1px solid var(--color-border-subtle);
  }

  .chart-range__table-summary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 44px;
    color: var(--color-ink-muted);
    cursor: pointer;
    list-style: none;
  }

  .chart-range__table-summary::-webkit-details-marker {
    display: none;
  }

  .chart-range__table-summary::before {
    content: '▸';
    display: inline-block;
    transition: transform 120ms ease;
  }

  .chart-range__table-disclosure[open] > .chart-range__table-summary::before {
    transform: rotate(90deg);
  }

  .chart-range__table-summary:focus-visible {
    outline: 3px solid var(--color-signal-fill);
    outline-offset: 3px;
  }

  .chart-range__table-disclosure .chart-range__table-wrap {
    margin-top: var(--space-4);
  }

  .chart-range__table-disclosure .chart-range__table {
    font-size: var(--type-caption);
  }

  .chart-range__table-disclosure .chart-range__table th,
  .chart-range__table-disclosure .chart-range__table td {
    padding-block: var(--space-2);
  }

  .chart-range,
  .chart-range__visual,
  .chart-range__support {
    min-width: 0;
  }
</style>
