---
import { isSelfHostedSource } from '../lib/evidence';

interface TableRow {
  label: string;
  value: string;
}

type RangeTone = 'signal' | 'action';

interface RangeRow {
  label: string;
  /** Position of the median dot, percent along the shared axis (0–100). */
  medianPosition: number;
  /** Left edge of the IQR / confidence band, percent along the shared axis. */
  bandStart: number;
  /** Right edge of the IQR / confidence band, percent along the shared axis. */
  bandEnd: number;
  /** Printed headline value, e.g. "SGD 72k". */
  valueLabel: string;
  /** Printed spread/caveat text, e.g. "±8k IQR" or "n=34 — directional only". */
  rangeLabel?: string;
  tone?: RangeTone;
  /**
   * "low" renders the band dashed and the dot as a smaller neutral marker,
   * regardless of tone — the DPA way of disclosing a thin sample without
   * deleting the row. Pair with rangeLabel explaining the n.
   */
  confidence?: 'standard' | 'low';
}

interface Props {
  title: string;
  caption: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel: string;
  sourceUrl: string;
  reportPath?: string;
  fallbackColumns: [string, string];
  fallbackRows: TableRow[];
  rows: RangeRow[];
  /**
   * Tick text for the shared axis, paired with the fixed 0/25/50/75/100%
   * gridline positions (same positions as ChartBlock). Defaults to plain
   * percentages; pass domain-specific labels (e.g. salary bands) instead.
   */
  axisTickLabels?: [string, string, string, string, string];
  /** Optional mono methodology note rendered under the axis. */
  note?: string;
  /**
   * Controls how the fallback data table renders relative to the chart
   * visual. Defaults to `'collapsed'` so the table never competes with the
   * rendered chart.
   * - 'collapsed' — table sits inside a closed `<details>` disclosure.
   * - 'open' — prominent table, always expanded (table-only usage).
   * - 'hidden' — visually-hidden accessible alternative only.
   */
  tableMode?: 'collapsed' | 'open' | 'hidden';
}

const LABEL_COLUMN_WIDTH_PX = 140;
const GRIDLINE_PERCENTAGES = [0, 25, 50, 75, 100] as const;
const DEFAULT_TICK_LABELS: [string, string, string, string, string] = ['0%', '25%', '50%', '75%', '100%'];

const {
  title,
  caption,
  summary,
  evidenceIds,
  sourceLabel,
  sourceUrl,
  reportPath,
  fallbackColumns,
  fallbackRows,
  rows,
  axisTickLabels,
  note,
  tableMode,
} = Astro.props;

const tickLabels = axisTickLabels ?? DEFAULT_TICK_LABELS;
const resolvedTableMode: 'collapsed' | 'open' | 'hidden' = tableMode ?? 'collapsed';

/**
 * §1d colour contract: at most one row carries the crimson signal tone.
 * A low-confidence row is never allowed to be the signal row — a thin
 * sample can't be "the one finding that matters".
 */
const normalizeRows = (inputRows: RangeRow[]) => {
  const signalIndex = inputRows.findIndex(
    (row) => row.tone === 'signal' && row.confidence !== 'low',
  );

  return inputRows.map((row, index) => ({
    ...row,
    tone: index === signalIndex ? 'signal' : row.tone === 'signal' ? 'action' : row.tone ?? 'action',
    confidence: row.confidence ?? 'standard',
  }));
};

const renderedRows = normalizeRows(rows);
const evidenceLabel = evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs';
const showSource = !isSelfHostedSource(sourceUrl, reportPath);
---

<figure class="chart-range">
  <figcaption class="chart-range__header">
    <p class="label-mono">Chart proof</p>
    <h2>{title}</h2>
    <p class="prose">{caption}</p>
  </figcaption>

  <div class="chart-range__layout">
    <div
      class="chart-range__visual"
      role="img"
      aria-label={summary}
      style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
    >
      <p class="chart-range__summary">{summary}</p>

      <div class="chart-range__axis" aria-hidden="true">
        <div class="chart-range__axis-spacer"></div>
        <div class="chart-range__ticks">
          {GRIDLINE_PERCENTAGES.map((percentage, index) => (
            <span style={`left: ${percentage}%;`}>{tickLabels[index]}</span>
          ))}
        </div>
        <div class="chart-range__axis-value-spacer"></div>
      </div>

      <div class="chart-range__rows">
        {renderedRows.map((row) => (
          <div class="chart-range__row">
            <div class="chart-range__label">{row.label}</div>

            <div class="chart-range__track" aria-hidden="true">
              <div class="chart-range__gridlines">
                {GRIDLINE_PERCENTAGES.map((percentage) => (
                  <span style={`left: ${percentage}%;`}></span>
                ))}
              </div>

              <span
                class:list={[
                  'chart-range__band',
                  row.confidence === 'low' && 'chart-range__band--low-confidence',
                ]}
                style={`left: ${row.bandStart}%; width: ${row.bandEnd - row.bandStart}%;`}
              ></span>

              <span
                class:list={[
                  'chart-range__dot',
                  row.confidence === 'low'
                    ? 'chart-range__dot--low-confidence'
                    : row.tone === 'signal'
                      ? 'chart-range__dot--signal'
                      : 'chart-range__dot--action',
                ]}
                style={`left: ${row.medianPosition}%;`}
              ></span>
            </div>

            <div class="chart-range__value">
              <span class="chart-range__value-headline">{row.valueLabel}</span>
              {row.rangeLabel && <span class="chart-range__value-note">{row.rangeLabel}</span>}
            </div>
          </div>
        ))}
      </div>

      {note && <p class="chart-range__note">{note}</p>}

      <div class="chart-range__meta">
        {showSource && (
          <p class="chart-range__source">
            Source:{' '}
            <a href={sourceUrl} class="chart-range__source-link">
              {sourceLabel}
            </a>
          </p>
        )}

        <p class="chart-range__evidence">
          {evidenceLabel}: {evidenceIds.join(', ')}
        </p>
      </div>
    </div>

    <div class:list={['chart-range__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
      {resolvedTableMode === 'collapsed' ? (
        <details class="chart-range__table-disclosure">
          <summary class="label-mono chart-range__table-summary">View data table</summary>
          <div class="chart-range__table-wrap">
            <table class="chart-range__table">
              <thead>
                <tr>
                  <th>{fallbackColumns[0]}</th>
                  <th>{fallbackColumns[1]}</th>
                </tr>
              </thead>
              <tbody>
                {fallbackRows.map((row) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    <td>{row.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </details>
      ) : (
        <div class="chart-range__table-wrap">
          <table class="chart-range__table">
            <thead>
              <tr>
                <th>{fallbackColumns[0]}</th>
                <th>{fallbackColumns[1]}</th>
              </tr>
            </thead>
            <tbody>
              {fallbackRows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  <td>{row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</figure>

<style>
  .chart-range {
    margin: 0;
  }

  .chart-range__header h2 {
    margin-block: var(--space-4);
    font-family: var(--type-h2-face);
    font-size: var(--type-h2-size);
    line-height: var(--type-h2-leading);
    letter-spacing: var(--type-h2-tracking);
    font-weight: var(--weight-regular);
    text-rendering: auto;
  }

  .chart-range__layout {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .chart-range__visual {
    display: grid;
    gap: var(--space-5);
  }

  .chart-range__summary {
    margin: 0;
    color: var(--color-ink-muted);
    overflow-wrap: anywhere;
  }

  .chart-range__axis,
  .chart-range__row {
    display: grid;
    grid-template-columns: var(--chart-label-column) minmax(0, 1fr) auto;
    column-gap: var(--space-4);
    align-items: center;
  }

  .chart-range__axis {
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
  }

  .chart-range__ticks,
  .chart-range__track {
    position: relative;
  }

  .chart-range__ticks {
    height: 1.5rem;
  }

  .chart-range__ticks span,
  .chart-range__gridlines span {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border-subtle);
  }

  .chart-range__ticks span {
    background: none;
    width: auto;
    bottom: auto;
    transform: translateX(-50%);
  }

  .chart-range__rows {
    display: grid;
    gap: var(--space-4);
  }

  .chart-range__label {
    color: var(--color-ink);
    font-family: var(--font-data);
    line-height: 1.4;
    overflow-wrap: break-word;
  }

  .chart-range__track {
    min-height: 1.5rem;
  }

  .chart-range__gridlines {
    position: absolute;
    inset: 0;
  }

  /* Band is always chart-neutral at reduced emphasis — per §1d only the dot
     carries the tone-dependent colour, so the band never competes with it. */
  .chart-range__band {
    position: absolute;
    top: 50%;
    height: 5px;
    border-radius: 999px;
    background: var(--color-chart-neutral);
    opacity: 0.35;
    transform: translateY(-50%);
  }

  .chart-range__band--low-confidence {
    opacity: 1;
    background-color: transparent;
    background-image: repeating-linear-gradient(
      90deg,
      var(--color-chart-neutral) 0 4px,
      transparent 4px 8px
    );
  }

  .chart-range__dot {
    position: absolute;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 0 1px var(--color-border-strong);
  }

  .chart-range__dot--signal {
    background: var(--color-signal-fill);
  }

  .chart-range__dot--action {
    background: var(--color-action);
  }

  .chart-range__dot--low-confidence {
    width: 9px;
    height: 9px;
    background: var(--color-chart-neutral);
    box-shadow: none;
  }

  .chart-range__value {
    display: grid;
    justify-items: end;
    text-align: right;
    row-gap: 2px;
  }

  .chart-range__value-headline {
    font-family: var(--font-data);
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
  }

  .chart-range__value-note {
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    color: var(--color-ink-muted);
  }

  .chart-range__note {
    margin: 0;
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    line-height: var(--leading-ui);
    border-left: 1.5px solid var(--color-border-strong);
    padding-left: var(--space-3);
  }

  .chart-range__meta {
    display: grid;
    gap: var(--space-2);
  }

  .chart-range__source,
  .chart-range__evidence {
    margin: 0;
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    line-height: var(--leading-ui);
    overflow-wrap: anywhere;
  }

  .chart-range__source-link {
    display: inline-flex;
    color: var(--color-action);
    text-decoration: none;
    width: fit-content;
  }

  .chart-range__source-link:hover {
    text-decoration: underline;
  }

  .chart-range__support {
    display: grid;
    gap: var(--space-6);
  }

  .chart-range__table {
    width: 100%;
    border-collapse: collapse;
  }

  .chart-range__table th,
  .chart-range__table td {
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: left;
    vertical-align: top;
    overflow-wrap: break-word;
  }

  /* Accessible table alternative — removed from the visual flow only. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Collapsed table disclosure — quiet by default so it never competes with
     the chart visual above it. Native <details>/<summary>, no JS. */
  .chart-range__table-disclosure {
    border-top: 1px solid var(--color-border-subtle);
  }

  .chart-range__table-summary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 44px;
    color: var(--color-ink-muted);
    cursor: pointer;
    list-style: none;
  }

  .chart-range__table-summary::-webkit-details-marker {
    display: none;
  }

  .chart-range__table-summary::before {
    content: '▸';
    display: inline-block;
    transition: transform 120ms ease;
  }

  .chart-range__table-disclosure[open] > .chart-range__table-summary::before {
    transform: rotate(90deg);
  }

  .chart-range__table-summary:focus-visible {
    outline: 3px solid var(--color-signal-fill);
    outline-offset: 3px;
  }

  .chart-range__table-disclosure .chart-range__table-wrap {
    margin-top: var(--space-4);
  }

  .chart-range__table-disclosure .chart-range__table {
    font-size: var(--type-caption);
  }

  .chart-range__table-disclosure .chart-range__table th,
  .chart-range__table-disclosure .chart-range__table td {
    padding-block: var(--space-2);
  }

  .chart-range,
  .chart-range__visual,
  .chart-range__row,
  .chart-range__support {
    min-width: 0;
  }

  @media (max-width: 767px) {
    .chart-range__visual {
      --chart-label-column: min(220px, 38vw);
    }

    .chart-range__axis,
    .chart-range__row {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
    }

    .chart-range__axis-spacer,
    .chart-range__axis-value-spacer {
      display: none;
    }

    .chart-range__axis {
      display: none;
    }

    .chart-range__value {
      justify-items: start;
      text-align: left;
    }
  }
</style>
