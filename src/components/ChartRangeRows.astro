---
export type RangeTone = 'signal' | 'action';

export interface RangeRow {
  label: string;
  medianPosition: number;
  bandStart?: number;
  bandEnd?: number;
  whiskerStart?: number;
  whiskerEnd?: number;
  valueLabel: string;
  rangeLabel?: string;
  tone?: RangeTone;
  /**
   * "low" renders the band dashed and the dot as a smaller neutral marker,
   * regardless of tone — the DPA way of disclosing a thin sample without
   * deleting the row. Pair with rangeLabel explaining the n.
   */
  confidence?: 'standard' | 'low';
  /** Per-row finding callout, rendered under the row's track. */
  annotation?: string;
}

interface Props {
  rows: RangeRow[];
  /**
   * Tick text for the shared axis, paired with the fixed 0/25/50/75/100%
   * gridline positions. Defaults to plain percentages; pass domain-specific
   * labels (e.g. salary bands) instead.
   */
  axisTickLabels?: [string, string, string, string, string];
}

const LABEL_COLUMN_WIDTH_PX = 140;
const GRIDLINE_PERCENTAGES = [0, 25, 50, 75, 100] as const;
const DEFAULT_TICK_LABELS: [string, string, string, string, string] = [
  '0%',
  '25%',
  '50%',
  '75%',
  '100%',
];

const { rows, axisTickLabels } = Astro.props;

const tickLabels = axisTickLabels ?? DEFAULT_TICK_LABELS;

/**
 * §1d colour contract: at most one row carries the crimson signal tone.
 * A low-confidence row is never allowed to be the signal row — a thin
 * sample can't be "the one finding that matters".
 */
export const normalizeRows = (inputRows: RangeRow[]) => {
  const signalIndex = inputRows.findIndex(
    (row) => row.tone === 'signal' && row.confidence !== 'low',
  );

  return inputRows.map((row, index) => ({
    ...row,
    tone:
      index === signalIndex ? 'signal' : row.tone === 'signal' ? 'action' : row.tone ?? 'action',
    confidence: row.confidence ?? 'standard',
  }));
};

const renderedRows = normalizeRows(rows);
---

<div class="chart-range-rows" style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}>
  <div class="chart-range__axis" aria-hidden="true">
    <div class="chart-range__axis-spacer"></div>
    <div class="chart-range__ticks">
      {GRIDLINE_PERCENTAGES.map((percentage, index) => (
        <span style={`left: ${percentage}%;`}>{tickLabels[index]}</span>
      ))}
    </div>
    <div class="chart-range__axis-value-spacer"></div>
  </div>

  <div class="chart-range__rows">
    {renderedRows.map((row) => (
      <>
        <div class="chart-range__row">
          <div class="chart-range__label">{row.label}</div>

          <div class="chart-range__track" aria-hidden="true">
            <div class="chart-range__gridlines">
              {GRIDLINE_PERCENTAGES.map((percentage) => (
                <span style={`left: ${percentage}%;`}></span>
              ))}
            </div>

            {row.whiskerStart !== undefined && row.whiskerEnd !== undefined && (
              <span
                class="chart-range__whisker"
                style={`left: ${row.whiskerStart}%; width: ${row.whiskerEnd - row.whiskerStart}%;`}
              ></span>
            )}

            {row.bandStart !== undefined && row.bandEnd !== undefined && (
              <span
                class:list={[
                  'chart-range__band',
                  row.confidence === 'low' && 'chart-range__band--low-confidence',
                ]}
                style={`left: ${row.bandStart}%; width: ${row.bandEnd - row.bandStart}%;`}
              ></span>
            )}

            <span
              class:list={[
                'chart-range__dot',
                row.confidence === 'low'
                  ? 'chart-range__dot--low-confidence'
                  : row.tone === 'signal'
                    ? 'chart-range__dot--signal'
                    : 'chart-range__dot--action',
              ]}
              style={`left: ${row.medianPosition}%;`}
            ></span>
          </div>

          <div class="chart-range__value">
            <span class="chart-range__value-headline">{row.valueLabel}</span>
            {row.rangeLabel && <span class="chart-range__value-note">{row.rangeLabel}</span>}
          </div>
        </div>

        {row.annotation && <p class="chart-range__row-annotation">{row.annotation}</p>}
      </>
    ))}
  </div>
</div>

<style>
  .chart-range-rows,
  .chart-range__row {
    min-width: 0;
  }

  .chart-range__axis,
  .chart-range__row {
    display: grid;
    grid-template-columns: var(--chart-label-column) minmax(0, 1fr) auto;
    column-gap: var(--space-4);
    align-items: center;
  }

  .chart-range__axis {
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
  }

  .chart-range__ticks,
  .chart-range__track {
    position: relative;
  }

  .chart-range__ticks {
    height: 1.5rem;
  }

  .chart-range__ticks span,
  .chart-range__gridlines span {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border-subtle);
  }

  .chart-range__ticks span {
    background: none;
    width: auto;
    bottom: auto;
    transform: translateX(-50%);
  }

  .chart-range__rows {
    display: grid;
    gap: var(--space-4);
  }

  .chart-range__label {
    color: var(--color-ink);
    font-family: var(--font-data);
    line-height: 1.4;
    overflow-wrap: break-word;
  }

  .chart-range__track {
    min-height: 1.5rem;
  }

  .chart-range__gridlines {
    position: absolute;
    inset: 0;
  }

  /* New: faint min-max whisker, behind the band — same muted-ink language
     as the band's own opacity treatment, thinner so it reads as structural
     context (the row's full range), not a second data mark competing with
     the band or dot. */
  .chart-range__whisker {
    position: absolute;
    top: 50%;
    height: 1.5px;
    background: var(--color-border-strong);
    opacity: 0.35;
    transform: translateY(-50%);
  }

  /* Band is always chart-neutral at reduced emphasis — per §1d only the dot
     carries the tone-dependent colour, so the band never competes with it. */
  .chart-range__band {
    position: absolute;
    top: 50%;
    height: 5px;
    border-radius: 999px;
    background: var(--color-chart-neutral);
    opacity: 0.35;
    transform: translateY(-50%);
  }

  .chart-range__band--low-confidence {
    opacity: 1;
    background-color: transparent;
    background-image: repeating-linear-gradient(
      90deg,
      var(--color-chart-neutral) 0 4px,
      transparent 4px 8px
    );
  }

  .chart-range__dot {
    position: absolute;
    top: 50%;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-surface);
    box-shadow: 0 0 0 1px var(--color-border-strong);
  }

  .chart-range__dot--signal {
    background: var(--color-signal-fill);
  }

  .chart-range__dot--action {
    background: var(--color-action);
  }

  .chart-range__dot--low-confidence {
    width: 9px;
    height: 9px;
    background: var(--color-chart-neutral);
    box-shadow: none;
  }

  .chart-range__value {
    display: grid;
    justify-items: end;
    text-align: right;
    row-gap: 2px;
  }

  .chart-range__value-headline {
    font-family: var(--font-data);
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .chart-range__value-note {
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    color: var(--color-ink-muted);
    overflow-wrap: break-word;
  }

  /* New: per-row finding callout, block-level under the row it labels — not
     positioned at a computed x-coordinate (see design note's "Corrections"
     section for why). Indented to align under the track, not the label. */
  .chart-range__row-annotation {
    margin: 0;
    margin-top: calc(-1 * var(--space-2));
    margin-inline-start: var(--chart-label-column);
    padding-inline-start: var(--space-4);
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
  }

  /* Container query, not a viewport media query: see ChartBlock.astro for
     the same pattern and threshold reasoning. */
  @container (max-width: 600px) {
    .chart-range-rows {
      --chart-label-column: min(220px, 38vw);
    }

    .chart-range__axis,
    .chart-range__row {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
    }

    .chart-range__axis-spacer,
    .chart-range__axis-value-spacer {
      display: none;
    }

    .chart-range__axis {
      display: none;
    }

    .chart-range__value {
      justify-items: start;
      text-align: left;
    }

    .chart-range__row-annotation {
      margin-inline-start: 0;
    }
  }
</style>
