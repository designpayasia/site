---
import Blob from './Blob.astro';

interface Props {
  question?: string;
  questionDraft?: boolean;
  draftLabel?: string;
}

const {
  question,
  questionDraft = true,
  draftLabel = 'Draft for Jon',
} = Astro.props;

const cleanQuestion = question?.trim();
---

<section class="invitation" aria-label="Invitation">
  <div class="invitation__inner">
  <Blob
    as="fill"
    aspect={1}
    size={40}
    fill="var(--color-signal-fill)"
    class="invitation__marker"
    aria-hidden="true"
  />

    {cleanQuestion && (
      <h2 id="invitation-question" class="invitation__question t-h2">
        {cleanQuestion}
      </h2>
    )}

    {questionDraft && <span class="invitation__flag label-mono">{draftLabel}</span>}
  </div>
</section>

<style>
  .invitation {
    color: var(--color-workhorse);
    padding-block: var(--space-32);
  }

  .invitation__inner {
    display: grid;
    justify-items: center;
    gap: 0.9rem;
    text-align: center;
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .invitation__marker {
    width: 40px;
    min-width: 40px;
    aspect-ratio: 1 / 1;
  }

  .invitation__question {
    margin: 0;
    max-width: 20ch;
    overflow-wrap: break-word;
  }

  .invitation__flag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    color: var(--color-ink-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 767px) {
    .invitation__inner {
      padding-inline: var(--space-4);
    }
  }
</style>
