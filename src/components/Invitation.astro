---
import Blob from './Blob.astro';

interface Props {
  question?: string;
  questionDraft?: boolean;
  draftLabel?: string;
}

const {
  question,
  questionDraft = true,
  draftLabel = 'Draft for Jon',
} = Astro.props;

const cleanQuestion = question?.trim();
---

<section class="invitation" aria-label="Invitation">
  <div class="invitation__inner">
  <Blob
    as="fill"
    aspect={1}
    size={40}
    fill="var(--color-signal-fill)"
    class="invitation__marker"
    aria-hidden="true"
  />

    {cleanQuestion && (
      <h2 id="invitation-question" class="invitation__question">
        {cleanQuestion}
      </h2>
    )}

    {questionDraft && <span class="invitation__flag label-mono">{draftLabel}</span>}
  </div>
</section>

<style>
  .invitation {
    color: var(--color-workhorse);
  }

  .invitation__inner {
    display: grid;
    justify-items: center;
    gap: 0.9rem;
    text-align: center;
  }

  .invitation__marker {
    width: 40px;
    min-width: 40px;
    aspect-ratio: 1 / 1;
  }

  .invitation__question {
    margin: 0;
    max-width: 20ch;
    font-family: var(--type-h2-face);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: var(--type-h2-tracking);
    color: var(--color-workhorse);
  }

  .invitation__flag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    color: var(--color-ink-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
</style>
