---
interface Props {
  value: string;
  unit?: string;
  label: string;
  color?: 'workhorse' | 'signal';
  countUp?: boolean;
  variant?: 'hero' | 'finding' | 'compact';
}

const { value, unit, label, color = 'workhorse', countUp = false, variant = 'finding' } = Astro.props;
const numericValue = parseFloat(value.replace(/,/g, ''));
const decimals = value.includes('.') ? (value.split('.')[1].match(/\d+/)?.[0].length ?? 0) : 0;
---

<div class:list={['bigstat', `bigstat--${color}`]}>
  <p class="bigstat__figure" aria-label={`${value}${unit ? unit : ''} ${label}`}>
    <span
      class="bigstat__value"
      data-count-target={countUp && !Number.isNaN(numericValue) ? numericValue : undefined}
      data-count-decimals={countUp ? decimals : undefined}
    >
      {value}
    </span>
    {unit && <span class="bigstat__unit">{unit}</span>}
  </p>
  <p class="bigstat__label">{label}</p>
</div>

<script is:inline>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const format = (n, decimals) =>
    n.toLocaleString(undefined, {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });

  const animateCount = (el, target, decimals = 0) => {
    if (prefersReducedMotion) {
      el.textContent = format(target, decimals);
      return;
    }

    const duration = 1400;
    const start = performance.now();

    const tick = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = target * eased;

      el.textContent = format(current, decimals);

      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    };

    requestAnimationFrame(tick);
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) {
          return;
        }

        const el = entry.target;
        const target = parseFloat(el.dataset.countTarget ?? '');
        const decimals = parseInt(el.dataset.countDecimals ?? '0', 10);

        if (!Number.isNaN(target)) {
          animateCount(el, target, decimals);
        }

        observer.unobserve(el);
      });
    },
    { threshold: 0.5 },
  );

  document.querySelectorAll('[data-count-target]').forEach((el) => observer.observe(el));
</script>

<style>
  .bigstat {
    display: grid;
    gap: var(--space-2);
    overflow: hidden;
    min-width: 0;
    max-width: 100%;
    container-type: inline-size;
  }

  /* Variant: hero — maximum impact, homepage hero blob */
  .bigstat--hero {
    --_bigstat-size: clamp(4rem, 5vw, var(--type-stat-size));
    --_unit-size: 0.42em;
    --_label-size: var(--type-body);
    --_label-lh: var(--leading-body);
  }

  /* Variant: finding — medium, findings strip + dark beat (default) */
  .bigstat--finding {
    --_bigstat-size: clamp(2.5rem, 3.5vw, 5rem);
    --_unit-size: 0.35em;
    --_label-size: var(--font-size-sm);
    --_label-lh: var(--leading-caption);
  }

  /* Variant: compact — small, report page grid cells, no overflow */
  .bigstat--compact {
    --_bigstat-size: clamp(1.75rem, 2.5vw, 3rem);
    --_unit-size: 0.32em;
    --_label-size: var(--font-size-xs);
    --_label-lh: 1.3;
  }

  .bigstat__figure {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.08em;
    overflow: hidden;
    min-width: 0;
    font-family: var(--type-stat-face); /* R2 — DM Mono, not display serif */
    font-size: var(--_bigstat-size, var(--type-stat-size));
    line-height: var(--type-stat-leading);
    letter-spacing: var(--type-stat-tracking);
  }

  @media (max-width: 767px) {
    .bigstat__figure {
      font-size: var(--t-display-mobile); /* R1 — narrow-viewport display size */
    }
  }

  .bigstat__value {
    font-variant-numeric: lining-nums;
    min-width: 0;
  }

  .bigstat__unit {
    font-size: var(--_unit-size, 0.42em);
    overflow-wrap: break-word;
    max-width: 100%;
    min-width: 0;
  }

  .bigstat__label {
    margin: 0;
    font-size: var(--_label-size, var(--type-body));
    overflow-wrap: break-word;
    max-width: 100%;
    line-height: var(--_label-lh, var(--leading-body));
    color: var(--color-ink-muted);
  }

  .bigstat--workhorse .bigstat__figure {
    color: var(--color-workhorse);
  }

  .bigstat--signal .bigstat__figure {
    color: var(--color-signal-text);
  }
</style>
