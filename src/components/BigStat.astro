---
interface Props {
  value: string;
  unit?: string;
  label: string;
  color?: 'workhorse' | 'signal';
  countUp?: boolean;
  variant?: 'hero' | 'finding' | 'compact';
}

const { value, unit, label, color = 'workhorse', countUp = false, variant = 'finding' } = Astro.props;
const displayValue = value.trim();
const normalizedUnit = unit?.trim();
const valueMatch = displayValue.match(/^([^0-9]*)(\d[\d,]*(?:\.\d+)?)(.*)$/);
const valuePrefix = valueMatch?.[1] ?? '';
const valueCore = valueMatch?.[2] ?? displayValue;
const valueSuffix = valueMatch?.[3]?.trim() ?? '';
const numericValue = parseFloat(valueCore.replace(/,/g, ''));
const decimals = valueCore.includes('.') ? (valueCore.split('.')[1].match(/\d+/)?.[0].length ?? 0) : 0;
const stackUnit = Boolean(normalizedUnit && (normalizedUnit.length > 8 || /\s/.test(normalizedUnit)));
---

<div
  class:list={[
    'bigstat',
    `bigstat--${color}`,
    `bigstat--${variant}`,
    {
      'bigstat--unit-stacked': stackUnit,
    },
  ]}
>
  <p class="bigstat__figure" aria-label={`${value}${normalizedUnit ? ` ${normalizedUnit}` : ''} ${label}`}>
    {valuePrefix && <span class="bigstat__affix bigstat__affix--prefix">{valuePrefix}</span>}
    <span
      class="bigstat__value"
      data-count-target={countUp && !Number.isNaN(numericValue) ? numericValue : undefined}
      data-count-decimals={countUp ? decimals : undefined}
    >
      {valueCore}
    </span>
    {valueSuffix && <span class="bigstat__affix bigstat__affix--suffix">{valueSuffix}</span>}
    {normalizedUnit && <span class="bigstat__unit">{normalizedUnit}</span>}
  </p>
  <p class="bigstat__label">{label}</p>
</div>

<script is:inline>
  (() => {
    const root = document.currentScript?.previousElementSibling;
    const countTarget = root?.querySelector('[data-count-target]');
    if (!(countTarget instanceof HTMLElement)) {
      return;
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const format = (n, decimals) =>
      n.toLocaleString(undefined, {
        minimumFractionDigits: decimals,
        maximumFractionDigits: decimals,
      });

    const animateCount = (el, target, decimals = 0) => {
      if (prefersReducedMotion) {
        el.textContent = format(target, decimals);
        return;
      }

      const duration = 1400;
      const start = performance.now();

      const tick = (now) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = target * eased;

        el.textContent = format(current, decimals);

        if (progress < 1) {
          requestAnimationFrame(tick);
        }
      };

      requestAnimationFrame(tick);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            return;
          }

          const el = entry.target;
          const target = parseFloat(el.dataset.countTarget ?? '');
          const decimals = parseInt(el.dataset.countDecimals ?? '0', 10);

          if (!Number.isNaN(target)) {
            animateCount(el, target, decimals);
          }

          observer.unobserve(el);
        });
      },
      { threshold: 0.5 },
    );

    observer.observe(countTarget);
  })();
</script>

<style>
  .bigstat {
    display: grid;
    gap: var(--space-2);
    overflow: hidden;
    min-width: 0;
    max-width: 100%;
    container-type: inline-size;
  }

  /* Variant: hero — maximum impact, homepage hero blob */
  .bigstat--hero {
    --_bigstat-size: clamp(4rem, 5cqi, var(--type-stat-size));
    --_unit-size: 0.42em;
    --_label-size: var(--type-body);
    --_label-lh: var(--leading-body);
  }

  /* Variant: finding — medium, findings strip + dark beat (default) */
  .bigstat--finding {
    --_bigstat-size: clamp(2.5rem, 40cqi, 10rem);
    --_unit-size: 0.35em;
    --_label-size: var(--font-size-sm);
    --_label-lh: var(--leading-caption);
  }

  /* Variant: compact — small, report page grid cells, no overflow */
  .bigstat--compact {
    --_bigstat-size: clamp(1.75rem, 40cqi, 10rem);
    --_unit-size: 0.32em;
    --_label-size: var(--font-size-xs);
    --_label-lh: 1.3;
  }

  .bigstat__figure {
    margin: 0;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.12em;
    overflow: hidden;
    min-width: 0;
    font-family: var(--type-stat-face); /* R2 — DM Mono, not display serif */
    font-size: var(--_bigstat-size, var(--type-stat-size));
    line-height: var(--type-stat-leading);
    letter-spacing: var(--type-stat-tracking);
  }

  @media (max-width: 767px) {
    .bigstat__figure {
      font-size: var(--t-display-mobile); /* R1 — narrow-viewport display size */
    }
  }

  .bigstat__value {
    font-variant-numeric: lining-nums;
    min-width: 0;
  }

  .bigstat__affix {
    min-width: 0;
    max-width: 100%;
    font-size: var(--_unit-size, 0.42em);
    line-height: 1;
    white-space: nowrap;
  }

  .bigstat__unit {
    line-height: 1.2;
    font-size: var(--_unit-size, 0.42em);
    overflow-wrap: anywhere;
    max-width: 100%;
    min-width: 0;
    white-space: nowrap;
  }

  .bigstat--unit-stacked .bigstat__unit {
    flex-basis: 100%;
    white-space: normal;
  }

  .bigstat__label {
    margin: 0;
    font-size: var(--_label-size, var(--type-body));
    overflow-wrap: break-word;
    max-width: 100%;
    line-height: var(--_label-lh, var(--leading-body));
    color: var(--color-ink-muted);
  }

  .bigstat--workhorse .bigstat__figure {
    color: var(--color-workhorse);
  }

  .bigstat--signal .bigstat__figure {
    color: var(--color-signal-text);
  }
</style>
