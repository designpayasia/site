---
import { isSelfHostedSource } from '../lib/evidence';

interface TableRow {
  label: string;
  value: string;
}

interface Bar {
  label: string;
  value: number;
  tone?: 'workhorse' | 'signal';
}

interface Segment {
  id: string;
  label: string;
  caption: string;
  summary: string;
  averageLabel?: string;
  bars: Bar[];
  fallbackColumns: [string, string];
  fallbackRows: TableRow[];
}

/**
 * Filter-control variant (progressive enhancement). One segmented button
 * shows one variant's bars/table/summary at a time; the rest render
 * server-side too but sit `hidden`. Unlike `Segment`, each variant carries
 * its own evidence and may override the chart's source.
 *
 * Frontmatter shape (do not migrate existing charts yet — see chartSchema in
 * src/content.config.ts):
 *
 * ```yaml
 * variants:
 *   - label: Singapore
 *     summary: Bar chart showing ...
 *     evidenceIds: [evidence:2024-singapore-cut]
 *     sourceLabel: Design Pay Asia 2024 Survey — Singapore cut
 *     sourceUrl: https://designpay.asia/reports/2024
 *     bars:
 *       - label: 0-3 years
 *         value: 41.2
 *     fallbackTable:
 *       columns: [Experience, Respondents]
 *       rows:
 *         - label: 0-3 years
 *           value: "62 (41.2%)"
 * ```
 */
interface Variant {
  label: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel?: string;
  sourceUrl?: string;
  bars: Bar[];
  fallbackColumns: [string, string];
  fallbackRows: TableRow[];
}

interface Props {
  title: string;
  caption: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel: string;
  sourceUrl: string;
  reportPath?: string;
  fallbackColumns: [string, string];
  fallbackRows: TableRow[];
  bars: Bar[];
  pngPath?: string;
  /**
   * Pre-rendered Observable Plot SVG markup (build-time only — see
   * `src/lib/plot.ts`). When present it replaces the bars track in the
   * chart zone; everything else (header, meta, fallback table,
   * segments/variants) is unaffected. The SVG is inert (no client JS) and
   * carries its own `aria-hidden="true"`, so the `summary` prop remains
   * the sole accessible representation alongside the fallback table.
   * Mutually exclusive with `pngPath` — `pngPath` wins if both are set.
   */
  plotSvg?: string;
  /**
   * Optional plain-text headline stat rendered above the distribution bars
   * (e.g. "Mean: 4.57 / 7"). Used for Likert-style rating charts where the
   * bare 1-7 bar labels give no sense of central tendency on their own.
   */
  averageLabel?: string;
  segments?: Segment[];
  defaultSegmentLabel?: string;
  /**
   * Filter-control variants — see the `Variant` interface above. Renders a
   * segmented button group; the first variant is visible by default
   * (no-JS-safe). Mutually exclusive with `segments`.
   */
  variants?: Variant[];
  /**
   * When true (report hub overview), the visible fallback table is suppressed
   * and the treatment tightens. The table is still rendered as a
   * visually-hidden accessible alternative so screen-reader and no-JS users
   * keep the full data. Detail pages omit this prop and keep the full table.
   *
   * @deprecated Use `tableMode="hidden"` instead. Kept for back-compat: when
   * `tableMode` is not explicitly passed, `hideTable: true` resolves to
   * `tableMode: 'hidden'`.
   */
  hideTable?: boolean;
  /**
   * Controls how the fallback data table renders relative to the chart
   * visual. Defaults to `'collapsed'` so the table never competes with the
   * rendered chart.
   * - 'collapsed' — table sits inside a closed `<details>` disclosure.
   * - 'open' — prominent table, always expanded (table-only usage).
   * - 'hidden' — visually-hidden accessible alternative only.
   */
  tableMode?: 'collapsed' | 'open' | 'hidden';
}

const LABEL_COLUMN_WIDTH_PX = 220;
const GRIDLINE_PERCENTAGES = [0, 25, 50, 75, 100] as const;

const {
  title,
  caption,
  summary,
  evidenceIds,
  sourceLabel,
  sourceUrl,
  reportPath,
  fallbackColumns,
  fallbackRows,
  bars,
  segments,
  defaultSegmentLabel,
  variants,
  pngPath,
  plotSvg,
  averageLabel,
  hideTable = false,
  tableMode,
} = Astro.props;

const resolvedTableMode: 'collapsed' | 'open' | 'hidden' =
  tableMode ?? (hideTable ? 'hidden' : 'collapsed');

const segmentList = segments ?? [];
const hasSegments = segmentList.length > 0;

const normalizeBars = (inputBars: Bar[]) => {
  const highlightedSignalIndex = inputBars.findIndex((bar) => bar.tone === 'signal');

  return inputBars.map((bar, index) => ({
    ...bar,
    tone:
      highlightedSignalIndex !== -1 && index === highlightedSignalIndex
        ? 'signal'
        : 'workhorse',
  }));
};

const renderedBars = normalizeBars(bars);
const evidenceLabel = evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs';
const showSource = !isSelfHostedSource(sourceUrl, reportPath);
const makeBlockId = (...parts: Array<string | undefined>) =>
  parts
    .filter(Boolean)
    .join(' ')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'chart-block';
const chartBlockId = makeBlockId(title, sourceLabel, reportPath, evidenceIds.join('-'));
const defaultTabId = `${chartBlockId}-tab-default`;
const defaultPanelId = `${chartBlockId}-panel-default`;
const segmentedViews = hasSegments
  ? [
      {
        id: 'default',
        label: defaultSegmentLabel,
        caption,
        summary,
        averageLabel,
        fallbackColumns,
        fallbackRows,
        renderedBars,
        pngPath,
        tabId: defaultTabId,
        panelId: defaultPanelId,
      },
      ...segmentList.map((segment) => ({
        ...segment,
        pngPath: undefined,
        tabId: `${chartBlockId}-tab-${segment.id}`,
        panelId: `${chartBlockId}-panel-${segment.id}`,
        renderedBars: normalizeBars(segment.bars),
      })),
    ]
  : [];

const variantList = variants ?? [];
const hasVariants = variantList.length > 0;
const variantViews = hasVariants
  ? variantList.map((variant) => {
      const variantSourceLabel = variant.sourceLabel ?? sourceLabel;
      const variantSourceUrl = variant.sourceUrl ?? sourceUrl;
      const variantBlockId = makeBlockId(chartBlockId, variant.label);

      return {
        ...variant,
        sourceLabel: variantSourceLabel,
        sourceUrl: variantSourceUrl,
        showSource: !isSelfHostedSource(variantSourceUrl, reportPath),
        renderedBars: normalizeBars(variant.bars),
        evidenceLabel: variant.evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs',
        buttonId: `${variantBlockId}-variant-button`,
        panelId: `${variantBlockId}-variant-panel`,
      };
    })
  : [];
---

<figure
  class:list={[
    'chart-block',
    hideTable && 'chart-block--compact',
    hasSegments && 'chart-block--segments',
    hasVariants && 'chart-block--variants',
  ]}
>
  {hasVariants ? (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
        <p class="prose">{caption}</p>
      </figcaption>

      <div class="chart-block__variants" data-chart-block-variants>
        <div
          class="chart-block__variant-control"
          role="group"
          aria-label={`Filter ${title}`}
        >
          {variantViews.map((view, index) => (
            <button
              type="button"
              id={view.buttonId}
              aria-pressed={index === 0 ? 'true' : 'false'}
              aria-controls={view.panelId}
              class:list={['btn', index === 0 ? 'btn--primary' : 'btn--secondary']}
              data-chart-variant-button
            >
              {view.label}
            </button>
          ))}
        </div>

        {variantViews.map((view, index) => (
          <section
            id={view.panelId}
            class="chart-block__variant-panel"
            aria-labelledby={view.buttonId}
            hidden={index !== 0}
            data-chart-variant-panel
          >
            <div class="chart-block__layout">
              <div
                class="chart-block__visual"
                role="img"
                aria-label={view.summary}
                style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
              >
                <p class="chart-block__summary">{view.summary}</p>

                <div class="chart-block__axis" aria-hidden="true">
                  <div class="chart-block__axis-spacer"></div>
                  <div class="chart-block__ticks">
                    {GRIDLINE_PERCENTAGES.map((percentage) => (
                      <span style={`left: ${percentage}%;`}>{percentage}%</span>
                    ))}
                  </div>
                  <div class="chart-block__axis-value-spacer"></div>
                </div>

                <div class="chart-block__bars">
                  {view.renderedBars.map((bar) => (
                    <div class="chart-block__row">
                      <div
                        class:list={[
                          'chart-block__label',
                          bar.tone === 'signal' && 'chart-block__label--signal',
                        ]}
                      >
                        {bar.label}
                      </div>

                      <div class="chart-block__track" aria-hidden="true">
                        <div class="chart-block__gridlines">
                          {GRIDLINE_PERCENTAGES.map((percentage) => (
                            <span style={`left: ${percentage}%;`}></span>
                          ))}
                        </div>

                        <div
                          class:list={[
                            'chart-block__fill',
                            bar.tone === 'signal'
                              ? 'chart-block__fill--signal'
                              : 'chart-block__fill--workhorse',
                          ]}
                          style={`width: ${bar.value}%;`}
                        />
                      </div>

                      <div
                        class:list={[
                          'chart-block__value',
                          bar.tone === 'signal' && 'chart-block__value--signal',
                        ]}
                      >
                        {bar.value}%
                      </div>
                    </div>
                  ))}
                </div>

                <div class="chart-block__meta">
                  {view.showSource && (
                    <p class="chart-block__source">
                      Source:{' '}
                      <a href={view.sourceUrl} class="chart-block__source-link">
                        {view.sourceLabel}
                      </a>
                    </p>
                  )}

                  <p class="chart-block__evidence">
                    {view.evidenceLabel}: {view.evidenceIds.join(', ')}
                  </p>
                </div>
              </div>

              <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
                {resolvedTableMode === 'collapsed' ? (
                  <details class="chart-block__table-disclosure">
                    <summary class="label-mono chart-block__table-summary">View data table</summary>
                    <div class="chart-block__table-wrap">
                      <table class="chart-block__table">
                        <thead>
                          <tr>
                            <th>{view.fallbackColumns[0]}</th>
                            <th>{view.fallbackColumns[1]}</th>
                          </tr>
                        </thead>
                        <tbody>
                          {view.fallbackRows.map((row) => (
                            <tr>
                              <th scope="row">{row.label}</th>
                              <td>{row.value}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </details>
                ) : (
                  <div class="chart-block__table-wrap">
                    <table class="chart-block__table">
                      <thead>
                        <tr>
                          <th>{view.fallbackColumns[0]}</th>
                          <th>{view.fallbackColumns[1]}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {view.fallbackRows.map((row) => (
                          <tr>
                            <th scope="row">{row.label}</th>
                            <td>{row.value}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            </div>
          </section>
        ))}

        <script is:inline>
          // Wrapped in an IIFE (like the segments script below) so
          // multiple variant-enabled charts on one page never collide
          // by re-declaring the same block-scoped bindings in the
          // shared classic-script global environment.
          (function () {
            const variantsRoot = document.currentScript?.closest('[data-chart-block-variants]');

            if (!(variantsRoot instanceof HTMLElement)) {
              return;
            }

            variantsRoot.dataset.jsReady = 'true';

            const variantButtons = Array.from(
              variantsRoot.querySelectorAll('[data-chart-variant-button]'),
            );
            const variantPanels = Array.from(
              variantsRoot.querySelectorAll('[data-chart-variant-panel]'),
            );

            variantButtons.forEach((button, index) => {
              button.addEventListener('click', () => {
                variantButtons.forEach((otherButton, otherIndex) => {
                  const selected = otherIndex === index;
                  otherButton.setAttribute('aria-pressed', String(selected));
                  otherButton.classList.toggle('btn--primary', selected);
                  otherButton.classList.toggle('btn--secondary', !selected);
                });

                variantPanels.forEach((panel, panelIndex) => {
                  panel.hidden = panelIndex !== index;
                });
              });
            });
          })();
        </script>
      </div>
    </>
  ) : hasSegments ? (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
      </figcaption>

      <div class="chart-block__segments" data-chart-block-segments>
        <div class="chart-block__segment-tabs" role="tablist" aria-label={`${title} chart views`}>
          <button
            id={defaultTabId}
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls={defaultPanelId}
            tabindex="0"
            class="chart-block__segment-tab"
          >
            {defaultSegmentLabel}
          </button>

          {segmentList.map((segment) => (
            <button
              id={`${chartBlockId}-tab-${segment.id}`}
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls={`${chartBlockId}-panel-${segment.id}`}
              tabindex="-1"
              class="chart-block__segment-tab"
            >
              {segment.label}
            </button>
          ))}
        </div>

        <div class="chart-block__segment-panels">
          {segmentedViews.map((view, index) => (
            <section
              id={view.panelId}
              class="chart-block__segment-panel"
              role="tabpanel"
              aria-labelledby={view.tabId}
              hidden={index !== 0}
            >
              <p class="prose chart-block__segment-caption">{view.caption}</p>

              <div class="chart-block__layout">
                <div
                  class="chart-block__visual"
                  {...(!view.pngPath && { role: 'img', 'aria-label': view.summary })}
                  style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
                >
                  <p class="chart-block__summary">{view.summary}</p>

                  {view.averageLabel && (
                    <p class="chart-block__average">{view.averageLabel}</p>
                  )}

                  {view.pngPath ? (
                    <img
                      src={view.pngPath}
                      alt={view.summary}
                      class="chart-block__png-image"
                      loading="lazy"
                    />
                  ) : (
                    <>
                      <div class="chart-block__axis" aria-hidden="true">
                        <div class="chart-block__axis-spacer"></div>
                        <div class="chart-block__ticks">
                          {GRIDLINE_PERCENTAGES.map((percentage) => (
                            <span style={`left: ${percentage}%;`}>{percentage}%</span>
                          ))}
                        </div>
                        <div class="chart-block__axis-value-spacer"></div>
                      </div>

                      <div class="chart-block__bars">
                        {view.renderedBars.map((bar) => (
                          <div class="chart-block__row">
                            <div
                              class:list={[
                                'chart-block__label',
                                bar.tone === 'signal' && 'chart-block__label--signal',
                              ]}
                            >
                              {bar.label}
                            </div>

                            <div class="chart-block__track" aria-hidden="true">
                              <div class="chart-block__gridlines">
                                {GRIDLINE_PERCENTAGES.map((percentage) => (
                                  <span style={`left: ${percentage}%;`}></span>
                                ))}
                              </div>

                              <div
                                class:list={[
                                  'chart-block__fill',
                                  bar.tone === 'signal'
                                    ? 'chart-block__fill--signal'
                                    : 'chart-block__fill--workhorse',
                                ]}
                                style={`width: ${bar.value}%;`}
                              />
                            </div>

                            <div
                              class:list={[
                                'chart-block__value',
                                bar.tone === 'signal' && 'chart-block__value--signal',
                              ]}
                            >
                              {bar.value}%
                            </div>
                          </div>
                        ))}
                      </div>
                    </>
                  )}

                  <div class="chart-block__meta">
                    {showSource && (
                      <p class="chart-block__source">
                        Source:{' '}
                        <a href={sourceUrl} class="chart-block__source-link">
                          {sourceLabel}
                        </a>
                      </p>
                    )}

                    <p class="chart-block__evidence">
                      {evidenceLabel}: {evidenceIds.join(', ')}
                    </p>

                    {view.pngPath && (
                      <a href={view.pngPath} class="chart-block__png-link">
                        Download PNG proof
                      </a>
                    )}
                  </div>
                </div>

                <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
                  {resolvedTableMode === 'collapsed' ? (
                    <details class="chart-block__table-disclosure">
                      <summary class="label-mono chart-block__table-summary">View data table</summary>
                      <div class="chart-block__table-wrap">
                        <table class="chart-block__table">
                          <thead>
                            <tr>
                              <th>{view.fallbackColumns[0]}</th>
                              <th>{view.fallbackColumns[1]}</th>
                            </tr>
                          </thead>
                          <tbody>
                            {view.fallbackRows.map((row) => (
                              <tr>
                                <th scope="row">{row.label}</th>
                                <td>{row.value}</td>
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </details>
                  ) : (
                    <div class="chart-block__table-wrap">
                      <table class="chart-block__table">
                        <thead>
                          <tr>
                            <th>{view.fallbackColumns[0]}</th>
                            <th>{view.fallbackColumns[1]}</th>
                          </tr>
                        </thead>
                        <tbody>
                          {view.fallbackRows.map((row) => (
                            <tr>
                              <th scope="row">{row.label}</th>
                              <td>{row.value}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </div>
              </div>
            </section>
          ))}
        </div>
      <script is:inline>
        // Wrapped in an IIFE so multiple segmented charts on one page
        // never collide by re-declaring the same block-scoped bindings
        // in the shared classic-script global environment.
        (function () {
          const root = document.currentScript?.closest('[data-chart-block-segments]');

          if (!(root instanceof HTMLElement)) {
            return;
          }

          const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
          const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));

          const activate = (index, focus = false) => {
            tabs.forEach((tab, tabIndex) => {
              const selected = tabIndex === index;
              tab.setAttribute('aria-selected', String(selected));
              tab.tabIndex = selected ? 0 : -1;
            });

            panels.forEach((panel, panelIndex) => {
              panel.hidden = panelIndex !== index;
            });

            if (focus) {
              tabs[index]?.focus();
            }
          };

          tabs.forEach((tab, index) => {
            tab.addEventListener('click', () => activate(index));
            tab.addEventListener('keydown', (event) => {
              const { key } = event;

              if (key !== 'ArrowLeft' && key !== 'ArrowRight' && key !== 'Home' && key !== 'End') {
                return;
              }

              event.preventDefault();

              const lastIndex = tabs.length - 1;
              let nextIndex = index;

              if (key === 'ArrowLeft') {
                nextIndex = index === 0 ? lastIndex : index - 1;
              } else if (key === 'ArrowRight') {
                nextIndex = index === lastIndex ? 0 : index + 1;
              } else if (key === 'Home') {
                nextIndex = 0;
              } else if (key === 'End') {
                nextIndex = lastIndex;
              }

              activate(nextIndex, true);
            });
          });
        })();
      </script>
      </div>
    </>
  ) : (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
        <p class="prose">{caption}</p>
      </figcaption>

      <div class="chart-block__layout">
        <div
          class="chart-block__visual"
          {...(!pngPath && { role: 'img', 'aria-label': summary })}
          style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
        >
          <p class="chart-block__summary">{summary}</p>

          {averageLabel && (
            <p class="chart-block__average">{averageLabel}</p>
          )}

          {pngPath ? (
            <img
              src={pngPath}
              alt={summary}
              class="chart-block__png-image"
              loading="lazy"
            />
          ) : plotSvg ? (
            <div class="chart-block__plot" set:html={plotSvg} />
          ) : (
            <>
              <div class="chart-block__axis" aria-hidden="true">
                <div class="chart-block__axis-spacer"></div>
                <div class="chart-block__ticks">
                  {GRIDLINE_PERCENTAGES.map((percentage) => (
                    <span style={`left: ${percentage}%;`}>{percentage}%</span>
                  ))}
                </div>
                <div class="chart-block__axis-value-spacer"></div>
              </div>

              <div class="chart-block__bars">
                {renderedBars.map((bar) => (
                  <div class="chart-block__row">
                    <div
                      class:list={[
                        'chart-block__label',
                        bar.tone === 'signal' && 'chart-block__label--signal',
                      ]}
                    >
                      {bar.label}
                    </div>

                    <div class="chart-block__track" aria-hidden="true">
                      <div class="chart-block__gridlines">
                        {GRIDLINE_PERCENTAGES.map((percentage) => (
                          <span style={`left: ${percentage}%;`}></span>
                        ))}
                      </div>

                      <div
                        class:list={[
                          'chart-block__fill',
                          bar.tone === 'signal'
                            ? 'chart-block__fill--signal'
                            : 'chart-block__fill--workhorse',
                        ]}
                        style={`width: ${bar.value}%;`}
                      />
                    </div>

                    <div
                      class:list={[
                        'chart-block__value',
                        bar.tone === 'signal' && 'chart-block__value--signal',
                      ]}
                    >
                      {bar.value}%
                    </div>
                  </div>
                ))}
              </div>
            </>
          )}

          <div class="chart-block__meta">
            {showSource && (
              <p class="chart-block__source">
                Source:{' '}
                <a href={sourceUrl} class="chart-block__source-link">
                  {sourceLabel}
                </a>
              </p>
            )}

            <p class="chart-block__evidence">
              {evidenceLabel}: {evidenceIds.join(', ')}
            </p>

            {pngPath && (
              <a href={pngPath} class="chart-block__png-link">
                Download PNG proof
              </a>
            )}
          </div>
        </div>

        <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
          {resolvedTableMode === 'collapsed' ? (
            <details class="chart-block__table-disclosure">
              <summary class="label-mono chart-block__table-summary">View data table</summary>
              <div class="chart-block__table-wrap">
                <table class="chart-block__table">
                  <thead>
                    <tr>
                      <th>{fallbackColumns[0]}</th>
                      <th>{fallbackColumns[1]}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {fallbackRows.map((row) => (
                      <tr>
                        <th scope="row">{row.label}</th>
                        <td>{row.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          ) : (
            <div class="chart-block__table-wrap">
              <table class="chart-block__table">
                <thead>
                  <tr>
                    <th>{fallbackColumns[0]}</th>
                    <th>{fallbackColumns[1]}</th>
                  </tr>
                </thead>
                <tbody>
                  {fallbackRows.map((row) => (
                    <tr>
                      <th scope="row">{row.label}</th>
                      <td>{row.value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </>
  )}
</figure>

<style>
  .chart-block {
    margin: 0;
  }

  /* Compact (report hub overview): tighter rhythm, table suppressed visually
