---
import { isSelfHostedSource } from '../lib/evidence';

interface TableRow {
  label: string;
  /** Legacy single-value shape — only valid alongside a 2-column table. */
  value?: string;
  /** N-column shape: one printed value per non-label fallbackColumns entry. */
  values?: string[];
}

/** Row shape after normalisation: always a `values` array, so every table
 * branch below can render N columns without re-checking which shape the
 * source data used. */
interface NormalizedTableRow {
  label: string;
  values: string[];
}

interface Bar {
  label: string;
  value: number;
  tone?: 'workhorse' | 'signal';
  /** Overrides the printed value text (e.g. "S$123,000"); width still derives from `value`. */
  displayValue?: string;
}

interface Segment {
  id: string;
  label: string;
  caption: string;
  summary: string;
  averageLabel?: string;
  bars: Bar[];
  /** 2–6 printed header cells: `[0]` is the row-label column. */
  fallbackColumns: string[];
  fallbackRows: TableRow[];
}

/**
 * Filter-control variant (progressive enhancement). One segmented button
 * shows one variant's bars/table/summary at a time; the rest render
 * server-side too but sit `hidden`. Unlike `Segment`, each variant carries
 * its own evidence and may override the chart's source.
 *
 * Frontmatter shape (do not migrate existing charts yet — see chartSchema in
 * src/content.config.ts):
 *
 * ```yaml
 * variants:
 *   - label: Singapore
 *     summary: Bar chart showing ...
 *     evidenceIds: [evidence:2024-singapore-cut]
 *     sourceLabel: Design Pay Asia 2024 Survey — Singapore cut
 *     sourceUrl: https://designpay.asia/reports/2024
 *     bars:
 *       - label: 0-3 years
 *         value: 41.2
 *     fallbackTable:
 *       columns: [Experience, Respondents]
 *       rows:
 *         - label: 0-3 years
 *           value: "62 (41.2%)"
 * ```
 */
interface Variant {
  label: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel?: string;
  sourceUrl?: string;
  bars: Bar[];
  /**
   * Pre-rendered Observable Plot SVG for this variant — same contract as
   * the top-level `plotSvg` prop: when present it replaces the variant's
   * axis + bars track; the variant's fallback table is unaffected.
   * Byte-parity note: in the variants template the plot/bars ternary sits
   * flush against its neighbouring tags, and no JSX comment may precede
   * it — each expression slot and template newline collapses to a space
   * in emitted HTML, and any extra one breaks parity with the pre-plot
   * bars markup.
   */
  plotSvg?: string;
  /** 2–6 printed header cells: `[0]` is the row-label column. */
  fallbackColumns: string[];
  fallbackRows: TableRow[];
}

interface Props {
  title: string;
  caption: string;
  summary: string;
  evidenceIds: string[];
  sourceLabel: string;
  sourceUrl: string;
  reportPath?: string;
  /** 2–6 printed header cells: `[0]` is the row-label column. */
  fallbackColumns: string[];
  fallbackRows: TableRow[];
  bars: Bar[];
  /**
   * Archived chart PNG. Renders as the chart visual only when it's the
   * *sole* visual — i.e. `bars` is empty and `plotSvg` is absent. When
   * `plotSvg` or a non-empty `bars` is present, that renders as the chart
   * instead and `pngPath` demotes to a "Download PNG proof" citation link
   * in the meta row.
   */
  pngPath?: string;
  /**
   * Pre-rendered Observable Plot SVG markup (build-time only — see
   * `src/lib/plot.ts`). When present it replaces the bars track in the
   * chart zone; everything else (header, meta, fallback table,
   * segments/variants) is unaffected. The SVG is inert (no client JS) and
   * carries its own `aria-hidden="true"`, so the `summary` prop remains
   * the sole accessible representation alongside the fallback table.
   * Takes precedence over both `bars` and `pngPath` as the chart visual;
   * `pngPath` still renders as a download-proof link if also set.
   */
  plotSvg?: string;
  /**
   * Optional plain-text headline stat rendered above the distribution bars
   * (e.g. "Mean: 4.57 / 7"). Used for Likert-style rating charts where the
   * bare 1-7 bar labels give no sense of central tendency on their own.
   */
  averageLabel?: string;
  segments?: Segment[];
  defaultSegmentLabel?: string;
  /**
   * Filter-control variants — see the `Variant` interface above. Renders a
   * segmented button group; the first variant is visible by default
   * (no-JS-safe). Mutually exclusive with `segments`.
   */
  variants?: Variant[];
  /**
   * When true (report hub overview), the visible fallback table is suppressed
   * and the treatment tightens. The table is still rendered as a
   * visually-hidden accessible alternative so screen-reader and no-JS users
   * keep the full data. Detail pages omit this prop and keep the full table.
   *
   * @deprecated Use `tableMode="hidden"` instead. Kept for back-compat: when
   * `tableMode` is not explicitly passed, `hideTable: true` resolves to
   * `tableMode: 'hidden'`.
   */
  hideTable?: boolean;
  /**
   * Controls how the fallback data table renders relative to the chart
   * visual. Defaults to `'collapsed'` so the table never competes with the
   * rendered chart.
   * - 'collapsed' — table sits inside a closed `<details>` disclosure.
   * - 'open' — prominent table, always expanded (table-only usage).
   * - 'hidden' — visually-hidden accessible alternative only.
   */
  tableMode?: 'collapsed' | 'open' | 'hidden';
}

const LABEL_COLUMN_WIDTH_PX = 220;
const GRIDLINE_PERCENTAGES = [0, 25, 50, 75, 100] as const;
/** Bars below this track-width percentage render as a solid tick, not a
 *  hollow pill — the value label already carries the magnitude, but an
 *  outline pill this narrow collapses into an unreadable dot. */
const MIN_TICK_PERCENTAGE = 3;

const {
  title,
  caption,
  summary,
  evidenceIds,
  sourceLabel,
  sourceUrl,
  reportPath,
  fallbackColumns,
  fallbackRows,
  bars,
  segments,
  defaultSegmentLabel,
  variants,
  pngPath,
  plotSvg,
  averageLabel,
  hideTable = false,
  tableMode,
} = Astro.props;

const resolvedTableMode: 'collapsed' | 'open' | 'hidden' =
  tableMode ?? (hideTable ? 'hidden' : 'collapsed');

const segmentList = segments ?? [];
const hasSegments = segmentList.length > 0;

const normalizeBars = (inputBars: Bar[]) => {
  const highlightedSignalIndex = inputBars.findIndex((bar) => bar.tone === 'signal');

  return inputBars.map((bar, index) => ({
    ...bar,
    tone:
      highlightedSignalIndex !== -1 && index === highlightedSignalIndex
        ? 'signal'
        : 'workhorse',
  }));
};

/**
 * Normalise the legacy single-`value` row shape into `values: string[]` so
 * every table branch below renders N columns the same way regardless of
 * which shape the source frontmatter used.
 */
const normalizeTableRows = (rows: TableRow[]): NormalizedTableRow[] =>
  rows.map((row) => ({
    label: row.label,
    values: row.values ?? (row.value !== undefined ? [row.value] : []),
  }));

const renderedBars = normalizeBars(bars);
/** pngPath renders as the chart visual only when it's the sole visual —
 *  no plotSvg and no bars. Otherwise it demotes to a download-proof link. */
const pngIsPrimaryVisual = Boolean(pngPath) && !plotSvg && renderedBars.length === 0;
const normalizedFallbackRows = normalizeTableRows(fallbackRows);
const evidenceLabel = evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs';
const showSource = !isSelfHostedSource(sourceUrl, reportPath);
const makeBlockId = (...parts: Array<string | undefined>) =>
  parts
    .filter(Boolean)
    .join(' ')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'chart-block';
const chartBlockId = makeBlockId(title, sourceLabel, reportPath, evidenceIds.join('-'));
const defaultTabId = `${chartBlockId}-tab-default`;
const defaultPanelId = `${chartBlockId}-panel-default`;
const segmentedViews = hasSegments
  ? [
      {
        id: 'default',
        label: defaultSegmentLabel,
        caption,
        summary,
        averageLabel,
        fallbackColumns,
        fallbackRows: normalizedFallbackRows,
        renderedBars,
        pngPath,
        tabId: defaultTabId,
        panelId: defaultPanelId,
      },
      ...segmentList.map((segment) => ({
        ...segment,
        pngPath: undefined,
        tabId: `${chartBlockId}-tab-${segment.id}`,
        panelId: `${chartBlockId}-panel-${segment.id}`,
        renderedBars: normalizeBars(segment.bars),
        fallbackRows: normalizeTableRows(segment.fallbackRows),
      })),
    ]
  : [];

const variantList = variants ?? [];
const hasVariants = variantList.length > 0;
const variantViews = hasVariants
  ? variantList.map((variant) => {
      const variantSourceLabel = variant.sourceLabel ?? sourceLabel;
      const variantSourceUrl = variant.sourceUrl ?? sourceUrl;
      const variantBlockId = makeBlockId(chartBlockId, variant.label);

      return {
        ...variant,
        sourceLabel: variantSourceLabel,
        sourceUrl: variantSourceUrl,
        showSource: !isSelfHostedSource(variantSourceUrl, reportPath),
        renderedBars: normalizeBars(variant.bars),
        fallbackRows: normalizeTableRows(variant.fallbackRows),
        evidenceLabel: variant.evidenceIds.length === 1 ? 'Evidence ID' : 'Evidence IDs',
        buttonId: `${variantBlockId}-variant-button`,
        panelId: `${variantBlockId}-variant-panel`,
      };
    })
  : [];
---

<figure
  class:list={[
    'chart-block',
    hideTable && 'chart-block--compact',
    hasSegments && 'chart-block--segments',
    hasVariants && 'chart-block--variants',
  ]}
>
  {hasVariants ? (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
        <p class="prose">{caption}</p>
      </figcaption>

      <div class="chart-block__variants" data-chart-block-variants>
        <div
          class="chart-block__variant-control"
          role="group"
          aria-label={`Filter ${title}`}
        >
          {variantViews.map((view, index) => (
            <button
              type="button"
              id={view.buttonId}
              aria-pressed={index === 0 ? 'true' : 'false'}
              aria-controls={view.panelId}
              class="label-mono chart-block__variant-chip"
              data-chart-variant-button
            >
              {view.label}
            </button>
          ))}
        </div>

        {variantViews.map((view) => (
          <section
            id={view.panelId}
            class="chart-block__variant-panel"
            aria-labelledby={view.buttonId}
            data-chart-variant-panel
          >
            <div class="chart-block__layout">
              <div
                class="chart-block__visual"
                role="img"
                aria-label={view.summary}
                style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
              >
                <p class="chart-block__summary">{view.summary}</p>{view.plotSvg ? (
                  <div class="chart-block__plot" set:html={view.plotSvg} />
                ) : (
                  <>
                <div class="chart-block__axis" aria-hidden="true">
                  <div class="chart-block__axis-spacer"></div>
                  <div class="chart-block__ticks">
                    {GRIDLINE_PERCENTAGES.map((percentage) => (
                      <span style={`left: ${percentage}%;`}>{percentage}%</span>
                    ))}
                  </div>
                  <div class="chart-block__axis-value-spacer"></div>
                </div>

                <div class="chart-block__bars">
                  {view.renderedBars.map((bar) => (
                    <div class="chart-block__row">
                      <div
                        class:list={[
                          'chart-block__label',
                          bar.tone === 'signal' && 'chart-block__label--signal',
                        ]}
                      >
                        {bar.label}
                      </div>

                      <div class="chart-block__track" aria-hidden="true">
                        <div class="chart-block__gridlines">
                          {GRIDLINE_PERCENTAGES.map((percentage) => (
                            <span style={`left: ${percentage}%;`}></span>
                          ))}
                        </div>

                        <div
                          class:list={[
                            'chart-block__fill',
                            bar.tone === 'signal'
                              ? 'chart-block__fill--signal'
                              : 'chart-block__fill--workhorse',
                            bar.value < MIN_TICK_PERCENTAGE && 'chart-block__fill--tiny',
                          ]}
                          style={`width: ${bar.value}%;`}
                        />
                      </div>

                      <div
                        class:list={[
                          'chart-block__value',
                          bar.tone === 'signal' && 'chart-block__value--signal',
                        ]}
                      >
                        {bar.displayValue ?? `${bar.value}%`}
                      </div>
                    </div>
                  ))}
                </div>
                  </>
                )}<div class="chart-block__meta">
                  {view.showSource && (
                    <p class="chart-block__source">
                      Source:{' '}
                      <a href={view.sourceUrl} class="chart-block__source-link">
                        {view.sourceLabel}
                      </a>
                    </p>
                  )}

                  <p class="chart-block__evidence">
                    {view.evidenceLabel}: {view.evidenceIds.join(', ')}
                  </p>
                </div>
              </div>

              <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
                {resolvedTableMode === 'collapsed' ? (
                  <details class="chart-block__table-disclosure">
                    <summary class="label-mono chart-block__table-summary">View data table</summary>
                    <div class="chart-block__table-wrap">
                      <table class="chart-block__table">
                        <thead>
                          <tr>
                            {view.fallbackColumns.map((column) => (
                              <th scope="col">{column}</th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          {view.fallbackRows.map((row) => (
                            <tr>
                              <th scope="row">{row.label}</th>
                              {row.values.map((value) => (
                                <td class="chart-block__table-value">{value}</td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </details>
                ) : (
                  <div class="chart-block__table-wrap">
                    <table class="chart-block__table">
                      <thead>
                        <tr>
                          {view.fallbackColumns.map((column) => (
                            <th scope="col">{column}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {view.fallbackRows.map((row) => (
                          <tr>
                            <th scope="row">{row.label}</th>
                            {row.values.map((value) => (
                              <td class="chart-block__table-value">{value}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            </div>
          </section>
        ))}

        <script is:inline>
          // Wrapped in an IIFE (like the segments script below) so
          // multiple variant-enabled charts on one page never collide
          // by re-declaring the same block-scoped bindings in the
          // shared classic-script global environment.
          (function () {
            const variantsRoot = document.currentScript?.closest('[data-chart-block-variants]');

            if (!(variantsRoot instanceof HTMLElement)) {
              return;
            }

            const variantButtons = Array.from(
              variantsRoot.querySelectorAll('[data-chart-variant-button]'),
            );
            const variantPanels = Array.from(
              variantsRoot.querySelectorAll('[data-chart-variant-panel]'),
            );

            const activateVariant = (index) => {
              variantButtons.forEach((otherButton, otherIndex) => {
                // aria-pressed doubles as the styling hook — the chip CSS
                // selects on [aria-pressed='true'], so no class juggling.
                otherButton.setAttribute('aria-pressed', String(otherIndex === index));
              });

              variantPanels.forEach((panel, panelIndex) => {
                panel.hidden = panelIndex !== index;
              });
            };

            variantButtons.forEach((button, index) => {
              button.addEventListener('click', () => activateVariant(index));
            });

            // Markup ships with every panel visible (no hidden attribute)
            // so non-JS visitors see all variants stacked. Once this script
            // runs, collapse down to the default panel and flag the root
            // as JS-ready so CSS can style the now-interactive pills.
            activateVariant(0);
            variantsRoot.dataset.jsReady = 'true';
          })();
        </script>
      </div>
    </>
  ) : hasSegments ? (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
      </figcaption>

      <div class="chart-block__segments" data-chart-block-segments>
        <div class="chart-block__segment-tabs" role="tablist" aria-label={`${title} chart views`}>
          <button
            id={defaultTabId}
            type="button"
            role="tab"
            aria-selected="true"
            aria-controls={defaultPanelId}
            tabindex="0"
            class="label-mono chart-block__segment-tab"
          >
            {defaultSegmentLabel}
          </button>

          {segmentList.map((segment) => (
            <button
              id={`${chartBlockId}-tab-${segment.id}`}
              type="button"
              role="tab"
              aria-selected="false"
              aria-controls={`${chartBlockId}-panel-${segment.id}`}
              tabindex="-1"
              class="label-mono chart-block__segment-tab"
            >
              {segment.label}
            </button>
          ))}
        </div>

        <div class="chart-block__segment-panels">
          {segmentedViews.map((view) => (
            <section
              id={view.panelId}
              class="chart-block__segment-panel"
              role="tabpanel"
              aria-labelledby={view.tabId}
            >
              <p class="prose chart-block__segment-caption">{view.caption}</p>

              <div class="chart-block__layout">
                <div
                  class="chart-block__visual"
                  {...(!(view.pngPath && view.renderedBars.length === 0) && { role: 'img', 'aria-label': view.summary })}
                  style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
                >
                  <p class="chart-block__summary">{view.summary}</p>

                  {view.averageLabel && (
                    <p class="chart-block__average">{view.averageLabel}</p>
                  )}

                  {view.pngPath && view.renderedBars.length === 0 ? (
                    <img
                      src={view.pngPath}
                      alt={view.summary}
                      class="chart-block__png-image"
                      loading="lazy"
                    />
                  ) : (
                    <>
                      <div class="chart-block__axis" aria-hidden="true">
                        <div class="chart-block__axis-spacer"></div>
                        <div class="chart-block__ticks">
                          {GRIDLINE_PERCENTAGES.map((percentage) => (
                            <span style={`left: ${percentage}%;`}>{percentage}%</span>
                          ))}
                        </div>
                        <div class="chart-block__axis-value-spacer"></div>
                      </div>

                      <div class="chart-block__bars">
                        {view.renderedBars.map((bar) => (
                          <div class="chart-block__row">
                            <div
                              class:list={[
                                'chart-block__label',
                                bar.tone === 'signal' && 'chart-block__label--signal',
                              ]}
                            >
                              {bar.label}
                            </div>

                            <div class="chart-block__track" aria-hidden="true">
                              <div class="chart-block__gridlines">
                                {GRIDLINE_PERCENTAGES.map((percentage) => (
                                  <span style={`left: ${percentage}%;`}></span>
                                ))}
                              </div>

                              <div
                                class:list={[
                                  'chart-block__fill',
                                  bar.tone === 'signal'
                                    ? 'chart-block__fill--signal'
                                    : 'chart-block__fill--workhorse',
                                  bar.value < MIN_TICK_PERCENTAGE && 'chart-block__fill--tiny',
                                ]}
                                style={`width: ${bar.value}%;`}
                              />
                            </div>

                            <div
                              class:list={[
                                'chart-block__value',
                                bar.tone === 'signal' && 'chart-block__value--signal',
                              ]}
                            >
                              {bar.displayValue ?? `${bar.value}%`}
                            </div>
                          </div>
                        ))}
                      </div>
                    </>
                  )}

                  <div class="chart-block__meta">
                    {showSource && (
                      <p class="chart-block__source">
                        Source:{' '}
                        <a href={sourceUrl} class="chart-block__source-link">
                          {sourceLabel}
                        </a>
                      </p>
                    )}

                    <p class="chart-block__evidence">
                      {evidenceLabel}: {evidenceIds.join(', ')}
                    </p>

                    {view.pngPath && (
                      <a href={view.pngPath} class="chart-block__png-link">
                        Download PNG proof
                      </a>
                    )}
                  </div>
                </div>

                <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
                  {resolvedTableMode === 'collapsed' ? (
                    <details class="chart-block__table-disclosure">
                      <summary class="label-mono chart-block__table-summary">View data table</summary>
                      <div class="chart-block__table-wrap">
                        <table class="chart-block__table">
                          <thead>
                            <tr>
                              {view.fallbackColumns.map((column) => (
                                <th scope="col">{column}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {view.fallbackRows.map((row) => (
                              <tr>
                                <th scope="row">{row.label}</th>
                                {row.values.map((value) => (
                                  <td class="chart-block__table-value">{value}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </details>
                  ) : (
                    <div class="chart-block__table-wrap">
                      <table class="chart-block__table">
                        <thead>
                          <tr>
                            {view.fallbackColumns.map((column) => (
                              <th scope="col">{column}</th>
                            ))}
                          </tr>
                        </thead>
                        <tbody>
                          {view.fallbackRows.map((row) => (
                            <tr>
                              <th scope="row">{row.label}</th>
                              {row.values.map((value) => (
                                <td class="chart-block__table-value">{value}</td>
                              ))}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </div>
              </div>
            </section>
          ))}
        </div>
      <script is:inline>
        // Wrapped in an IIFE so multiple segmented charts on one page
        // never collide by re-declaring the same block-scoped bindings
        // in the shared classic-script global environment.
        (function () {
          const root = document.currentScript?.closest('[data-chart-block-segments]');

          if (!(root instanceof HTMLElement)) {
            return;
          }

          const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
          const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));

          const activate = (index, focus = false) => {
            tabs.forEach((tab, tabIndex) => {
              const selected = tabIndex === index;
              tab.setAttribute('aria-selected', String(selected));
              tab.tabIndex = selected ? 0 : -1;
            });

            panels.forEach((panel, panelIndex) => {
              panel.hidden = panelIndex !== index;
            });

            if (focus) {
              tabs[index]?.focus();
            }
          };

          tabs.forEach((tab, index) => {
            tab.addEventListener('click', () => activate(index));
            tab.addEventListener('keydown', (event) => {
              const { key } = event;

              if (key !== 'ArrowLeft' && key !== 'ArrowRight' && key !== 'Home' && key !== 'End') {
                return;
              }

              event.preventDefault();

              const lastIndex = tabs.length - 1;
              let nextIndex = index;

              if (key === 'ArrowLeft') {
                nextIndex = index === 0 ? lastIndex : index - 1;
              } else if (key === 'ArrowRight') {
                nextIndex = index === lastIndex ? 0 : index + 1;
              } else if (key === 'Home') {
                nextIndex = 0;
              } else if (key === 'End') {
                nextIndex = lastIndex;
              }

              activate(nextIndex, true);
            });
          });

          // Markup ships with every panel visible (no hidden attribute) so
          // non-JS visitors see all segments stacked. Once this script
          // runs, collapse down to the default panel.
          activate(0);
          root.dataset.jsReady = 'true';
        })();
      </script>
      </div>
    </>
  ) : (
    <>
      <figcaption class="chart-block__header">
        <p class="label-mono">Chart proof</p>
        <h2>{title}</h2>
        <p class="prose">{caption}</p>
      </figcaption>

      <div class="chart-block__layout">
        <div
          class="chart-block__visual"
          {...(!pngIsPrimaryVisual && { role: 'img', 'aria-label': summary })}
          style={`--chart-label-column: ${LABEL_COLUMN_WIDTH_PX}px;`}
        >
          <p class="chart-block__summary">{summary}</p>

          {averageLabel && (
            <p class="chart-block__average">{averageLabel}</p>
          )}

          {plotSvg ? (
            <div class="chart-block__plot" set:html={plotSvg} />
          ) : pngIsPrimaryVisual ? (
            <img
              src={pngPath}
              alt={summary}
              class="chart-block__png-image"
              loading="lazy"
            />
          ) : (
            <>
              <div class="chart-block__axis" aria-hidden="true">
                <div class="chart-block__axis-spacer"></div>
                <div class="chart-block__ticks">
                  {GRIDLINE_PERCENTAGES.map((percentage) => (
                    <span style={`left: ${percentage}%;`}>{percentage}%</span>
                  ))}
                </div>
                <div class="chart-block__axis-value-spacer"></div>
              </div>

              <div class="chart-block__bars">
                {renderedBars.map((bar) => (
                  <div class="chart-block__row">
                    <div
                      class:list={[
                        'chart-block__label',
                        bar.tone === 'signal' && 'chart-block__label--signal',
                      ]}
                    >
                      {bar.label}
                    </div>

                    <div class="chart-block__track" aria-hidden="true">
                      <div class="chart-block__gridlines">
                        {GRIDLINE_PERCENTAGES.map((percentage) => (
                          <span style={`left: ${percentage}%;`}></span>
                        ))}
                      </div>

                      <div
                        class:list={[
                          'chart-block__fill',
                          bar.tone === 'signal'
                            ? 'chart-block__fill--signal'
                            : 'chart-block__fill--workhorse',
                          bar.value < MIN_TICK_PERCENTAGE && 'chart-block__fill--tiny',
                        ]}
                        style={`width: ${bar.value}%;`}
                      />
                    </div>

                    <div
                      class:list={[
                        'chart-block__value',
                        bar.tone === 'signal' && 'chart-block__value--signal',
                      ]}
                    >
                      {bar.displayValue ?? `${bar.value}%`}
                    </div>
                  </div>
                ))}
              </div>
            </>
          )}

          <div class="chart-block__meta">
            {showSource && (
              <p class="chart-block__source">
                Source:{' '}
                <a href={sourceUrl} class="chart-block__source-link">
                  {sourceLabel}
                </a>
              </p>
            )}

            <p class="chart-block__evidence">
              {evidenceLabel}: {evidenceIds.join(', ')}
            </p>

            {pngPath && (
              <a href={pngPath} class="chart-block__png-link">
                Download PNG proof
              </a>
            )}
          </div>
        </div>

        <div class:list={['chart-block__support', resolvedTableMode === 'hidden' && 'visually-hidden']}>
          {resolvedTableMode === 'collapsed' ? (
            <details class="chart-block__table-disclosure">
              <summary class="label-mono chart-block__table-summary">View data table</summary>
              <div class="chart-block__table-wrap">
                <table class="chart-block__table">
                  <thead>
                    <tr>
                      {fallbackColumns.map((column) => (
                        <th scope="col">{column}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {normalizedFallbackRows.map((row) => (
                      <tr>
                        <th scope="row">{row.label}</th>
                        {row.values.map((value) => (
                          <td class="chart-block__table-value">{value}</td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </details>
          ) : (
            <div class="chart-block__table-wrap">
              <table class="chart-block__table">
                <thead>
                  <tr>
                    {fallbackColumns.map((column) => (
                      <th scope="col">{column}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {normalizedFallbackRows.map((row) => (
                    <tr>
                      <th scope="row">{row.label}</th>
                      {row.values.map((value) => (
                        <td class="chart-block__table-value">{value}</td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </>
  )}
</figure>

<style>
  .chart-block {
    margin: 0;
  }

  /* Compact (report hub overview): tighter rhythm, table suppressed visually
     but kept in the DOM as a screen-reader / no-JS accessible alternative. */
  .chart-block--compact .chart-block__layout {
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .chart-block--compact .chart-block__visual {
    gap: var(--space-4);
  }

  /* Accessible table alternative — removed from the visual flow only. */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .chart-block__header h2 {
    margin-block: var(--space-4);
    font-family: var(--type-h2-face);
    font-size: var(--type-h2-size);
    line-height: var(--type-h2-leading);
    letter-spacing: var(--type-h2-tracking);
    font-weight: var(--weight-regular);
    text-rendering: auto;
  }

  .chart-block__layout {
    display: grid;
    gap: var(--space-8);
    margin-top: var(--space-8);
  }

  .chart-block__visual {
    display: grid;
    gap: var(--space-5);
    container-type: inline-size;
  }

  .chart-block__summary {
    margin: 0;
    color: var(--color-ink-muted);
    overflow-wrap: anywhere;
  }

  .chart-block__average {
    margin: 0;
    color: var(--color-ink);
    font-weight: var(--weight-semibold);
    font-variant-numeric: tabular-nums;
  }

  .chart-block__axis,
  .chart-block__row {
    display: grid;
    grid-template-columns: var(--chart-label-column) minmax(0, 1fr) auto;
    column-gap: var(--space-4);
    align-items: center;
  }

  .chart-block__axis {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
  }

  .chart-block__ticks,
  .chart-block__track {
    position: relative;
  }

  .chart-block__ticks {
    height: 1.5rem;
  }

  .chart-block__ticks span,
  .chart-block__gridlines span {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border-subtle);
  }

  .chart-block__ticks span {
    background: none;
    width: auto;
    bottom: auto;
    transform: translateX(-50%);
  }

  .chart-block__bars {
    display: grid;
    gap: var(--space-4);
  }

  .chart-block__label {
    color: var(--color-ink);
    line-height: 1.4;
    overflow-wrap: break-word;
  }

  .chart-block__label--signal,
  .chart-block__value--signal {
    color: var(--color-signal-text);
  }

  .chart-block__track {
    min-height: 1.25rem;
  }

  .chart-block__gridlines {
    position: absolute;
    inset: 0;
  }

  .chart-block__fill {
    position: relative;
    z-index: 1;
    height: 1.25rem;
    border-radius: 999px;
  }

  .chart-block__fill--workhorse {
    background: transparent;
    border: 1.5px solid var(--color-border-strong);
  }

  .chart-block__fill--signal {
    background: var(--color-signal-fill);
  }

  /* Below MIN_TICK_PERCENTAGE, the hollow workhorse pill's rounded border
     collapses into an unreadable dot. Render a short solid tick of the
     bar's tone instead — the value label already carries the magnitude. */
  .chart-block__fill--tiny {
    width: var(--space-3) !important;
  }

  .chart-block__fill--tiny.chart-block__fill--workhorse {
    background: var(--color-border-strong);
    border: none;
  }

  .chart-block__value {
    min-width: 3ch;
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .chart-block__meta {
    display: grid;
    gap: var(--space-2);
  }

  .chart-block__source,
  .chart-block__evidence {
    margin: 0;
    color: var(--color-ink-muted);
    font-family: var(--font-data);
    font-size: var(--ui-meta);
    line-height: var(--leading-ui);
    overflow-wrap: anywhere;
  }

  .chart-block__png-link,
  .chart-block__source-link {
    display: inline-flex;
    color: var(--color-action);
    text-decoration: none;
    width: fit-content;
  }

  .chart-block__png-link:hover,
  .chart-block__source-link:hover {
    text-decoration: underline;
  }

  .chart-block__support {
    display: grid;
    gap: var(--space-6);
  }

  /* Horizontal scroll lives on the wrapper only, never the page — a wide
     N-column fallback table (e.g. min/median/max/n) must never force the
     document itself to scroll sideways. */
  .chart-block__table-wrap {
    overflow-x: auto;
  }

  .chart-block__table {
    width: 100%;
    border-collapse: collapse;
  }

  .chart-block__table th,
  .chart-block__table td {
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: left;
    vertical-align: top;
    overflow-wrap: break-word;
  }

  /* Value columns are numeric (counts, medians, percentages) — right-align
     and set in the data face, tabular so digits line up down the column. */
  .chart-block__table-value {
    font-family: var(--font-data);
    text-align: right;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* Align column headers (except first, the row-label column) right to match
     their value cells below — headers sit over right-aligned numbers. */
  .chart-block__table th[scope='col']:not(:first-child) {
    text-align: right;
  }

  /* Collapsed table disclosure — quiet by default so it never competes with
     the chart visual above it. Native <details>/<summary>, no JS. */
  .chart-block__table-disclosure {
    border-top: 1px solid var(--color-border-subtle);
  }

  .chart-block__table-summary {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 44px;
    color: var(--color-ink-muted);
    cursor: pointer;
    list-style: none;
  }

  .chart-block__table-summary::-webkit-details-marker {
    display: none;
  }

  .chart-block__table-summary::before {
    content: '▸';
    display: inline-block;
    transition: transform 120ms ease;
  }

  .chart-block__table-disclosure[open] > .chart-block__table-summary::before {
    transform: rotate(90deg);
  }

  .chart-block__table-summary:focus-visible {
    outline: 3px solid var(--color-signal-fill);
    outline-offset: 3px;
  }

  .chart-block__table-disclosure .chart-block__table-wrap {
    margin-top: var(--space-4);
  }

  .chart-block__table-disclosure .chart-block__table {
    font-size: var(--type-caption);
  }

  .chart-block__table-disclosure .chart-block__table th,
  .chart-block__table-disclosure .chart-block__table td {
    padding-block: var(--space-2);
  }

  /* Container query, not a viewport media query: the row layout needs to
     collapse whenever the chart's own rendered width is narrow — inside a
     mobile viewport, but equally inside any narrow non-viewport wrapper
     (e.g. a card) — not only when the whole screen is small. Threshold is
     tuned to match the old 767px viewport breakpoint's effective content
     width for a full-width chart (~700-780px inside the editorial zone),
     while still catching genuinely narrow renders. */
  @container (max-width: 600px) {
    .chart-block__visual {
      --chart-label-column: min(220px, 38vw);
    }

    .chart-block__axis,
    .chart-block__row {
      grid-template-columns: 1fr;
      row-gap: var(--space-2);
    }

    .chart-block__axis-spacer,
    .chart-block__axis-value-spacer {
      display: none;
    }

    .chart-block__value {
      text-align: left;
    }

    .chart-block__axis {
      display: none;
    }

    .chart-block__ticks span:last-child,
    .chart-block__gridlines span:last-child {
      transform: translateX(-100%);
    }

    .chart-block__summary,
    .chart-block__source,
    .chart-block__evidence {
      overflow-wrap: anywhere;
    }
  }
  .chart-block,
  .chart-block__visual,
  .chart-block__row,
  .chart-block__support {
    min-width: 0;
  }

  .chart-block__png-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Observable Plot SVG (src/lib/plot.ts) — injected via set:html, so its
     markup never receives Astro's scoped-style attribute. Rules that must
     reach into it use :global(). The SVG itself carries a
     chart-block__fill--* tone class (set in plot.ts) so `color` here is
     what its marks' `fill="currentColor"`/`stroke="currentColor"`
     attributes resolve against — dark mode is free via _dark.css same as
     the bars above. */
  .chart-block__plot :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    font-family: var(--font-data);
    font-size: var(--type-caption);
  }

  .chart-block__plot :global(.chart-block__fill--workhorse) {
    color: var(--color-workhorse);
  }

  .chart-block__plot :global(.chart-block__fill--signal) {
    color: var(--color-signal-fill);
  }

  .chart-block__plot :global(text) {
    fill: var(--color-ink-muted);
  }

  /* Grouped/paired two-series bars (renderTwoSeriesBarSvg): `bar`/`key`
     aria-labels are unique to that renderer, so this scoping never touches
     scatter/range/single-series plot marks. Series A (solid) reads navy —
     the secondary/accent role, not a whole-series crimson signal; series B
     (outline + 0.12 fill-opacity, marked identically on bars and the key
     swatch) reads as the warm chart-neutral support tone. Both tokens carry
     dark-mode overrides in _dark.css already. */
  .chart-block__plot :global(g[aria-label='bar']),
  .chart-block__plot :global(g[aria-label='key']) {
    color: var(--color-action);
  }

  .chart-block__plot :global(g[aria-label='bar'][fill-opacity='0.12']),
  .chart-block__plot :global(rect[fill-opacity='0.12']) {
    color: var(--color-chart-neutral);
  }

  .chart-block__segments {
    display: grid;
    gap: var(--space-5);
  }

  .chart-block__segment-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  /* Chip pattern shared with FilterCompare.astro — the site's segmented-
     control look. Selected state is driven by the ARIA attribute each
     control already maintains (aria-selected for tabs, aria-pressed for
     variant toggles), so the JS never needs to juggle style classes. */
  .chart-block__segment-tab,
  .chart-block__variant-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding-inline: var(--space-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: 999px;
    background: transparent;
    color: var(--color-ink-muted);
    cursor: pointer;
    transition:
      background-color var(--transition-hover),
      border-color var(--transition-hover),
      color var(--transition-hover);
  }

  .chart-block__segment-tab:hover,
  .chart-block__variant-chip:hover {
    border-color: var(--color-border-strong);
    color: var(--color-ink);
  }

  .chart-block__segment-tab:focus-visible,
  .chart-block__variant-chip:focus-visible {
    outline: 2px solid var(--color-action);
    outline-offset: 2px;
  }

  .chart-block__segment-tab[aria-selected='true'],
  .chart-block__variant-chip[aria-pressed='true'] {
    border-color: var(--color-action);
    background: var(--color-action);
    color: var(--color-ambient);
  }

  .chart-block__segment-panels {
    display: grid;
    gap: var(--space-5);
  }

  .chart-block__segment-panel {
    display: grid;
    gap: var(--space-4);
  }

  /* Author styles beat the UA stylesheet's [hidden] { display: none }, so
     the display: grid rule above must be countered explicitly or the
     native hidden attribute (set by the tabs script below) has no visual
     effect and every panel renders stacked at once. */
  .chart-block__segment-panel[hidden] {
    display: none;
  }

  .chart-block__segment-caption {
    margin: 0;
  }

  /* Filter-control variants — segmented button group (role="group" +
     aria-pressed), distinct from the tab pattern above. Buttons share the
     FilterCompare chip styling defined alongside .chart-block__segment-tab,
     so the selected state reads as filled-vs-outline, not colour alone. */
  .chart-block__variants {
    display: grid;
    gap: var(--space-5);
  }

  .chart-block__variant-control {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .chart-block__variant-panel {
    display: grid;
    gap: var(--space-4);
  }

  /* Same [hidden] override as .chart-block__segment-panel above — without
     it, the variants script's panel.hidden toggle is set correctly on the
     DOM but display: grid keeps every panel visible regardless. */
  .chart-block__variant-panel[hidden] {
    display: none;
  }

  /* Before JS runs, clicking a variant button does nothing — keep the
     cursor honest rather than implying interactivity that isn't there yet. */
  .chart-block__variants:not([data-js-ready]) .chart-block__variant-control button {
    cursor: default;
  }
</style>
