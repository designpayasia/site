---
const year = new Date().getFullYear();

const linkGroups = [
  {
    heading: 'Reports',
    links: [
      { href: '/reports', label: 'All reports' },
      { href: '/reports/2024', label: '2024 report' },
      { href: '/reports/2023', label: '2023 archive' },
    ],
  },
  {
    heading: 'The site',
    links: [
      { href: '/about', label: 'About' },
      { href: '/contribute', label: 'Contribute' },
      { href: '/resources', label: 'Resources' },
    ],
  },
  {
    heading: 'Elsewhere',
    links: [
      { href: '/docs', label: 'Docs' },
      { href: '/ops', label: 'Ops' },
      { href: '/search', label: 'Search' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__mark" aria-label="Design Pay Asia — home">
        <svg
          class="site-footer__blob"
          viewBox="0 0 400 400"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M0 400 V133.14 A80 80 0 0 1 23.43 76.57 L76.57 23.43 A80 80 0 0 1 133.14 0 H200 A200 200 0 0 1 200 400 Z" />
        </svg>
        <span class="site-footer__name">Design Pay Asia</span>
      </a>
      <p class="site-footer__summary">
        Public reports, operational notes, and continuity docs for Southeast Asia&apos;s
        design pay conversation.
      </p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      {
        linkGroups.map((group, index) => (
          <section class="site-footer__group" aria-labelledby={`footer-group-${index}`}>
            <h2 id={`footer-group-${index}`} class="site-footer__heading">
              {group.heading}
            </h2>
            <ul class="site-footer__list">
              {group.links.map((link) => (
                <li>
                  <a href={link.href} class="site-footer__link">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </nav>

    <p class="site-footer__licence">
      MIT code · CC-BY 4.0 content &amp; data ·{' '}
      <a href="https://github.com/designpayasia/site" class="site-footer__link">
        Repo
      </a>
      {' '}· {year}
    </p>
  </div>
</footer>

<style>
  .site-footer {
    /* R3: the footer reuses the shared navy chrome via the dark-surface role, so we do not invent a footer-only background token. */
    --color-dark: var(--color-ambient);
    --color-dark-signal-fill: var(--color-signal-fill);
    --color-dark-signal-text: var(--color-signal-text);

    background: var(--color-dark);
    color: var(--color-workhorse);
    margin-top: var(--space-10);
  }

  .site-footer__inner {
    width: min(100% - 2rem, var(--container-full));
    margin: 0 auto;
    padding-block: var(--space-8);
    display: grid;
    gap: var(--space-6);
  }

  .site-footer__brand {
    display: grid;
    gap: var(--space-3);
  }

  .site-footer__mark {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
    color: inherit;
    text-decoration: none;
  }

  .site-footer__blob {
    width: 22px;
    height: 22px;
    aspect-ratio: 1 / 1;
    flex: none;
    fill: var(--color-dark-signal-fill);
  }

  .site-footer__name {
    font: var(--type-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__summary {
    margin: 0;
    max-width: 42rem;
    color: var(--color-workhorse);
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .site-footer__group {
    display: grid;
    gap: var(--space-2);
  }

  .site-footer__heading {
    margin: 0;
    font: var(--type-label);
    color: var(--color-dark-signal-text);
    letter-spacing: 0.06em;
    text-transform: none;
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .site-footer__link {
    color: var(--color-workhorse);
    text-decoration: none;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--color-dark-signal-text);
  }

  .site-footer__licence {
    margin: 0;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-dark-signal-text);
    color: var(--color-workhorse);
  }

  @media (max-width: 720px) {
    .site-footer__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
