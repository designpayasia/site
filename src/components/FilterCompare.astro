---
/**
 * FilterCompare — filter pills driving a live-filtered matrix/table.
 *
 * Built for table treatments and multi-market chart filtering (pairs with
 * ChartSmallMultiples). Each filter group renders an implicit "All <group>"
 * pill plus one pill per supplied option; pills within a group are
 * mutually exclusive (single active value), groups combine with AND logic.
 *
 * Progressive enhancement: the pill controls are rendered `hidden` and are
 * only revealed once the anchored inline script runs, so a no-JS visit
 * renders a complete, unfiltered table with every row visible. Filtering
 * itself toggles the native `hidden` attribute on rows and updates an
 * `aria-live="polite"` result count.
 *
 * Consumer contract: `group.id` values must be safe to use as an HTML
 * attribute suffix (lowercase letters, numbers, hyphens — same convention
 * as chart/section ids elsewhere on the site).
 */
interface FilterOption {
  value: string;
  label: string;
}

interface FilterGroup {
  id: string;
  label: string;
  options: FilterOption[];
}

interface FilterRow {
  id: string;
  /** Rendered table cells, left-to-right. First cell renders as a row header (`<th scope="row">`). */
  cells: string[];
  /** Filter values this row matches per group id. A row can match more than one value per group. */
  filters: Record<string, string | string[]>;
}

interface Props {
  caption: string;
  eyebrow?: string;
  title?: string;
  columns: string[];
  groups: FilterGroup[];
  rows: FilterRow[];
  /** Noun used in the live result count, e.g. "row" / "market". Defaults to "row". */
  resultNoun?: string;
}

const { caption, eyebrow = 'Filter & compare', title, columns, groups, rows, resultNoun = 'row' } = Astro.props;

const resultNounPlural = `${resultNoun}s`;

const rowFilterAttrs = (row: FilterRow) => {
  const attrs: Record<string, string> = {};

  for (const group of groups) {
    const raw = row.filters[group.id];
    const values = Array.isArray(raw) ? raw : raw ? [raw] : [];
    attrs[`data-filter-${group.id}`] = values.join(' ');
  }

  return attrs;
};
---

<div class="filter-compare" data-filter-compare>
  <div class="filter-compare__head">
    <p class="label-mono filter-compare__eyebrow">{eyebrow}</p>
    {title && <h2 class="filter-compare__title">{title}</h2>}
  </div>

  <div class="filter-compare__pills" data-filter-pills hidden>
    {groups.map((group) => (
      <div class="filter-compare__group" role="group" aria-label={group.label}>
        <span class="label-mono filter-compare__group-label">{group.label}</span>
        <div class="filter-compare__pill-row">
          <button
            type="button"
            class="label-mono filter-compare__pill"
            data-filter-pill
            data-filter-group={group.id}
            data-filter-value=""
            aria-pressed="true"
          >
            All {group.label}
          </button>

          {group.options.map((option) => (
            <button
              type="button"
              class="label-mono filter-compare__pill"
              data-filter-pill
              data-filter-group={group.id}
              data-filter-value={option.value}
              aria-pressed="false"
            >
              {option.label}
            </button>
          ))}
        </div>
      </div>
    ))}
  </div>

  <p
    class="label-mono filter-compare__count"
    data-filter-count
    data-filter-noun={resultNounPlural}
    aria-live="polite"
  >
    {rows.length} of {rows.length} {resultNounPlural} shown
  </p>

  <div class="filter-compare__table-wrap">
    <table class="filter-compare__table">
      <caption class="visually-hidden">{caption}</caption>
      <thead>
        <tr>
          {columns.map((column) => (
            <th class="label-mono" scope="col">{column}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr data-filter-row {...rowFilterAttrs(row)}>
            {row.cells.map((cell, index) =>
              index === 0 ? <th scope="row">{cell}</th> : <td>{cell}</td>
            )}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<script is:inline>
  const root = document.currentScript?.closest('[data-filter-compare]');

  if (root instanceof HTMLElement) {
    const pillsWrap = root.querySelector('[data-filter-pills]');
    const pills = Array.from(root.querySelectorAll('[data-filter-pill]'));
    const rows = Array.from(root.querySelectorAll('[data-filter-row]'));
    const countEl = root.querySelector('[data-filter-count]');
    const active = {};

    pills.forEach((pill) => {
      const group = pill.getAttribute('data-filter-group');

      if (group && pill.getAttribute('aria-pressed') === 'true') {
        active[group] = pill.getAttribute('data-filter-value') || '';
      }
    });

    const apply = () => {
      let shown = 0;

      rows.forEach((row) => {
        const visible = Object.keys(active).every((groupId) => {
          const value = active[groupId];

          if (!value) {
            return true;
          }

          const rowValues = (row.getAttribute(`data-filter-${groupId}`) || '')
            .split(' ')
            .filter(Boolean);

          return rowValues.includes(value);
        });

        row.hidden = !visible;

        if (visible) {
          shown += 1;
        }
      });

      if (countEl instanceof HTMLElement) {
        const noun = countEl.getAttribute('data-filter-noun');
        countEl.textContent = `${shown} of ${rows.length}${noun ? ` ${noun}` : ''} shown`;
      }
    };

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const group = pill.getAttribute('data-filter-group');

        if (!group) {
          return;
        }

        active[group] = pill.getAttribute('data-filter-value') || '';

        pills
          .filter((candidate) => candidate.getAttribute('data-filter-group') === group)
          .forEach((candidate) => {
            candidate.setAttribute('aria-pressed', String(candidate === pill));
          });

        apply();
      });
    });

    if (pillsWrap instanceof HTMLElement) {
      pillsWrap.hidden = false;
    }

    apply();
  }
</script>

<style>
  .filter-compare {
    display: grid;
    gap: var(--space-6);
  }

  .filter-compare__head {
    display: grid;
    gap: var(--space-2);
  }

  .filter-compare__eyebrow {
    color: var(--color-ink-muted);
  }

  .filter-compare__title {
    font: var(--type-body);
    line-height: var(--leading-editorial);
    color: var(--color-workhorse);
  }

  .filter-compare__pills {
    display: grid;
    gap: var(--space-4);
  }

  .filter-compare__group {
    display: grid;
    gap: var(--space-2);
  }

  .filter-compare__group-label {
    color: var(--color-ink-muted);
  }

  .filter-compare__pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .filter-compare__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding-inline: var(--space-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: 999px;
    background: transparent;
    color: var(--color-ink-muted);
    cursor: pointer;
    transition:
      background-color var(--transition-hover),
      border-color var(--transition-hover),
      color var(--transition-hover);
  }

  .filter-compare__pill:hover {
    border-color: var(--color-border-strong);
    color: var(--color-ink);
  }

  .filter-compare__pill:focus-visible {
    outline: 2px solid var(--color-action);
    outline-offset: 2px;
  }

  .filter-compare__pill[aria-pressed='true'] {
    border-color: var(--color-action);
    background: var(--color-action);
    color: var(--color-ambient);
  }

  .filter-compare__count {
    margin: 0;
    color: var(--color-ink-muted);
  }

  .filter-compare__table-wrap {
    overflow-x: auto;
  }

  .filter-compare__table {
    width: 100%;
    border-collapse: collapse;
  }

  .filter-compare__table th,
  .filter-compare__table td {
    padding-block: var(--space-3);
    padding-inline-end: var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
    text-align: left;
    vertical-align: top;
    overflow-wrap: break-word;
  }

  .filter-compare__table thead th {
    color: var(--color-ink-muted);
    font-weight: var(--weight-medium);
  }

  .filter-compare__table tbody th {
    color: var(--color-ink);
    font-weight: var(--weight-medium);
  }

  .filter-compare__table td {
    color: var(--color-ink);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
