---
type ProvenanceStatus = 'proven' | 'draft' | 'unresolved';
type PublishMode = 'published' | 'sample' | 'suppressed' | 'draft';

interface MetricCard {
  value?: string;
  unit?: string;
  /** Optional explicit prefix override (e.g. "S$"). Falls back to the
   *  leading non-numeric run auto-parsed from `value` when omitted, so
   *  existing callers passing a flat `value` string keep working unchanged. */
  affix?: string;
  label?: string;
  evidenceLabel?: string;
  evidenceId?: string;
  note?: string;
  publishMode?: PublishMode;
}

interface Props {
  eyebrow?: string;
  title?: string;
  statement?: string;
  statementDraft?: boolean;
  draftLabel?: string;
  metrics?: MetricCard[];
  provenanceStatus?: ProvenanceStatus;
  provenanceNote?: string;
}

const {
  eyebrow = 'Dark beat',
  title = '2024 feels like progress with precarity',
  statement,
  statementDraft = true,
  draftLabel = 'Draft for Jon',
  metrics = [],
  provenanceStatus = 'proven',
  provenanceNote,
} = Astro.props;

// Length-aware fit sizing (DESIGN.md § Long values and currency): a blind
// cqi clamp with a fixed rem floor can't tell a short value from a long one,
// so the floor either overshoots (clipped digits — SGD 4,200 in a ~290px
// cell rendered "4,20") or undershoots (wasted space). Instead we measure
// each value's own advance (total rendered width in units of its own
// font-size) and size the font so that advance exactly fills the container.
//
// DM Mono (tabular-nums) renders each character at ~0.62em of advance width.
// --type-stat-tracking (-0.03em, applied per character) subtracts from that,
// giving a net 0.59em advance per character at this face/tracking pairing.
const MONO_ADVANCE = 0.59;
// Segment gap (flex `gap: 0.12em` between affix/core/suffix/unit spans) and
// affix/unit scale (DESIGN.md: stat units set at 0.42em) mirror the CSS
// rules below — keep these two in sync with the stylesheet if either rule
// changes.
const AFFIX_SCALE = 0.42;
const SEGMENT_GAP_EM = 0.12;
// Safety margin for glyph metrics variance (kerning, rounding) we don't
// model exactly.
const SAFETY_FACTOR = 1.04;

function computeStatAdvance(core: string, affix?: string, suffix?: string, unit?: string) {
  const coreChars = core.length;
  const affixChars = (affix?.length ?? 0) + (suffix?.length ?? 0) + (unit?.length ?? 0);
  const segments = [affix, core, suffix, unit].filter((segment) => segment && segment.length > 0);
  const segmentGaps = Math.max(segments.length - 1, 0);
  const advance =
    coreChars * MONO_ADVANCE + affixChars * AFFIX_SCALE * MONO_ADVANCE + segmentGaps * SEGMENT_GAP_EM;
  return Number((advance * SAFETY_FACTOR).toFixed(3));
}

const cleanStatement = statement?.trim();
const visibleMetricsRaw = metrics
  .filter((metric) => metric.publishMode !== 'suppressed')
  .filter((metric) => metric.value?.trim() && metric.label?.trim())
  .slice(0, 3)
  .map((metric) => {
    // Segment anatomy (DESIGN.md § Long values and currency): split the flat
    // value string into affix / numeric core / trailing suffix, same regex
    // BigStat.astro uses, so a plain `value` alone still renders correctly.
    const trimmedValue = metric.value!.trim();
    const valueMatch = trimmedValue.match(/^([^0-9]*)(\d[\d,]*(?:\.\d+)?)(.*)$/);
    const affix = metric.affix ?? valueMatch?.[1]?.trim();
    const core = valueMatch?.[2] ?? trimmedValue;
    const suffix = valueMatch?.[3]?.trim();
    return {
      ...metric,
      affix,
      core,
      suffix,
      advance: computeStatAdvance(core, affix, suffix, metric.unit),
    };
  });

// Row-level sizing (not per-value): every metric in the row shares one
// font size, so the shelf reads level instead of ragged. Use the largest
// per-value advance in the row for all figures — the most space-hungry
// value sets the size, shorter values just get more breathing room.
const rowAdvance =
  visibleMetricsRaw.length > 0 ? Math.max(...visibleMetricsRaw.map((metric) => metric.advance)) : 0;
const visibleMetrics = visibleMetricsRaw.map((metric) => ({ ...metric, advance: rowAdvance }));

const showDraftFlag = statementDraft || provenanceStatus !== 'proven';
const statusLabel =
  provenanceStatus === 'unresolved'
    ? 'Evidence pending'
    : provenanceStatus === 'draft'
      ? 'Draft figures'
      : draftLabel;
---

<section class="dark-beat" data-theme="dark" aria-labelledby="dark-beat-title">
  <div class="dark-beat__inner">
    <header class="dark-beat__header">
      <p class="dark-beat__eyebrow label-mono">{eyebrow}</p>
      <h2 id="dark-beat-title" class="dark-beat__title t-h2">{title}</h2>
    </header>

    {(cleanStatement || showDraftFlag) && (
      <div class="dark-beat__statement prose">
        {cleanStatement && cleanStatement.split(/\n{2,}/).map((para, idx, arr) => (
          <p class={`dark-beat__copy${idx === arr.length - 1 && arr.length > 1 ? ' dark-beat__copy--caveat' : ''}`}>
            {para.trim()}
          </p>
        ))}
        {showDraftFlag && <span class="dark-beat__flag label-mono">{statusLabel}</span>}
      </div>
    )}

    {visibleMetrics.length > 0 && (
      <div class="dark-beat__metrics" role="list" aria-label="Evidence-backed metrics">
        {visibleMetrics.map((metric) => (
          <article class="dark-beat__metric" role="listitem">
            <p class="dark-beat__figure" style={`--stat-advance: ${metric.advance}`}>
              {metric.affix && <span class="dark-beat__affix">{metric.affix}</span>}
              <span class="dark-beat__value">{metric.core}</span>
              {metric.suffix && <span class="dark-beat__affix">{metric.suffix}</span>}
              {metric.unit && <span class="dark-beat__unit">{metric.unit}</span>}
            </p>
            <p class="dark-beat__label">{metric.label}</p>
            {(metric.evidenceLabel || metric.note) && (
              <p class="dark-beat__evidence label-mono">
                {metric.evidenceLabel ?? metric.note}
              </p>
            )}
          </article>
        ))}
      </div>
    )}

    {provenanceStatus !== 'proven' && provenanceNote && (
      <p class="dark-beat__note label-mono">{provenanceNote}</p>
    )}
  </div>
</section>

<style>
  .dark-beat {
    background: var(--color-inverse-surface);
    color: var(--color-inverse-text);
  }

  .dark-beat__inner {
    display: grid;
    gap: var(--space-6);
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
    padding-block-start: var(--space-16);
    padding-block-end: var(--space-24);
  }

  .dark-beat__header {
    display: grid;
    gap: var(--space-2);
  }

  .dark-beat__eyebrow {
    margin: 0;
    color: var(--color-inverse-signal-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dark-beat__title {
    margin: 0;
    max-width: 22ch;
    color: var(--color-inverse-text);
  }

  .dark-beat__statement {
    display: grid;
    gap: var(--space-4);
    align-items: start;
  }

  .dark-beat__copy {
    margin: 0;
    max-width: 55ch;
    font-size: var(--type-caption);
    line-height: 1.5;
    color: var(--color-inverse-text);
    overflow-wrap: break-word;
  }

  .dark-beat__copy--caveat {
    font-size: var(--type-footnote);
    color: color-mix(in srgb, var(--color-inverse-text) 72%, transparent);
  }

  .dark-beat__flag {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-inverse-signal-text) 55%, transparent);
    border-radius: 999px;
    color: var(--color-inverse-signal-text);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .dark-beat__metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid color-mix(in srgb, var(--color-inverse-text) 14%, transparent);
  }

  .dark-beat__metric {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
    container-type: inline-size;
  }

  .dark-beat__figure,
  .dark-beat__label,
  .dark-beat__evidence,
  .dark-beat__note {
    margin: 0;
  }

  .dark-beat__figure {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.12em;
    min-width: 0;
    overflow: visible;
    font-family: var(--type-stat-face);
    /* Length-aware fit (DESIGN.md § Long values and currency): size to the
       lesser of the locked stat size and the value's own measured advance
       filling the container (--stat-advance set inline per value in the
       frontmatter). A fixed rem floor can't distinguish a short value from
       a long one — it either clips digits (overshoot) or wastes space
       (undershoot). The 1rem clamp floor is a legibility backstop only;
       real values never reach it. If a pathological value ever does,
       overflow is visible rather than clipping digits — a lie is worse
       than an overflow. */
    font-size: clamp(1rem, calc(100cqi / var(--stat-advance)), var(--type-stat-size));
    line-height: var(--type-stat-leading);
    letter-spacing: var(--type-stat-tracking);
    color: var(--color-inverse-text);
  }

  .dark-beat__value {
    min-width: 0;
    line-height: 0.95;
    font-variant-numeric: lining-nums;
  }

  .dark-beat__affix,
  .dark-beat__unit {
    min-width: 0;
    max-width: 100%;
    font-size: var(--type-stat-unit-size);
    line-height: 1;
    white-space: nowrap;
  }

  .dark-beat__unit {
    font-family: var(--font-data);
    color: var(--color-inverse-signal-fill);
    overflow-wrap: anywhere;
  }

  .dark-beat__label {
    max-width: 22ch;
    font-size: var(--type-body);
    line-height: var(--leading-editorial);
    color: var(--color-inverse-text);
    overflow-wrap: break-word;
  }

  .dark-beat__evidence,
  .dark-beat__note {
    color: color-mix(in srgb, var(--color-inverse-text) 72%, transparent);
    overflow-wrap: break-word;
  }

  @media (max-width: 768px) {
    .dark-beat__inner {
      padding-inline: var(--space-4);
      padding-block-start: var(--space-8);
      padding-block-end: var(--space-12);
    }
    .dark-beat__metrics {
      grid-template-columns: 1fr;
    }
    .dark-beat__metric + .dark-beat__metric {
      border-top: 1px solid color-mix(in srgb, var(--color-inverse-text) 14%, transparent);
      padding-top: var(--space-4);
    }
  }
</style>
