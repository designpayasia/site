---
import Base from '../../layouts/Base.astro';
import CoverIndexSpread from '../../components/CoverIndexSpread.astro';
import CoverSplitEditorial from '../../components/CoverSplitEditorial.astro';
import DarkBeat from '../../components/DarkBeat.astro';
import CoverFullBleed from '../../components/CoverFullBleed.astro';
import CoverCardInverse from '../../components/CoverCardInverse.astro';
import FindingsStrip from '../../components/FindingsStrip.astro';
import MetricShelf from '../../components/MetricShelf.astro';
import BigStat from '../../components/BigStat.astro';
import StatTakeover from '../../components/StatTakeover.astro';
import ChartBlock from '../../components/ChartBlock.astro';
import ChartSmallMultiples from '../../components/ChartSmallMultiples.astro';
import ChartRange from '../../components/ChartRange.astro';
import ChartDotPlot from '../../components/ChartDotPlot.astro';
import Invitation from '../../components/Invitation.astro';
import Provocations from '../../components/Provocations.astro';
import RegisterCards from '../../components/RegisterCards.astro';
import PullQuote from '../../components/PullQuote.astro';
import PullQuoteBeat from '../../components/PullQuoteBeat.astro';
import StickyMeta from '../../components/StickyMeta.astro';
import TocScrollspy from '../../components/TocScrollspy.astro';
import FilterCompare from '../../components/FilterCompare.astro';
import ConversationSpine from '../../components/ConversationSpine.astro';
import type { NavGroup } from '../../lib/report-nav';

// Shared sample data. Fictional but DPA-plausible — no real employers, no
// real names, every sampleSize at or above MIN_SAFE_COHORT (10).

const shelfMetrics = [
  {
    value: 'SGD 4,200',
    label: 'Median monthly pay',
    evidenceId: 'evidence:2025-sea-median-pay',
    sampleSize: 412,
    color: 'signal' as const,
    countUp: true,
  },
  {
    value: '72',
    unit: '%',
    label: 'Pay bands disclosed pre-interview',
    evidenceId: 'evidence:2025-sea-pay-band-disclosure',
    sampleSize: 288,
    delta: { value: 6.2 },
  },
  {
    value: '3.1',
    unit: 'yrs',
    label: 'Median time to first promotion',
    evidenceId: 'evidence:2025-sea-promotion-time',
    sampleSize: 196,
  },
  {
    value: '18',
    unit: '%',
    label: 'Negotiated most recent offer',
    evidenceId: 'evidence:2025-sea-negotiated-offer',
    sampleSize: 134,
    delta: { value: -4.5, tone: 'signal' as const },
  },
];

const splitMetrics = [
  {
    value: 'SGD 6,800',
    label: 'Median lead-level pay',
    evidenceId: 'evidence:2025-sea-lead-pay',
    sampleSize: 58,
  },
  {
    value: '22',
    unit: '%',
    label: 'Spread, lowest to highest market',
    evidenceId: 'evidence:2025-sea-market-spread',
    sampleSize: 58,
  },
];

const inverseCoverCards = [
  {
    href: '/reports/2023',
    year: 2023,
    title: 'The first pass at pay parity.',
    stat: { value: 'SGD 3,900', label: 'Median IC pay' },
  },
  {
    href: '/reports/2024',
    year: 2024,
    title: 'Naming the gap.',
    stat: { value: '68%', label: 'Reported transparency' },
  },
  {
    href: '/reports',
    year: 2025,
    title: 'Six markets, one baseline.',
    stat: { value: '1,842', label: 'Respondents' },
  },
];

const smallMultiplesPanels = [
  {
    id: 'sg',
    label: 'Singapore',
    rows: [
      { label: '2023', value: 52 },
      { label: '2025', value: 64, tone: 'signal' as const },
    ],
  },
  {
    id: 'my',
    label: 'Malaysia',
    rows: [
      { label: '2023', value: 47 },
      { label: '2025', value: 58 },
    ],
  },
  {
    id: 'id',
    label: 'Indonesia',
    rows: [
      { label: '2023', value: 38 },
      { label: '2025', value: 49 },
    ],
  },
];

const rangeRows = [
  { label: 'Junior IC', medianPosition: 32, bandStart: 26, bandEnd: 38, valueLabel: 'SGD 3,800', rangeLabel: 'n=64' },
  {
    label: 'Mid IC',
    medianPosition: 43,
    bandStart: 37,
    bandEnd: 50,
    valueLabel: 'SGD 5,200',
    rangeLabel: 'n=41',
    tone: 'action' as const,
  },
  {
    label: 'Senior IC',
    medianPosition: 59,
    bandStart: 50,
    bandEnd: 68,
    valueLabel: 'SGD 7,100',
    rangeLabel: 'n=22',
    tone: 'signal' as const,
  },
  {
    label: 'Lead/Principal',
    medianPosition: 80,
    bandStart: 68,
    bandEnd: 92,
    valueLabel: 'SGD 9,600',
    rangeLabel: 'n=11',
    confidence: 'low' as const,
  },
];

const dotRows = [
  { label: 'Product design', value: 45, valueLabel: 'SGD 5,400' },
  { label: 'UX research', value: 42.5, valueLabel: 'SGD 5,100', tone: 'action' as const },
  { label: 'Brand/visual', value: 35.8, valueLabel: 'SGD 4,300' },
  { label: 'Design systems', value: 49.2, valueLabel: 'SGD 5,900', tone: 'signal' as const },
  { label: 'Motion/3D', value: 39.2, valueLabel: 'SGD 4,700' },
];

const filterGroups = [
  {
    id: 'market',
    label: 'Market',
    options: [
      { value: 'sg', label: 'Singapore' },
      { value: 'my', label: 'Malaysia' },
    ],
  },
  {
    id: 'level',
    label: 'Level',
    options: [
      { value: 'mid', label: 'Mid' },
      { value: 'senior', label: 'Senior' },
    ],
  },
];

const filterRows = [
  { id: 'r1', cells: ['Singapore', 'Mid', 'SGD 5,200'], filters: { market: 'sg', level: 'mid' } },
  { id: 'r2', cells: ['Singapore', 'Senior', 'SGD 7,100'], filters: { market: 'sg', level: 'senior' } },
  { id: 'r3', cells: ['Malaysia', 'Mid', 'MYR 8,400'], filters: { market: 'my', level: 'mid' } },
  { id: 'r4', cells: ['Malaysia', 'Senior', 'MYR 11,600'], filters: { market: 'my', level: 'senior' } },
];

const darkBeatMetrics = [
  {
    value: 'SGD 4,200',
    label: 'Median monthly pay',
    evidenceId: 'evidence:2025-sea-median-pay',
    publishMode: 'published' as const,
  },
  {
    value: '72',
    unit: '%',
    label: 'Pay bands disclosed pre-interview',
    evidenceId: 'evidence:2025-sea-pay-band-disclosure',
    publishMode: 'published' as const,
  },
];

const chartBlockBars = [
  { label: 'Singapore', value: 24, tone: 'signal' as const },
  { label: 'Malaysia', value: 19 },
  { label: 'Indonesia', value: 14 },
  { label: 'Vietnam', value: 11 },
];

const chartBlockFallbackRows = [
  { label: 'Singapore', value: '24%' },
  { label: 'Malaysia', value: '19%' },
  { label: 'Indonesia', value: '14%' },
  { label: 'Vietnam', value: '11%' },
];

const stickyMetaItems = [
  { label: 'Methodology', value: 'Self-reported survey, median of base pay', href: '/docs/data-safety' },
  { label: 'Sample', value: 'n = 1,842 across 6 markets' },
  { label: 'Published', value: 'March 2025', href: '/reports' },
];

const navPatternGroups = [
  { key: 'landscape', label: 'Landscape', sections: [
    { id: 'demographics', title: 'Demographics', summary: 'Who the region’s designers are.' },
    { id: 'compensation', title: 'Compensation', summary: 'What designers were paid.' },
  ]},
  { key: 'sentiments', label: 'Sentiments', sections: [
    { id: 'offer-and-negotiation', title: 'Offer & negotiation', summary: 'How pay gets decided.' },
  ]},
  { key: 'close', label: 'Close', sections: [
    { id: 'closing', title: 'The year’s question', summary: 'What this year leaves open.' },
  ]},
] as unknown as NavGroup[];

const provocationSample = [
  {
    header: 'A generation without a ladder',
    stat: '93.9%',
    statDetail: '93.9% of designers are under 35; 5.9% hold a leadership role.',
    question: 'Where is the seat you are meant to grow into?',
  },
  {
    header: 'Valued, but the pay disagrees',
    stat: '70.2%',
    statDetail: '70.2% feel valued at work; fewer than 30% have any salary transparency.',
    question: 'How do you know your worth when no one will say the number out loud?',
  },
  {
    header: 'The negotiation gap',
    stat: '2.1',
    statDetail: 'Senior designers are 2.1 times more likely to negotiate successfully.',
    question: 'What did no one teach you to ask for?',
  },
];

const tocItems = [
  { id: 'cover-index-spread', label: 'Cover — index spread' },
  { id: 'cover-split-editorial', label: 'Cover — split editorial' },
  { id: 'dark-beat', label: 'Dark beat' },
  { id: 'cover-full-bleed', label: 'Cover — full bleed' },
  { id: 'cover-card-inverse', label: 'Cover card — inverse' },
  { id: 'findings-strip', label: 'Findings strip' },
  { id: 'metric-shelf', label: 'Metric shelf' },
  { id: 'big-stat', label: 'Big stat' },
  { id: 'stat-takeover', label: 'Stat takeover' },
  { id: 'chart-block', label: 'Chart block' },
  { id: 'chart-small-multiples', label: 'Chart — small multiples' },
  { id: 'chart-range', label: 'Chart — range' },
  { id: 'chart-dot-plot', label: 'Chart — dot plot' },
  { id: 'invitation', label: 'Invitation' },
  { id: 'provocations', label: 'Provocations' },
  { id: 'register-cards', label: 'Register cards' },
  { id: 'pull-quote', label: 'Pull quote' },
  { id: 'pull-quote-beat', label: 'Pull-quote beat' },
  { id: 'sticky-meta', label: 'Sticky meta' },
  { id: 'toc-scrollspy', label: 'Toc scrollspy (this rail)' },
  { id: 'filter-compare', label: 'Filter & compare' },
  { id: 'nav-wayfinding', label: 'Nav & wayfinding' },
];
---

<Base
  title="Pattern library - Design Pay Asia"
  description="Contributor reference gallery for DPA's report pattern components, rendered with sample data."
>
  <header class="pattern-library-intro">
    <div class="pattern-library-intro__inner">
      <p class="label-mono">Docs</p>
      <h1>Pattern library</h1>
      <p class="prose">
        A contributor reference, not a public report page. Every reusable report and report-adjacent
        component is rendered here with fictional Southeast Asian pay data so a reviewer can see the
        real markup and styling without opening a live report.
      </p>
      <p class="prose">
        This page stacks every pattern back to back on purpose — that breaks the one-signal-per-view
        rule every real report page should hold to. Treat the density here as a specimen sheet, not a
        layout to copy.
      </p>
      <details class="pattern-library-reference">
        <summary class="label-mono">Component source and production reference</summary>
        <p>
          Each specimen imports the component named below from the listed source file. Production links
          are observed callers, not an exhaustive usage catalogue. Docs-only means the component is a
          maintained specimen without a direct page caller yet.
        </p>
        <div class="pattern-library-reference__table-wrap">
          <table class="pattern-library-reference__table">
            <thead>
              <tr>
                <th scope="col">Pattern</th>
                <th scope="col">Source</th>
                <th scope="col">Current reference</th>
              </tr>
            </thead>
            <tbody>
              <tr><th scope="row">Cover index spread</th><td><code>src/components/CoverIndexSpread.astro</code></td><td><a href="/reports">Production: reports index</a></td></tr>
              <tr><th scope="row">Cover split editorial</th><td><code>src/components/CoverSplitEditorial.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Dark beat</th><td><code>src/components/DarkBeat.astro</code></td><td><a href="/">Production: homepage</a></td></tr>
              <tr><th scope="row">Cover full bleed</th><td><code>src/components/CoverFullBleed.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Cover card inverse</th><td><code>src/components/CoverCardInverse.astro</code></td><td><a href="/reports">Production: reports index</a></td></tr>
              <tr><th scope="row">Findings strip</th><td><code>src/components/FindingsStrip.astro</code></td><td><a href="/">Production: homepage</a></td></tr>
              <tr><th scope="row">Metric shelf</th><td><code>src/components/MetricShelf.astro</code></td><td><a href="/reports">Production: reports index</a></td></tr>
              <tr><th scope="row">Big stat</th><td><code>src/components/BigStat.astro</code></td><td><a href="/">Production: homepage</a></td></tr>
              <tr><th scope="row">Stat takeover</th><td><code>src/components/StatTakeover.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Chart block</th><td><code>src/components/ChartBlock.astro</code></td><td><a href="/reports/2024/compensation">Production: report section</a></td></tr>
              <tr><th scope="row">Chart small multiples</th><td><code>src/components/ChartSmallMultiples.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Chart range</th><td><code>src/components/ChartRange.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Chart dot plot</th><td><code>src/components/ChartDotPlot.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Invitation</th><td><code>src/components/Invitation.astro</code></td><td><a href="/about">Production: about</a></td></tr>
              <tr><th scope="row">Provocations</th><td><code>src/components/Provocations.astro</code></td><td><a href="/reports/2023/closing">Production: report closing</a> (grid + hero in prod; split + inverse docs-only)</td></tr>
              <tr><th scope="row">Register cards</th><td><code>src/components/RegisterCards.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Pull quote</th><td><code>src/components/PullQuote.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Pull-quote beat</th><td><code>src/components/PullQuoteBeat.astro</code></td><td><a href="/reports/2024/compensation">Production: report section</a></td></tr>
              <tr><th scope="row">Sticky meta</th><td><code>src/components/StickyMeta.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Toc scrollspy</th><td><code>src/components/TocScrollspy.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Filter compare</th><td><code>src/components/FilterCompare.astro</code></td><td>Docs-only specimen</td></tr>
              <tr><th scope="row">Conversation spine</th><td><code>src/components/ConversationSpine.astro</code></td><td><a href="/reports/2024/compensation">Production: report section</a></td></tr>
            </tbody>
          </table>
        </div>
        <p>
          <code>ChapterRail</code>, <code>ConversationBlock</code>, and <code>TeamGrid</code> are
          production report-support components, documented in <code>DESIGN.md</code> but not rendered
          as standalone gallery specimens.
        </p>
      </details>
    </div>
  </header>

  <div class="pattern-library">
    <aside class="pattern-library__nav">
      <TocScrollspy items={tocItems} eyebrow="On this page" label="Pattern list" />
    </aside>

    <div class="pattern-library__content">
      <section id="cover-index-spread" class="pattern-demo">
        <p class="label-mono">Cover — pattern 01-A</p>
        <h2>Cover index spread</h2>
        <p class="pattern-demo__note">
          Default report cover. Two-column claim + thesis lockup with a metric-shelf slot beneath;
          <code>emphasis</code> marks one substring of <code>titleLines</code> as the single emphasis
          signal, <code>meta</code> takes small mono chips, and the caller supplies
          <code>&lt;slot name="metrics"&gt;</code> — <code>MetricShelf</code> here.
        </p>
        <div class="pattern-demo__frame">
          <CoverIndexSpread
            eyebrow="2025 pilot"
            titleLines={['Design pay across', 'Southeast Asia']}
            emphasis="Southeast Asia"
            thesis="A six-market pilot on how design compensation moves with seniority, discipline, and location, read against last year's baseline."
            meta={['6 markets', 'n = 1,842']}
          >
            <MetricShelf slot="metrics" metrics={shelfMetrics} />
          </CoverIndexSpread>
        </div>
      </section>

      <section id="cover-split-editorial" class="pattern-demo">
        <p class="label-mono">Cover — pattern 01-C</p>
        <h2>Cover split editorial</h2>
        <p class="pattern-demo__note">
          Magazine-style split: <code>question</code> carries the editorial provocation on the left,
          register-marked with a crimson glyph and mono label; the caller fills
          <code>&lt;slot name="data"&gt;</code> on the right — a compact <code>MetricShelf</code> here —
          to ground it.
        </p>
        <div class="pattern-demo__frame">
          <CoverSplitEditorial
            question="What does a three-year design lead actually take home across the region?"
            caption="Reader-facing framing device, not a report finding."
          >
            <MetricShelf slot="data" metrics={splitMetrics} />
          </CoverSplitEditorial>
        </div>
      </section>

      <section id="dark-beat" class="pattern-demo">
        <p class="label-mono">Editorial beat</p>
        <h2>Dark beat</h2>
        <p class="pattern-demo__note">
          Dark-inversion beat for a body-copy statement plus up to three evidence-backed metrics —
          reach for it mid-report to punctuate a finding. <code>CoverFullBleed</code> below is reserved
          for the ceremonial flagship cover instead: one short title line and one optional signal line,
          no statement and no metric strip.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--full-bleed">
          <DarkBeat
            eyebrow="Editorial beat"
            title="Transparency is rising, the gap isn't closing"
            statement="Seven in ten studios now disclose a pay band before interview, yet the median gap between top and bottom quartile hasn't moved in two years."
            statementDraft={false}
            metrics={darkBeatMetrics}
            provenanceStatus="proven"
          />
        </div>
      </section>

      <section id="cover-full-bleed" class="pattern-demo">
        <p class="label-mono">Cover — pattern 01-B</p>
        <h2>Cover full bleed</h2>
        <p class="pattern-demo__note">
          Ceremonial dark cover reserved for flagship release moments. Dark-beat surface (<code
          >data-theme="dark"</code
          > + <code>--color-inverse-*</code> tokens), D-blob reveal on load, one short title and one
          optional <code>signalText</code> line — no other stats.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--full-bleed">
          <CoverFullBleed
            eyebrow="Design Pay Asia — 2025 pilot"
            title="Pay, mapped."
            signalText="n = 1,842 across 6 markets"
          />
        </div>
      </section>

      <section id="cover-card-inverse" class="pattern-demo">
        <p class="label-mono">Cover — pattern 01 (archive card)</p>
        <h2>Cover card inverse</h2>
        <p class="pattern-demo__note">
          Compact inverse card for a report archive grid or a related-reports rail. The whole card is
          one link; <code>stat</code> is optional. Shown here as a three-card archive grid.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--transparent">
          <div class="pattern-demo__card-grid">
            {inverseCoverCards.map((card) => (
              <CoverCardInverse href={card.href} year={card.year} title={card.title} stat={card.stat} />
            ))}
          </div>
        </div>
      </section>

      <section id="findings-strip" class="pattern-demo">
        <p class="label-mono">Metrics</p>
        <h2>Findings strip</h2>
        <p class="pattern-demo__note">
          Standalone findings section with its own heading and framing copy, capped at exactly three
          metrics with one signal forced on by default. Reach for it to open a dedicated findings
          section; use <code>MetricShelf</code> below instead for an inline 2–6 cell shelf dropped into
          report body copy, where a signal colour only appears if a metric explicitly asks for one.
        </p>
        <div class="pattern-demo__frame">
          <FindingsStrip
            eyebrow="2025 SEA pilot"
            title="Three signals from the pilot"
            intro="Every figure is evidence-linked so readers can trace the signal back to the source."
            metrics={shelfMetrics}
          />
        </div>
      </section>

      <section id="metric-shelf" class="pattern-demo">
        <p class="label-mono">Metrics</p>
        <h2>Metric shelf</h2>
        <p class="pattern-demo__note">
          Flexible 2–6 cell stat row for inline use in report body copy. At most one cell may carry
          <code>color: 'signal'</code>; each cell shows a <code>n=…</code> sample caption, and a delta
          chip (<code>±pp</code>) is optional per cell.
        </p>
        <div class="pattern-demo__frame">
          <MetricShelf metrics={shelfMetrics} />
        </div>
      </section>

      <section id="big-stat" class="pattern-demo">
        <p class="label-mono">Metrics</p>
        <h2>Big stat</h2>
        <p class="pattern-demo__note">
          Plain, reusable single-stat cell — <code>FindingsStrip</code> above builds its three cells
          from this directly. Reach for it on its own for one bare figure with no annotations and no
          forced dark treatment; use <code>StatTakeover</code> below when that figure needs 2–3
          supporting annotations as a single hero moment instead.
        </p>
        <div class="pattern-demo__frame">
          <div class="pattern-demo__stack">
            <BigStat
              value="SGD 4,200"
              unit="per month"
              label="Median monthly pay"
              color="signal"
              variant="hero"
              countUp
            />
            <BigStat
              value="72"
              unit="%"
              label="Pay bands disclosed pre-interview"
              color="workhorse"
              variant="finding"
            />
          </div>
        </div>
      </section>

      <section id="stat-takeover" class="pattern-demo">
        <p class="label-mono">Metrics</p>
        <h2>Stat takeover</h2>
        <p class="pattern-demo__note">
          One locked hero stat (132px DM Mono) with 2–3 annotation callouts — for a single opener
          finding, not a row of stats (use <code>MetricShelf</code> for that).
          <code>inverse</code> defaults to true (dark-beat treatment); <code>countUp</code> is optional.
        </p>
        <div class="pattern-demo__frame">
          <StatTakeover
            value="SGD 4,200"
            unit="per month"
            contextBefore="The median designer in the region takes home"
            contextAfter="before bonus."
            annotations={[
              { label: 'Sample', body: '1,842 respondents across 6 markets.' },
              { label: 'Method', body: 'Self-reported, median of base pay only.' },
            ]}
            countUp
            countUpDuration={1600}
          />
        </div>
      </section>

      <section id="chart-block" class="pattern-demo">
        <p class="label-mono">Charts</p>
        <h2>Chart block</h2>
        <p class="pattern-demo__note">
          The original bar-chart component the small-multiples, range, and dot-plot patterns below are
          skinned to match — one bar per row plus an accessible fallback table, with an optional
          <code>segments</code> prop for tabbed views. Reach for it directly for one flat set of bars;
          use the specialised variants below when you need panel grouping, an IQR band, or a
          shared-axis dot per row instead.
        </p>
        <div class="pattern-demo__frame">
          <ChartBlock
            title="Share of respondents who negotiated their most recent offer, by market"
            caption="Share of respondents reporting they negotiated pay in their most recent offer, by market."
            summary="Bar chart comparing the share of respondents who negotiated their most recent offer across four Southeast Asian markets, with Singapore highest at 24% and Vietnam lowest at 11%."
            evidenceIds={['evidence:2025-sea-negotiated-offer']}
            sourceLabel="Design Pay Asia 2025 pilot"
            sourceUrl="https://designpay.asia/reports"
            fallbackColumns={['Market', 'Share negotiated']}
            fallbackRows={chartBlockFallbackRows}
            bars={chartBlockBars}
          />
        </div>
      </section>

      <section id="chart-small-multiples" class="pattern-demo">
        <p class="label-mono">Charts</p>
        <h2>Chart small multiples</h2>
        <p class="pattern-demo__note">
          A panel per market, one bar row per year within each panel. <code>fallbackColumns</code> +
          <code>fallbackRows</code> back a no-JS/accessible table; <code>panels[].rows[].tone</code> is
          optional per row.
        </p>
        <div class="pattern-demo__frame">
          <ChartSmallMultiples
            title="Base pay growth by market, 2023 vs 2025"
            caption="Share of respondents reporting a base pay increase, by market."
            summary="Small multiples comparing the share of respondents reporting a base pay increase in three Southeast Asian markets between 2023 and 2025."
            evidenceIds={['evidence:2025-sea-pay-growth']}
            sourceLabel="Design Pay Asia 2025 pilot"
            sourceUrl="https://designpay.asia/reports"
            fallbackColumns={['Market · year', 'Share reporting an increase']}
            fallbackRows={[
              { label: 'Singapore · 2023', value: '52%' },
              { label: 'Singapore · 2025', value: '64%' },
              { label: 'Malaysia · 2023', value: '47%' },
              { label: 'Malaysia · 2025', value: '58%' },
              { label: 'Indonesia · 2023', value: '38%' },
              { label: 'Indonesia · 2025', value: '49%' },
            ]}
            panels={smallMultiplesPanels}
          />
        </div>
      </section>

      <section id="chart-range" class="pattern-demo">
        <p class="label-mono">Charts</p>
        <h2>Chart range</h2>
        <p class="pattern-demo__note">
          IQR band + median dot per row, positioned 0–100 along a shared axis (<code
          >axisTickLabels</code
          > relabels the gridlines). <code>confidence: 'low'</code> renders a dashed band and a smaller
          neutral dot for a thin-sample row — shown here on Lead/Principal (n=11).
        </p>
        <div class="pattern-demo__frame">
          <ChartRange
            title="Base pay range by career level, Singapore"
            caption="Interquartile range of monthly base pay by career level (SGD)."
            summary="Range chart showing the interquartile spread and median of monthly base pay by career level among Singapore-based respondents, including one thin-sample level shown at low confidence."
            evidenceIds={['evidence:2025-sg-pay-range']}
            sourceLabel="Design Pay Asia 2025 pilot"
            sourceUrl="https://designpay.asia/reports"
            fallbackColumns={['Career level', 'Median (IQR)']}
            fallbackRows={[
              { label: 'Junior IC', value: 'SGD 3,800 (±600)' },
              { label: 'Mid IC', value: 'SGD 5,200 (±800)' },
              { label: 'Senior IC', value: 'SGD 7,100 (±1,100)' },
              { label: 'Lead/Principal', value: 'SGD 9,600 (±1,400)' },
            ]}
            rows={rangeRows}
            axisTickLabels={['SGD 0', 'SGD 3k', 'SGD 6k', 'SGD 9k', 'SGD 12k']}
            note="Lead/Principal shown at low confidence (n=11)."
          />
        </div>
      </section>

      <section id="chart-dot-plot" class="pattern-demo">
        <p class="label-mono">Charts</p>
        <h2>Chart dot plot</h2>
        <p class="pattern-demo__note">
          One dot per row along a shared 0–100 axis; every dot count-up animates by default —
          <code>countUpDurationMs</code> (clamped 1200–1800ms) is the only knob. <code>tone</code> is
          optional per row.
        </p>
        <div class="pattern-demo__frame">
          <ChartDotPlot
            title="Median monthly pay by discipline, 2025 pilot"
            caption="Median monthly base pay by design discipline (SGD), on a shared 0–12,000 scale."
            summary="Dot plot comparing median monthly base pay across five design disciplines, each point positioned along a shared pay scale, with the highest-median discipline highlighted."
            evidenceIds={['evidence:2025-sea-discipline-pay']}
            sourceLabel="Design Pay Asia 2025 pilot"
            sourceUrl="https://designpay.asia/reports"
            fallbackColumns={['Discipline', 'Median monthly pay']}
            fallbackRows={[
              { label: 'Product design', value: 'SGD 5,400' },
              { label: 'UX research', value: 'SGD 5,100' },
              { label: 'Brand/visual', value: 'SGD 4,300' },
              { label: 'Design systems', value: 'SGD 5,900' },
              { label: 'Motion/3D', value: 'SGD 4,700' },
            ]}
            rows={dotRows}
            countUpDurationMs={1400}
          />
        </div>
      </section>

      <section id="invitation" class="pattern-demo">
        <p class="label-mono">Registers</p>
        <h2>Invitation</h2>
        <p class="pattern-demo__note">
          Full-bleed, standalone personal-voice moment — one question, no card border, at most one per
          report section. Reach for it as a section-ending beat; use the <code>invitation</code>
          register on <code>RegisterCards</code> below instead when the question needs to sit inside a
          fixed-register card grid alongside data, editorial, and quote cards.
        </p>
        <div class="pattern-demo__frame">
          <Invitation
            question="What would make you comfortable sharing your own number?"
            questionDraft={false}
          />
        </div>
      </section>

      <section id="provocations" class="pattern-demo">
        <p class="label-mono">Registers</p>
        <h2>Provocations</h2>
        <p class="pattern-demo__note">
          Report-closing tension set — a stat (data voice) paired with a provocation question
          (invitation register). One data shape, four variants selected by content; never mix
          variants on one page. <code>grid</code> (2–6 co-equal cells, default, first spans) and
          <code>hero</code> (one dominant stat plus a numbered rail, 1 per page) are in production on
          the 2024 and 2023 closings. <code>split</code> (2–3 diptych cards) and <code>inverse</code>
          (one dark band, 1 per page, never stacked with a <code>DarkBeat</code>) are docs-only
          specimens. All four shown below.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--full-bleed">
          <div class="pattern-demo__stack">
            <p class="label-mono">variant="grid"</p>
            <Provocations items={provocationSample} variant="grid" label="Three tensions" />
            <p class="label-mono">variant="hero"</p>
            <Provocations items={provocationSample} variant="hero" label="Three tensions" />
            <p class="label-mono">variant="split"</p>
            <Provocations items={provocationSample.slice(0, 2)} variant="split" label="Two tensions" />
            <p class="label-mono">variant="inverse"</p>
            <Provocations items={provocationSample.slice(0, 2)} variant="inverse" label="Two tensions" />
          </div>
        </div>
      </section>

      <section id="register-cards" class="pattern-demo">
        <p class="label-mono">Registers</p>
        <h2>Register cards</h2>
        <p class="pattern-demo__note">
          One of four fixed registers per card (<code>data</code>, <code>editorial</code>,
          <code>quote</code>, <code>invitation</code>), each with its own field set and a default
          register label. Shown here as all four in a grid.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--transparent">
          <div class="pattern-demo__register-grid">
            <RegisterCards
              register="data"
              value="SGD 4,200"
              unit="per month"
              caption="Median base pay, 2025 pilot."
              cite="Source: Design Pay Asia 2025 pilot, n = 412"
            />
            <RegisterCards
              register="editorial"
              claim="Transparency is still optional in most SEA studios."
              body="Only a third of respondents said their employer publishes a pay band before interview."
            />
            <RegisterCards
              register="quote"
              quote="I only found out I was underpaid when a teammate told me their number."
              attribution="Mid-level product designer, Singapore"
            />
            <RegisterCards
              register="invitation"
              question="What would make you comfortable sharing your own number?"
            />
          </div>
        </div>
      </section>

      <section id="pull-quote" class="pattern-demo">
        <p class="label-mono">Registers</p>
        <h2>Pull quote</h2>
        <p class="pattern-demo__note">
          Inline, in-copy quote mark for one line of body prose — a plain blockquote with no blob and
          no full-bleed treatment; DESIGN.md caps it at one instance per section, never nested. Reach
          for <code>PullQuoteBeat</code> below instead when the quote needs to stand alone as a
          full-width beat with a blob mark.
        </p>
        <div class="pattern-demo__frame">
          <PullQuote
            quote="A pay band means nothing if nobody in the room will read it out loud."
            attribution="Senior product designer, Manila"
            draftState="final"
          />
        </div>
      </section>

      <section id="pull-quote-beat" class="pattern-demo">
        <p class="label-mono">Registers</p>
        <h2>Pull-quote beat</h2>
        <p class="pattern-demo__note">
          A full-width editorial beat built around one participant quote. Light surface by default
          (<code>inverse</code> unset or false); <code>inverse</code> switches to the dark-beat
          treatment. Shown here as both.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--transparent pattern-demo__frame--full-bleed">
          <div class="pattern-demo__stack">
            <PullQuoteBeat
              quote="Pay conversations in this region are still whispered, not published."
              attribution="Design lead, Kuala Lumpur"
            />
            <PullQuoteBeat
              quote="The moment we published our bands, recruiting got easier, not harder."
              attribution="Head of design, Jakarta"
              inverse
            />
          </div>
        </div>
      </section>

      <section id="sticky-meta" class="pattern-demo">
        <p class="label-mono">Navigation</p>
        <h2>Sticky meta</h2>
        <p class="pattern-demo__note">
          Scroll-aware sidebar panel for a section's methodology, sample, and publish-date metadata —
          pins alongside body copy on desktop. Reach for it beside a long-form report section; use
          <code>TocScrollspy</code> below instead for page-level "on this page" navigation, not
          per-section metadata.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--transparent">
          <div class="pattern-demo__toc-sample">
            <StickyMeta
              eyebrow="Section meta"
              title="About this section"
              items={stickyMetaItems}
              note="Every figure in this section links back to its evidence entry."
              draftState="final"
            />
          </div>
        </div>
      </section>

      <section id="toc-scrollspy" class="pattern-demo">
        <p class="label-mono">Navigation</p>
        <h2>Toc scrollspy</h2>
        <p class="pattern-demo__note">
          Progressive-enhancement "on this page" rail — plain anchor links with no JS, an
          IntersectionObserver-driven active state and offset scroll once JS runs. The rail pinned to
          the left of this page <em>is</em> the live demo, wired to every section id above.
          <code>headerOffset</code> clears sticky chrome.
        </p>
        <div class="pattern-demo__frame pattern-demo__frame--transparent">
          <div class="pattern-demo__toc-sample">
            <TocScrollspy
              items={tocItems.slice(0, 4)}
              eyebrow="Sample instance"
              label="Sample pattern list"
            />
          </div>
        </div>
      </section>

      <section id="filter-compare" class="pattern-demo">
        <p class="label-mono">Navigation</p>
        <h2>Filter compare</h2>
        <p class="pattern-demo__note">
          Filter pills drive a live-filtered table; groups combine with AND logic, options within a
          group are mutually exclusive. Renders a complete, unfiltered table with no JS, then reveals
          the pill controls once the inline script runs.
        </p>
        <div class="pattern-demo__frame">
          <FilterCompare
            title="Median monthly pay by market and level"
            caption="Filter by market and career level to compare median pay."
            columns={['Market', 'Level', 'Median pay']}
            groups={filterGroups}
            rows={filterRows}
          />
        </div>
      </section>

      <section id="nav-wayfinding" class="pattern-demo">
        <p class="label-mono">Navigation</p>
        <h2>Pattern 06 — nav & wayfinding</h2>
        <p class="pattern-demo__note">
          The report's two-register nav: the navy <strong>chapter rail</strong> is functional,
          sticky, and page-scoped — it runs a window-scroll progress script and clones itself
          into a mobile jump-sheet, so it only lives on a real report page (see it live on
          <a href="/reports/2024/compensation">the 2024 compensation section</a>). The
          <strong>conversation spine</strong> below is editorial and self-contained — Instrument
          Serif labels, a crimson "you are here" dot, and a prev/next pager — so it demos safely
          here.
        </p>
        <div class="pattern-demo__frame">
          <ConversationSpine
            mode="section"
            groups={navPatternGroups}
            reportPath="/reports/2024"
            currentId="compensation"
            previousSection={{ id: 'demographics', title: 'Demographics' }}
            nextSection={{ id: 'offer-and-negotiation', title: 'Offer & negotiation' }}
            eyebrow="Where this sits in the conversation"
          />
        </div>
      </section>
    </div>
  </div>
</Base>

