---
import { getCollection } from 'astro:content';

import BigStat from '../components/BigStat.astro';
import Base from '../layouts/Base.astro';
import { assertMetricsHaveEvidence, buildEvidenceMap, getVisibleMetrics } from '../lib/evidence';

const [homepage] = await getCollection('site');

if (!homepage) {
  throw new Error('Missing site/homepage data entry.');
}

const reports = (await getCollection('reports', ({ data }) => data.status === 'published')).sort(
  (left, right) => right.data.publishedAt.getTime() - left.data.publishedAt.getTime(),
);
const featuredReport =
  reports.find((report) => report.id === homepage.data.featuredReportSlug) ?? reports[0];

if (!featuredReport) {
  throw new Error('Missing published report entry for homepage.');
}

const evidenceEntries = await getCollection('evidence');
const evidenceMap = buildEvidenceMap(evidenceEntries);

assertMetricsHaveEvidence(homepage.data.stats, evidenceMap, 'site:homepage');

const stats = getVisibleMetrics(homepage.data.stats);
---

<Base
  title="Design Pay Asia - Southeast Asia's design pay conversation."
  description="Because pay is never just a number. It is context, power, and where the industry is going."
>
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__copy">
        <p class="label-mono">Public pay evidence</p>
        <h1>{homepage.data.heroTitle}</h1>
        <p class="hero__sub">{homepage.data.heroSummary}</p>
        <a href={homepage.data.heroCtaHref} class="hero__cta">
          {homepage.data.heroCtaLabel}
        </a>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="stats__inner">
      {stats.map((stat) => (
        <BigStat
          value={stat.value}
          unit={stat.unit}
          label={stat.label}
          color={stat.color}
          countUp
        />
      ))}
    </div>
  </section>

  <section class="intro">
    <div class="intro__inner">
      <div class="intro__copy">
        <p class="label-mono">{homepage.data.intro.eyebrow}</p>
        <h2>{homepage.data.intro.title}</h2>
        <p class="prose">{homepage.data.intro.body}</p>
      </div>
      <a href={homepage.data.intro.ctaHref} class="intro__cta">
        {homepage.data.intro.ctaLabel}
      </a>
    </div>
  </section>

  <section class="report-entry">
    <div class="report-entry__inner">
      <p class="report-entry__eyebrow">{featuredReport.data.eyebrow}</p>
      <h2 class="report-entry__heading">{featuredReport.data.title}</h2>
      <p class="report-entry__desc prose">{featuredReport.data.summary}</p>
      <p class="report-entry__meta">
        {featuredReport.data.year} · {featuredReport.data.markets.length} markets · evidence-linked
      </p>
      <a href={featuredReport.data.canonicalPath} class="report-entry__link">
        {featuredReport.data.heroCtaLabel}
      </a>
    </div>
  </section>
</Base>

<style>
  .hero,
  .stats,
  .intro,
  .report-entry {
    padding-inline: var(--space-8);
  }

  .hero {
    padding-block: var(--space-24) var(--space-12);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .hero__inner,
  .stats__inner,
  .intro__inner,
  .report-entry__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
  }

  .hero__copy {
    max-width: 72ch;
  }

  .hero__copy h1 {
    margin-block: var(--space-6);
    max-width: 12ch;
  }

  .hero__sub {
    max-width: 52ch;
    color: var(--color-ink-subtle);
  }

  .hero__cta,
  .intro__cta,
  .report-entry__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding-inline: var(--space-6);
    border-radius: 8px;
    text-decoration: none;
  }

  .hero__cta {
    margin-top: var(--space-8);
    background: var(--color-action);
    color: var(--color-action-ink);
  }

  .stats {
    padding-block: var(--space-12) var(--space-16);
  }

  .stats__inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .intro {
    padding-block: var(--space-8) var(--space-16);
  }

  .intro__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-8);
    align-items: end;
  }

  .intro__copy h2,
  .report-entry__heading {
    margin-block: var(--space-4);
  }

  .intro__cta,
  .report-entry__link {
    border: 1px solid var(--color-border-strong);
    color: var(--color-ink);
  }

  .report-entry {
    padding-block: var(--space-16) var(--space-24);
    border-top: 1px solid var(--color-border-subtle);
  }

  .report-entry__meta,
  .report-entry__eyebrow {
    color: var(--color-ink-muted);
  }

  .report-entry__link {
    margin-top: var(--space-8);
  }

  @media (max-width: 900px) {
    .stats__inner,
    .intro__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
