---
import { getCollection } from 'astro:content';

import BigStat from '../components/BigStat.astro';
import Blob from '../components/Blob.astro';
import ChartBlock from '../components/ChartBlock.astro';
import ConversationBlock from '../components/ConversationBlock.astro';
import DarkBeat from '../components/DarkBeat.astro';
import FindingsStrip from '../components/FindingsStrip.astro';
import Invitation from '../components/Invitation.astro';
import Base from '../layouts/Base.astro';
import {
  assertEvidenceIdsExist,
  assertMetricsHaveEvidence,
  buildEvidenceMap,
  getVisibleMetrics,
} from '../lib/evidence';
import { getSectionsForReport } from '../lib/report-content';

const [homepage] = await getCollection('site');

if (!homepage) {
  throw new Error('Missing site/homepage data entry.');
}

const [reports, reportSections] = await Promise.all([
  getCollection('reports'),
  getCollection('reportSections'),
]);
const publishedReports = reports
  .filter((report) => report.data.status === 'published')
  .sort((left, right) => right.data.publishedAt.getTime() - left.data.publishedAt.getTime());
const featuredReport =
  publishedReports.find((report) => report.data.slug === homepage.data.featuredReportSlug) ??
  publishedReports[0];
const featuredReportSections = featuredReport ? getSectionsForReport(featuredReport, reportSections) : [];
const featuredReportCharts = featuredReportSections.flatMap((section) => section.charts);

if (!featuredReport) {
  throw new Error('Missing published report entry for homepage.');
}

const evidenceEntries = await getCollection('evidence');
const evidenceMap = buildEvidenceMap(evidenceEntries);

const stats = getVisibleMetrics(homepage.data.stats);
assertMetricsHaveEvidence(stats, evidenceMap, 'site/homepage');

const heroStat = stats.find((stat) => stat.evidenceId === 'evidence:2024-negotiation') ?? stats[0];
const heroSampleSize = heroStat.sampleSize
  ? Number(heroStat.sampleSize).toLocaleString('en-GB')
  : undefined;
const heroSource = heroSampleSize ? `n=${heroSampleSize} · 2024 DPA Report` : '2024 DPA Report';

const findingsEvidenceIds = [
  'evidence:2024-total-respondents',
  'evidence:2024-career-progression',
  'evidence:2024-company-profile',
];
const findingsStats = findingsEvidenceIds.map((evidenceId) => {
  const metric = stats.find((stat) => stat.evidenceId === evidenceId);

  if (!metric) {
    throw new Error(`Missing homepage metric for ${evidenceId}.`);
  }

  return {
    ...metric,
    unit: evidenceId === 'evidence:2024-total-respondents' ? '' : metric.unit,
    color: evidenceId === 'evidence:2024-career-progression' ? ('signal' as const) : ('workhorse' as const),
  };
});

const featuredChart = featuredReportCharts.find(
  (chart) => chart.id === 'compensation-mix',
);

if (!featuredChart) {
  throw new Error('Missing compensation-mix chart in the featured report.');
}

assertEvidenceIdsExist(
  featuredChart.evidenceIds,
  evidenceMap,
  `report:${featuredReport.id}:chart:${featuredChart.id}`,
);

for (const variant of featuredChart.variants ?? []) {
  assertEvidenceIdsExist(
    variant.evidenceIds,
    evidenceMap,
    `report:${featuredReport.id}:chart:${featuredChart.id}:variant:${variant.label}`,
  );
}

const featuredChartFallbackColumns = featuredChart.fallbackTable.columns as [string, string];

const careerProgressionStat = findingsStats.find(
  (stat) => stat.evidenceId === 'evidence:2024-career-progression',
);
const regionalJobMarketEvidence = evidenceMap.get('evidence:2024-job-market');

if (!careerProgressionStat || !regionalJobMarketEvidence) {
  throw new Error('Missing dark-beat progress or regional job-market evidence.');
}

const extractEvidencePercent = (summary: string, pattern: RegExp, label: string) => {
  const match = summary.match(pattern);

  if (!match?.[1]) {
    throw new Error(`Missing ${label} percentage in evidence:2024-job-market.`);
  }

  return match[1];
};

const jobSecurityConcern = extractEvidencePercent(
  regionalJobMarketEvidence.data.summary,
  /(\d+(?:\.\d+)?)% of designers express concern about job security/,
  'job-security concern',
);
const layoffExposure = extractEvidencePercent(
  regionalJobMarketEvidence.data.summary,
  /(\d+(?:\.\d+)?)% report being directly affected by layoffs/,
  'layoff exposure',
);

const titleWords = homepage.data.heroTitle.trim().split(/\s+/);
const heroTitleHead = titleWords.slice(0, -1).join(' ');
const heroTitleSignal = titleWords.at(-1);
---

<Base
  title="Design Pay Asia - Southeast Asia's design pay conversation."
  description="Because pay is never just a number. It is context, power, and where the design industry is going."
>
  <main class="homepage">
    <section class="hero" aria-labelledby="homepage-title">
      <div class="hero__inner">
        <div class="hero__copy">
          <p class="hero__eyebrow label-mono">2024 DPA report</p>
          <h1 id="homepage-title" class="hero__title t-hero">
            {heroTitleHead} <span class="signal-word">{heroTitleSignal}</span>
          </h1>
          <p class="hero__sub">{homepage.data.heroSummary}</p>
          <div class="hero__ctas">
            <a href={homepage.data.heroCtaHref} class="btn btn--primary">
              {homepage.data.heroCtaLabel}
            </a>

          </div>
        </div>

        <div class="hero__stat">
          <Blob
            as="clip"
            aspect={1}
            opacity={0.55}
            fill="var(--color-surface-muted)"
            class="hero__stat-shape"
          />
          <div class="hero__stat-content">
            <BigStat variant="hero"
              value={heroStat.value}
              unit={heroStat.unit}
              label={heroStat.label}
              color="workhorse"
              countUp
            />
            <p class="hero__stat-source label-mono">{heroSource}</p>
          </div>
        </div>
      </div>
    </section>

    <FindingsStrip
      metrics={findingsStats}
      eyebrow="2024 survey signals"
      title="Three findings before the argument starts"
      intro="The homepage keeps the numbers close to their evidence, so each signal can be checked against the report."
    />

    <ConversationBlock
      id="conversation"
      eyebrow="Editorial conversation"
      title="Pay is a conversation about"
      signalWord="power"
      intro="AI-draft for Jon: the data is useful because it refuses to behave like a simple ranking table."
      paragraphs={[
        'Across the region, designers are advancing, negotiating, and taking on larger decisions. The evidence points to movement, but not always to security.',
        'That gap matters. A pay report can show what people earn, but the sharper question is what they are expected to absorb while the market changes around them.',
        'The homepage should leave that tension open: what counts as progress if the work grows faster than the protection around it?',
      ]}
      metaItems={[
        { label: 'Source', value: '2024 DPA Report', href: featuredReport.data.canonicalPath },
        { label: 'Sample', value: '1,797 designers' },
        { label: 'Markets', value: featuredReport.data.markets.join(', ') },
      ]}
      metaEyebrow="Section 03"
      metaTitle="Open argument"
      metaNote="AI-draft copy. Jon approval required before final publishing."
      quote={{
        quote: 'Progress is easier to measure than the pressure it creates.',
        attribution: 'Draft homepage line',
      }}
      draftState="ai-draft"
      draftLabel="AI draft for Jon"
    />

    <section class="chart-section" aria-label="Compensation mix">
      <div class="chart-section__inner">
        <ChartBlock
          title={featuredChart.title}
          caption={featuredChart.caption}
          summary={featuredChart.summary}
          evidenceIds={featuredChart.evidenceIds}
          sourceLabel={featuredChart.sourceLabel}
          sourceUrl={featuredChart.sourceUrl}
          fallbackColumns={featuredChartFallbackColumns}
          fallbackRows={featuredChart.fallbackTable.rows}
          bars={featuredChart.bars}
          pngPath={featuredChart.pngPath}
          averageLabel={featuredChart.averageLabel}
          segments={featuredChart.segments?.map((chartSegment) => ({
            id: chartSegment.id,
            label: chartSegment.label,
            caption: chartSegment.caption,
            summary: chartSegment.summary,
            averageLabel: chartSegment.averageLabel,
            bars: chartSegment.bars,
            fallbackColumns: chartSegment.fallbackTable.columns as [string, string],
            fallbackRows: chartSegment.fallbackTable.rows,
          }))}
          defaultSegmentLabel={featuredChart.defaultSegmentLabel}
          variants={featuredChart.variants?.map((variant) => ({
            label: variant.label,
            summary: variant.summary,
            evidenceIds: variant.evidenceIds,
            sourceLabel: variant.sourceLabel,
            sourceUrl: variant.sourceUrl,
            bars: variant.bars,
            fallbackColumns: variant.fallbackTable.columns as [string, string],
            fallbackRows: variant.fallbackTable.rows,
          }))}
        />
      </div>
    </section>

    <DarkBeat
      eyebrow="2024 dark beat"
      title="Progress is not the same as safety"
      statement="AI-draft for Jon: the year shows career movement and market strain at the same time."
      statementDraft
      draftLabel="AI draft for Jon"
      provenanceStatus="proven"
      provenanceNote="Regional job-market figures use evidence:2024-job-market, not the Singapore-only record."
      metrics={[
        {
          value: careerProgressionStat.value,
          unit: careerProgressionStat.unit,
          label: careerProgressionStat.label,
          evidenceId: careerProgressionStat.evidenceId,
          evidenceLabel: 'Regional progress',
        },
        {
          value: jobSecurityConcern,
          unit: '%',
          label: 'express concern about job security',
          evidenceId: regionalJobMarketEvidence.data.id,
          evidenceLabel: 'Regional job-market readout',
        },
        {
          value: layoffExposure,
          unit: '%',
          label: 'report being directly affected by layoffs',
          evidenceId: regionalJobMarketEvidence.data.id,
          evidenceLabel: 'Regional job-market readout',
        },
      ]}
    />

    <Invitation question="What will you ask?" questionDraft draftLabel="AI draft for Jon" />
  </main>
</Base>

<style>
  .homepage {
    background: var(--color-ambient);
    color: var(--color-workhorse);
  }

  .hero {
    padding: var(--space-24) 0 0;
  }

  .hero__inner,
  .chart-section__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-6);
    align-items: center;
    min-height: min(720px, calc(100vh - 160px));
  }

  .hero__copy {
    grid-column: 1 / 9;
  }

  .hero__eyebrow {
    margin: 0 0 var(--space-4);
    color: var(--color-ink-muted);
  }

  .hero__title {
    max-width: 14ch;
  }

  .hero__sub {
    max-width: 52ch;
    margin: var(--space-6) 0 0;
    color: var(--color-ink-subtle);
    font-size: var(--font-size-lg);
    line-height: 1.55;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  /* Buttons are now defined globally in src/styles/global.css */

  /* Hero blob-cropped stat remains 1:1 so the locked silhouette is never distorted. */
  .hero__stat {
    position: relative;
    grid-column: 9 / -1;
    aspect-ratio: 1;
    min-width: 0;
    overflow: hidden;
  }

  .hero__stat-shape {
    position: absolute;
    inset: 0;
  }

  .hero__stat-content {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    height: 100%;
    min-height: 0;
    padding: var(--space-8);
    overflow-wrap: break-word;
  }

  .hero__stat-content > * {
    max-width: 100%;
    min-width: 0;
  }

  .hero__stat-source {
    margin: var(--space-4) 0 0;
    color: var(--color-ink-muted);
  }

  .chart-section {
    padding: var(--space-24) 0;
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      min-height: min(720px, calc(100vh - 160px));
    }

    .hero__copy,
    .hero__stat {
      grid-column: 1;
    }

    .hero__stat {
      width: min(100%, 420px);
      margin: 0 auto;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: var(--space-16);
    }

    .hero__inner,
    .chart-section__inner {
      padding-inline: var(--space-4);
    }

    .hero__title {
      font-size: clamp(2.9rem, 14vw, var(--t-display-mobile));
    }

    .hero__stat-content {
      padding: var(--space-5);
    }
  }

  .hero__copy {
    min-width: 0;
  }

  .hero__title {
    overflow-wrap: break-word;
    hyphens: auto;
  }
</style>
