---
import Base from '../layouts/Base.astro';

const resources = [
  {
    href: '/reports',
    title: 'Reports',
    summary: 'Published report routes and archive stubs.',
  },
  {
    href: '/search',
    title: 'Search',
    summary: 'Static search across reports, docs, and ops notes.',
  },
  {
    href: '/docs',
    title: 'Runbooks',
    summary: 'Edit, publish, annual-cycle, architecture, and succession guides.',
  },
  {
    href: '/ops',
    title: 'Ops',
    summary: 'Route inventory, ownership matrix, and public continuity spine.',
  },
];
---

<Base
  title="Resources - Design Pay Asia"
  description="Public reference hub for reports, docs, search, and operational continuity."
>
  <section class="resources-page">
    <div class="resources-page__inner">
      <p class="label-mono">Resources</p>
      <h1>Public reference surface for the site.</h1>
      <p class="prose">
        Reports are the public evidence layer. Docs and ops pages make the platform legible
        enough to sustain without private context.
      </p>

      <div class="resources-page__grid">
        {resources.map((resource) => (
          <article class="resource-card">
            <h2>
              <a href={resource.href} class="resource-card__link">
                {resource.title}
              </a>
            </h2>
            <p class="prose">{resource.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .resources-page {
    padding-inline: var(--space-8);
    padding-block: var(--space-24);
  }

  .resources-page__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
  }

  .resources-page__inner h1 {
    margin-block: var(--space-6);
    max-width: 14ch;
  }

  .resources-page__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-8);
    margin-top: var(--space-10);
  }

  .resource-card {
    padding: var(--space-10);
    border: 1px solid var(--color-border-subtle);
    border-radius: 8px;
    background: var(--color-surface);
  }

  .resource-card__link {
    color: var(--color-ink);
    text-decoration: none;
  }

  .resource-card__link:hover {
    color: var(--color-action);
  }

  @media (max-width: 900px) {
    .resources-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
