---
import { getCollection, type CollectionEntry } from 'astro:content';

import ChartBlock from '../../../components/ChartBlock.astro';
import PullQuoteBeat from '../../../components/PullQuoteBeat.astro';
import DarkBeat from '../../../components/DarkBeat.astro';
import ChapterRail from '../../../components/ChapterRail.astro';
import ConversationSpine from '../../../components/ConversationSpine.astro';
import Base from '../../../layouts/Base.astro';
import { toChartRangeRows } from '../../../lib/chartRange';
import { renderPlotSvg } from '../../../lib/plot';
import {
  assertEvidenceIdsExist,
  buildEvidenceMap,
  collectEvidenceByIds,
  isSelfHostedSource,
} from '../../../lib/evidence';
import {
  buildSectionContentSegments,
  getReportSlug,
  getSectionsForReport,
  type ReportSectionView,
} from '../../../lib/report-content';
import { getSectionGroups } from '../../../lib/report-nav';

export async function getStaticPaths() {
  const [reports, reportSections] = await Promise.all([
    getCollection('reports', ({ data }) => data.status === 'published'),
    getCollection('reportSections'),
  ]);
  const excludedSectionIds = new Set(['executive-summary', 'methodology']);

  return reports.flatMap((report) =>
    getSectionsForReport(report, reportSections)
      .filter((section) => !excludedSectionIds.has(section.id))
      .map((section) => ({
        params: {
          year: getReportSlug(report),
          section: section.id,
        },
        props: {
          report,
          section,
          sections: getSectionsForReport(report, reportSections),
        },
      })),
  );
}

interface Props {
  report: CollectionEntry<'reports'>;
  section: ReportSectionView;
  sections: ReportSectionView[];
}

const { report, section, sections } = Astro.props as Props;
const evidenceEntries = await getCollection('evidence');
const evidenceMap = buildEvidenceMap(evidenceEntries);
const reportPath = report.data.canonicalPath;
const sectionCharts = section.charts;

// Consolidated suppression note (site-owner decision): individual charts
// render fully clean — no inline suppression text — and instead this page
// collects every distinct, non-empty suppressionNote across the section's
// charts (top-level, plus each variant/segment) into one deduplicated list,
// rendered once near the bottom of the page, immediately before Commentary.
const sectionSuppressionNotes = [
  ...new Set(
    sectionCharts.flatMap((chart) => [
      chart.suppressionNote,
      ...(chart.variants ?? []).map((variant) => variant.suppressionNote),
      ...(chart.segments ?? []).map((chartSegment) => chartSegment.suppressionNote),
    ]).filter((note): note is string => Boolean(note)),
  ),
];

for (const chart of sectionCharts) {
  assertEvidenceIdsExist(chart.evidenceIds, evidenceMap, `report:${report.id}:chart:${chart.id}`);

  for (const variant of chart.variants ?? []) {
    assertEvidenceIdsExist(
      variant.evidenceIds,
      evidenceMap,
      `report:${report.id}:chart:${chart.id}:variant:${variant.label}`,
    );
  }
}

// Observable Plot charts render once here, at build, into static SVG
// strings keyed by chart id — the section-page frontmatter is the "build"
// referred to in the architecture contract, not a client-side step.
// ChartBlock itself only ever receives an inert SVG string.
const chartPlotSvgById = new Map<string, string>();
// Variants carry no id, so per-variant SVGs key on chart id + variant
// label (labels are schema-enforced unique within a chart).
const variantPlotSvgByKey = new Map<string, string>();
const chartRangeRowsById = new Map<string, ReturnType<typeof toChartRangeRows>>();
const variantRangeRowsByKey = new Map<string, ReturnType<typeof toChartRangeRows>>();
for (const chart of sectionCharts) {
  if (chart.plot?.type === 'range') {
    chartRangeRowsById.set(chart.id, toChartRangeRows(chart.plot));
  } else if (chart.plot) {
    chartPlotSvgById.set(chart.id, renderPlotSvg(chart.plot));
  }
  for (const variant of chart.variants ?? []) {
    if (variant.plot?.type === 'range') {
      variantRangeRowsByKey.set(`${chart.id}::${variant.label}`, toChartRangeRows(variant.plot));
    } else if (variant.plot) {
      variantPlotSvgByKey.set(`${chart.id}::${variant.label}`, renderPlotSvg(variant.plot));
    }
  }
}

const getFallbackColumns = (columns: string[]): string[] => columns;

const sectionEvidenceIds = sectionCharts.flatMap((chart) => [
  ...chart.evidenceIds,
  ...(chart.variants ?? []).flatMap((variant) => variant.evidenceIds),
]);
const evidenceList = collectEvidenceByIds(sectionEvidenceIds, evidenceMap);

/** Split text on double-newline into trimmed non-empty paragraphs. */
const asParagraphs = (value: string | undefined) =>
  value?.split(/\n{2,}/).map((p) => p.trim()).filter(Boolean) ?? [];

/** Split text on single newlines into trimmed non-empty lines (for bullet lists). */
const asLines = (value: string | undefined) =>
  value?.split('\n').map((line: string) => line.trim()).filter(Boolean) ?? [];

// Ordered prose/chart segments, resolved and validated against this
// section's charts[] (Brief A3 — see buildSectionContentSegments).
const bodySegments = buildSectionContentSegments(section);
const firstProseSegmentIndex = bodySegments.findIndex((segment) => segment.type === 'prose');

/* ── Editorial block data ─────────────────────────────────────────── */

const individualNotes = asLines(section.whatThisMeansIndividuals);
const leaderNotes = asLines(section.whatThisMeansLeaders);
const whatThisMeansNotes = asLines(section.whatThisMeans);

// Commentary lead: strip embedded audience bullets (present in some sections).
// asParagraphs fails when commentary uses single newlines; fall back to
// asLines and slice before any "If you're a…" audience marker.
const commentaryRaw = asParagraphs(section.commentary);
let commentaryLead = commentaryRaw[0] ?? null;
if (commentaryLead) {
  const audienceMarkers = ['If you\'re a', 'If you\'re leading', 'If you\'re running'];
  for (const marker of audienceMarkers) {
    const idx = commentaryLead.indexOf(marker);
    if (idx > 0) { commentaryLead = commentaryLead.slice(0, idx).trim(); break; }
  }
}

const [leadQuestion, ...supportingQuestions] = section.questions;

// Suppress "What this could mean for you" when it is just audience guidance
// repeated from the columns above (starts with "If you're a…").
const isAudienceGuidance = whatThisMeansNotes.length > 0 &&
  /^If you\'re a/i.test(whatThisMeansNotes[0]);

const hasAudienceGuidance = individualNotes.length > 0 || leaderNotes.length > 0;
const hasEditorialBlock =
  commentaryRaw.length > 0 || hasAudienceGuidance || whatThisMeansNotes.length > 0 || section.questions.length > 0 || section.references.length > 0;

/* ── Navigation ───────────────────────────────────────────────────── */

const excludedSectionIds = new Set(['executive-summary', 'methodology']);
const navigableSections = sections.filter((item) => !excludedSectionIds.has(item.id));
const sectionIndex = navigableSections.findIndex((item) => item.id === section.id);
const previousSection = sectionIndex > 0 ? navigableSections[sectionIndex - 1] : undefined;
const nextSection =
  sectionIndex >= 0 && sectionIndex < navigableSections.length - 1
    ? navigableSections[sectionIndex + 1]
    : undefined;

const reportSlug = getReportSlug(report);
const navGroups = getSectionGroups(sections, reportSlug);

const publishedDate = new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(
  report.data.publishedAt,
);
---

<Base
  title={`${section.title} - ${report.data.title} - Design Pay Asia`}
  description={section.summary}
  ogType="article"
>
  <main class={`section-page${section.id === 'closing' ? ' section-page--closing' : ''}`}>
    <section class="section-hero" aria-labelledby="section-title">
      <div class="section-hero__inner">
        <a href={report.data.canonicalPath} class="section-hero__eyebrow label-mono">
          {report.data.eyebrow}
        </a>
        <h1 id="section-title" class="section-hero__title t-h2">{section.title}</h1>
        <p class="section-hero__summary prose-editorial">{section.summary}</p>
        <p class="section-hero__meta label-mono">
          Published {publishedDate} · {report.data.markets.join(', ')}
        </p>
      </div>
    </section>

    <ChapterRail
      mode="section"
      groups={navGroups}
      reportPath={report.data.canonicalPath}
      currentId={section.id}
      progressLabel={section.title}
    />
    <div class="section-reading">
      <section class="section-body" aria-label={`${section.title} analysis`}>
          <div class="section-body__inner">
            {bodySegments.map((segment, index) =>
          segment.type === 'chart' ? (
            <ChartBlock
              title={segment.chart.title}
              caption={segment.chart.caption}
              summary={segment.chart.summary}
              suppressionNote={segment.chart.suppressionNote}
              evidenceIds={segment.chart.evidenceIds}
              sourceLabel={segment.chart.sourceLabel}
              sourceUrl={segment.chart.sourceUrl}
              reportPath={reportPath}
              fallbackColumns={getFallbackColumns(segment.chart.fallbackTable.columns)}
              fallbackRows={segment.chart.fallbackTable.rows}
              bars={segment.chart.bars}
              pngPath={segment.chart.pngPath}
              plotSvg={chartPlotSvgById.get(segment.chart.id)}
              rangeRows={chartRangeRowsById.get(segment.chart.id)?.rows}
              rangeAxisTickLabels={chartRangeRowsById.get(segment.chart.id)?.axisTickLabels}
              averageLabel={segment.chart.averageLabel}
              segments={segment.chart.segments?.map((chartSegment) => ({
                id: chartSegment.id,
                label: chartSegment.label,
                caption: chartSegment.caption,
                summary: chartSegment.summary,
                suppressionNote: chartSegment.suppressionNote,
                averageLabel: chartSegment.averageLabel,
                bars: chartSegment.bars,
                fallbackColumns: getFallbackColumns(chartSegment.fallbackTable.columns),
                fallbackRows: chartSegment.fallbackTable.rows,
              }))}
              defaultSegmentLabel={segment.chart.defaultSegmentLabel}
              variants={segment.chart.variants?.map((variant) => ({
                label: variant.label,
                summary: variant.summary,
                suppressionNote: variant.suppressionNote,
                evidenceIds: variant.evidenceIds,
                sourceLabel: variant.sourceLabel,
                sourceUrl: variant.sourceUrl,
                bars: variant.bars,
                plotSvg: variantPlotSvgByKey.get(`${segment.chart.id}::${variant.label}`),
                rangeRows: variantRangeRowsByKey.get(`${segment.chart.id}::${variant.label}`)?.rows,
                rangeAxisTickLabels: variantRangeRowsByKey.get(`${segment.chart.id}::${variant.label}`)?.axisTickLabels,
                fallbackColumns: getFallbackColumns(variant.fallbackTable.columns),
                fallbackRows: variant.fallbackTable.rows,
              }))}
            />
          ) : segment.type === 'pullquote' ? (
            <PullQuoteBeat quote={segment.quote} attribution={segment.attribution} tint />
          ) : (
            <div
              class={`section-copy prose${index === firstProseSegmentIndex ? ' section-copy--lead' : ''}`}
              set:html={segment.html}
            />
          ),
        )}
      </div>
    </section>

    {/* Consolidated suppression note — one per distinct string, once per
        page, sitting immediately before the editorial block (whether or not
        that block itself renders). Rendered in its own standalone container,
        independent of hasEditorialBlock, so a page with only a suppression
        note and no other editorial content gets just the note — not the
        full-bleed editorial band or the evidence-disclosure collapsible.
        Replaces the removed per-chart ChartBlock suppression footnote (see
        ChartBlock.astro). */}
    {sectionSuppressionNotes.length > 0 && (
      <div class="section-suppression-note-standalone">
        <div class="section-suppression-note">
          {sectionSuppressionNotes.map((note) => (
            <p>{note}</p>
          ))}
          <p>
            <a href="/docs/data-safety">Read our data safety rules</a>
          </p>
        </div>
      </div>
    )}

    {/* ── Unified editorial block ──────────────────────────────────── */}

    {hasEditorialBlock && (
      <section class="section-editorial" aria-label="Commentary and guidance">
        <div class="section-editorial__inner">

          {/* Commentary: crimson-border lead + body bullets */}
          {commentaryRaw.length > 0 && (
            <div class="section-editorial__commentary">
              <h2 class="section-editorial__heading t-h2">Commentary</h2>
              <p class="section-editorial__lead">{commentaryRaw[0]}</p>
              {/* Body: whatThisMeans bullets (e.g. demographics) OR remaining commentary paragraphs */}
              {whatThisMeansNotes.length > 0 ? (
                <ul class="section-editorial__commentary-body">
                  {whatThisMeansNotes.map(item => <li>{item}</li>)}
                </ul>
              ) : commentaryRaw.length > 1 ? (
                <ul class="section-editorial__commentary-body">
                  {commentaryRaw.slice(1).flatMap(para => para.split('\n').filter(Boolean)).map(item => (
                    <li>{item}</li>
                  ))}
                </ul>
              ) : null}
            </div>
          )}

          {/* What this means for you — heading + 50:50 audience grid */}
          {hasAudienceGuidance && section.id !== 'closing' && (
            <div class="section-editorial__audience">
              <h3 class="section-editorial__subheading">What this means for you</h3>
              <div class="section-editorial__audience-grid">
                {individualNotes.length > 0 && (
                  <div class="section-editorial__audience-col">
                    <p class="section-editorial__audience-label label-mono">If you're a designer</p>
                    <ul class="section-editorial__list">
                      {individualNotes.map((note) => <li>{note}</li>)}
                    </ul>
                  </div>
                )}
                {leaderNotes.length > 0 && (
                  <div class="section-editorial__audience-col">
                    <p class="section-editorial__audience-label label-mono">If you're leading a team or organisation</p>
                    <ul class="section-editorial__list">
                      {leaderNotes.map((note) => <li>{note}</li>)}
                    </ul>
                  </div>
                )}
              </div>
            </div>
          )}
          {/* Closing section: tension cards instead of audience grid */}
          {section.id === 'closing' && individualNotes.length > 0 && (
            <div class="section-editorial__tensions">
              <p class="section-editorial__tensions-label label-mono">Five tensions</p>
              <div class="section-editorial__tensions-grid">
                {individualNotes.map((card, idx) => {
                  const parts = card.split('||');
                  const header = parts[0] || '';
                  const stat = parts[1] || '';
                  const question = parts[2] || '';
                  const numMatch = stat.match(/(\d+(?:\.\d+)?)\s*(%|×|x)?/);
                  const statValue = numMatch ? numMatch[1] : '';
                  const statUnit = numMatch ? (numMatch[2] || '') : '';
                  const statDetail = stat.trim();
                  return (
                    <article class="tension-card">
                      <p class="tension-card__index label-mono">{String(idx + 1).padStart(2, '0')}</p>
                      <div class="tension-card__stat-block">
                        <p class="tension-card__stat-value">
                          {statValue}
                          {statUnit && <span class="tension-card__stat-unit">{statUnit}</span>}
                        </p>
                        <p class="tension-card__stat-detail">{statDetail}</p>
                      </div>
                      <div class="tension-card__content">
                        <h3 class="tension-card__header">{header}</h3>
                        <p class="tension-card__question">{question}</p>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}

          {/* References — collapsible, inside editorial inner, before DarkBeat */}
          {(section.references.length > 0 || evidenceList.length > 0) && (
            <div class="section-editorial__references">
              <details class="section-source-group">
                <summary>
                  {section.references.length > 0 && evidenceList.length > 0
                    ? 'Evidence and further reading'
                    : section.references.length > 0
                      ? 'Further reading and context'
                      : 'Evidence used in this section'}
                </summary>
                {evidenceList.length > 0 && (
                  <>
                    {section.references.length > 0 && (
                      <p class="section-source-subhead label-mono">Evidence used in this section</p>
                    )}
                    <ul class="evidence-list">
                      {evidenceList.map((evidence) => {
                        const selfSourced = isSelfHostedSource(evidence.data.sourceUrl, reportPath);

                        return (
                          <li class="evidence-list__item">
                            <h3>{evidence.data.title}</h3>
                            <p>{evidence.data.summary}</p>
                            <p class="evidence-list__meta label-mono">
                              {selfSourced
                                ? `${evidence.id} · ${evidence.data.sensitivity}`
                                : `${evidence.id} · ${evidence.data.sourceName} · ${evidence.data.year} · ${evidence.data.sensitivity}`}
                            </p>
                            {!selfSourced && (
                              <a href={evidence.data.sourceUrl} class="evidence-list__link label-mono">
                                Open source
                              </a>
                            )}
                          </li>
                        );
                      })}
                    </ul>
                  </>
                )}
                {section.references.length > 0 && (
                  <>
                    {evidenceList.length > 0 && (
                      <p class="section-source-subhead label-mono">Further reading and context</p>
                    )}
                    <ul>
                      {section.references.map((reference) => (
                        <li>
                          {reference.url ? <a href={reference.url}>{reference.label}</a> : reference.label}
                        </li>
                      ))}
                    </ul>
                  </>
                )}
              </details>
            </div>
          )}
        </div>
      </section>
    )}
    </div>

    {/* Questions — DarkBeat, full-bleed dark band between the reading column and spine */}
    {section.questions.length > 0 && (
      <div class="section-close-beat">
        {leadQuestion ? (
          <div class="section-editorial__questions">
            <DarkBeat
              eyebrow="Questions worth exploring"
              title={leadQuestion}
              statement={section.id === 'closing' ? 'That question sits underneath every chart in this report. It is about money, but only partly. It is about whether the work is seen.\n\nAnd one admission before we go. Indonesia makes up close to 79% of who we heard from. A single market shapes much of what you have just read. Treat the regional picture as a sketch, not a census. We would rather tell you that than let you mistake it for the whole.' : undefined}
              statementDraft={false}
            />
            {supportingQuestions.length > 0 && (
              <section class="section-questions__more" data-theme="dark" aria-label={section.id === 'closing' ? 'Worth exploring next' : 'Supporting questions'}>
                <div class="section-questions__inner">
                  <p class="section-questions__more-label label-mono">Worth exploring next</p>
                  <ul class="section-questions__list">
                    {supportingQuestions.map((question) => <li>{question}</li>)}
                  </ul>
                </div>
              </section>
            )}
          </div>
        ) : (
          <section class="section-questions__more section-questions__more--standalone" data-theme="dark" aria-labelledby="section-questions-title">
            <div class="section-questions__inner">
              <p class="label-mono">Questions worth exploring</p>
              <h2 id="section-questions-title" class="section-questions__heading t-h2">
                Questions worth exploring
              </h2>
              <ul class="section-questions__list">
                {supportingQuestions.map((question) => <li>{question}</li>)}
              </ul>
            </div>
          </section>
        )}
      </div>
    )}

    <div class="section-nav__inner">
      <ConversationSpine
        mode="section"
        groups={navGroups}
        reportPath={report.data.canonicalPath}
        currentId={section.id}
        flushTop={section.questions.length > 0}
        previousSection={previousSection ? { id: previousSection.id, title: previousSection.title } : undefined}
        nextSection={nextSection ? { id: nextSection.id, title: nextSection.title } : undefined}
      />
    </div>
  </main>
</Base>

<style>
  /* ----------------------------------------------------------------------
     Section detail page layout. Width zones follow reports/[slug].astro.
     ---------------------------------------------------------------------- */

  /* Cap the hero to the same zone as .section-reading so .section-hero__inner
     resolves to the identical width as .section-body__inner (both:
     min(100% - space-8, zone-editorial) against a zone-editorial parent) —
     their text then shares one left edge. */
  .section-hero {
    max-width: var(--zone-editorial);
    margin-inline: auto;
    padding-block: var(--space-16) var(--space-6);
    margin-block-end: 0;
  }

  .section-hero__inner,
  .section-body__inner,
  .section-editorial__inner,
  .section-questions__inner,
  .section-sources__inner,
  .section-nav__inner,
  .section-suppression-note-standalone {
    width: min(100% - var(--space-8), var(--zone-editorial));
    margin-inline: auto;
  }

  .section-reading {
    min-width: 0;
    max-width: var(--zone-editorial);
    margin-inline: auto;
  }

  .section-hero__eyebrow {
    color: var(--color-ink-muted);
    text-decoration: none;
    display: inline-block;
  }

  .section-hero__eyebrow:hover {
    color: var(--color-ink);
  }

  .section-hero__meta {
    color: var(--color-ink-muted);
  }

  .section-hero__title {
    margin-block: var(--space-5);
    max-width: 16ch;
  }

  .section-hero__summary {
    margin-block: var(--space-5) 0;
    color: var(--color-ink-subtle);
    font-size: var(--font-size-lg);
    line-height: 1.55;
  }

  .section-hero__meta {
    margin-top: var(--space-6);
  }

  /* ── Body copy ─────────────────────────────────────────────────── */

  .section-body,
  .section-sources {
    padding-block: var(--space-12);
  }

  .section-body__inner {
    display: grid;
    gap: var(--space-12);
    padding-block: 0 var(--space-24);
  }

  /* ChartBlock is a direct grid child of .section-body__inner (same
     zone-editorial width previously used by the standalone charts
     section) so it breaks out of the narrower .prose (65ch) copy either
     side of it — reusing the existing width zones, no new container. */

  /* set:html injects content outside Astro's scope — use :global() for all
     .section-copy descendants so scoped CSS reaches the injected elements. */
  .section-copy :global(p) {
    margin-block: 0 var(--space-4);
  }

  .section-copy :global(p:last-child) {
    margin-block-end: 0;
  }

  /* Lead paragraph — larger, ink-subtle: frames the section before detail
     body. Scoped to --lead (the first prose segment) rather than
     :first-child, because a ::chart directive can split the body into
     several sibling .section-copy blocks and only the very first one
     should get the lead treatment. */
  .section-copy--lead :global(> p:first-child) {
    font-size: var(--font-size-lg);
    line-height: var(--leading-editorial);
    color: var(--color-ink-subtle);
    margin-block-end: var(--space-8);
  }

  .section-copy :global(h2) {
    margin-block: var(--space-10) var(--space-3);
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    color: var(--color-workhorse);
  }

  .section-copy :global(h3) {
    margin-block: var(--space-8) var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--type-body);
    font-weight: var(--weight-bold);
    line-height: var(--leading-body);
    color: var(--color-workhorse);
  }

  .section-copy :global(ul),
  .section-copy :global(ol) {
    margin-block: 0 var(--space-4);
    padding-left: var(--space-6);
    display: grid;
    gap: var(--space-2);
  }

  .section-copy :global(li) {
    line-height: var(--leading-body);
    color: var(--color-ink);
  }

  .section-copy :global(a) {
    color: var(--color-action);
    text-underline-offset: 0.2em;
  }

  .section-copy :global(a:hover) {
    text-decoration: none;
  }

  .section-copy :global(strong) {
    font-weight: var(--weight-bold);
    color: var(--color-workhorse);
  }

  .section-copy :global(em) {
    font-style: italic;
  }

  .section-copy :global(code) {
    font-family: var(--font-data);
    font-size: 0.875em;
    background: var(--color-surface-muted);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  /* Blockquote uses the locked pull-quote moment — spec §5 */
  .section-copy :global(blockquote) {
    margin-block: var(--space-10) var(--space-6);
    padding: 0;
    border: none;
  }

  .section-copy :global(blockquote p) {
    font-family: var(--type-pullquote-face);
    font-size: var(--type-pullquote-size);
    font-style: italic;
    font-weight: var(--weight-regular);
    line-height: var(--type-pullquote-leading);
    letter-spacing: var(--type-pullquote-tracking);
    color: var(--type-pullquote-color);
    margin: 0;
  }

  /* ═══════════════════════════════════════════════════════════════════
     Unified editorial block — commentary → audience grid →
     what-this-means → references. DarkBeat questions render as a
     full-bleed band after this block (see .section-close-beat).
     Light tinted wrapper, variety treatments per sub-part.
     ═══════════════════════════════════════════════════════════════════ */

  /* Full-bleed muted band: the commentary block sits inside the width-capped
     .section-reading column, so break its background out to the viewport edges
     (content stays constrained by .section-editorial__inner). Same trick as
     .section-close-beat. */
  .section-editorial {
    width: 100vw;
