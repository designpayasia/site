---
import { getCollection, render, type CollectionEntry } from 'astro:content';

import BigStat from '../../components/BigStat.astro';
import ChartBlock from '../../components/ChartBlock.astro';
import TeamGrid from '../../components/TeamGrid.astro';
import Base from '../../layouts/Base.astro';
import {
  assertEvidenceIdsExist,
  assertMetricsHaveEvidence,
  buildEvidenceMap,
  getVisibleMetrics,
} from '../../lib/evidence';

export async function getStaticPaths() {
  const reports = await getCollection('reports', ({ data }) => data.status === 'published');

  return reports.map((report) => ({
    params: { slug: report.id },
    props: { report },
  }));
}

interface Props {
  report: CollectionEntry<'reports'>;
}

const { report } = Astro.props;
const { Content } = await render(report);
const evidenceEntries = await getCollection('evidence');
const evidenceMap = buildEvidenceMap(evidenceEntries);

assertMetricsHaveEvidence(report.data.stats, evidenceMap, `report:${report.id}`);
for (const chart of report.data.charts) {
  assertEvidenceIdsExist(chart.evidenceIds, evidenceMap, `report:${report.id}:chart:${chart.id}`);
}

// Trust-core validation still runs (stats + charts validate against evidence
// records); we only removed the visual evidence list, not the asserts.
const stats = getVisibleMetrics(report.data.stats);
const methodologySection = report.data.sections.find((section) => section.id === 'methodology');

// Hub renders only three signature charts; all 7 remain in frontmatter data.
const SIGNATURE_CHART_IDS = ['geo-distribution', 'career-levels', 'compensation-mix'];
const signatureCharts = report.data.charts.filter((chart) =>
  SIGNATURE_CHART_IDS.includes(chart.id),
);

// Grouped, scannable section list. Two buckets mirror the source Notion hub.
const EXCLUDED_IDS = new Set(['executive-summary', 'methodology']);
const CLOSING_ID = 'closing';
const LANDSCAPE_IDS = ['demographics', 'roles-and-experiences', 'compensation', 'company-landscape'];
const SENTIMENT_IDS = ['offer-and-negotiation', 'career-progression', 'value-of-design', 'job-market'];

const routableSections = report.data.sections.filter(
  (section) => !EXCLUDED_IDS.has(section.id) && section.id !== CLOSING_ID,
);
const closingSection = report.data.sections.find((section) => section.id === CLOSING_ID);

const landscapeSections = routableSections.filter((section) => LANDSCAPE_IDS.includes(section.id));
const sentimentSections = routableSections.filter((section) => SENTIMENT_IDS.includes(section.id));
const otherSections = routableSections.filter(
  (section) => !LANDSCAPE_IDS.includes(section.id) && !SENTIMENT_IDS.includes(section.id),
);

// Methodology — pull the data/bias limitation points (markdown bullets) from
// the methodology section body for the slim strip; fall back to prose lines.
const methodologyPoints = methodologySection
  ? methodologySection.body
      .split('\n')
      .map((line) => line.trim())
      .filter((line) => line.startsWith('- '))
      .map((line) => line.slice(2).trim())
      .filter(Boolean)
  : [];

const methodologyStrip = report.data.methodologyStrip;

const methodologyBody = methodologySection?.body;
const methodologyFallbackParagraphs = methodologyBody
  ? methodologyBody
      .split('\n')
      .map((line: string) => line.trim())
      .filter(Boolean)
  : [];

const publishedDate = new Intl.DateTimeFormat('en', { dateStyle: 'long' }).format(
  report.data.publishedAt,
);
---

<Base title={`${report.data.title} - Design Pay Asia`} description={report.data.summary} ogType="article">
  <section class="report-hero">
    <div class="report-hero__inner">
      <div class="report-hero__copy">
        <p class="label-mono">{report.data.eyebrow}</p>
        <h1 class="t-h2">{report.data.title}</h1>
        <p class="report-hero__meta label-mono">
          Published {publishedDate} &middot; {report.data.markets.join(', ')}
        </p>
      </div>
      <div class="report-hero__lede">
        {report.data.summary.split('\n\n').map(paragraph => (
          <p class="report-hero__lede-p">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <section class="report-stats">
    <div class="report-stats__inner">
      {stats.map((stat) => (
        <BigStat
          variant="compact"
          value={stat.value}
          unit={stat.unit}
          label={stat.label}
          color={stat.color}
          countUp
        />
      ))}
    </div>
  </section>

  <section class="report-body report-body--findings">
    <div class="report-body__inner">
      <div class="report-findings-header">
        <h2 class="report-findings-title t-h2">Key findings</h2>
        <p class="report-findings-header__lede">{routableSections.length} sections drawing from {stats[0].value} survey responses — each with data-backed findings and community commentary.</p>
      </div>

      {signatureCharts.length > 0 && (
        <div class="report-charts">
          {signatureCharts.map((chart) => (
            <ChartBlock
              title={chart.title}
              caption={chart.caption}
              summary={chart.summary}
              evidenceIds={chart.evidenceIds}
              sourceLabel={chart.sourceLabel}
              sourceUrl={chart.sourceUrl}
              pngPath={chart.pngPath}
              fallbackColumns={chart.fallbackTable.columns as [string, string]}
              fallbackRows={chart.fallbackTable.rows}
              bars={chart.bars}
              hideTable
            />
          ))}
        </div>
      )}

      <div class="report-sections">
        {landscapeSections.length > 0 && (
          <div class="report-section-bucket">
            <h3 class="report-section-bucket__heading label-mono">The landscape</h3>
            {landscapeSections.map((section) => (
              <article class="report-section-row" id={section.id}>
                <h4 class="report-section-row__title t-h2">{section.title}</h4>
                {section.hubCommentary && (
                  <div class="report-section-row__intro">
                    <div class="report-section-row__commentary-block">
                      <p class="report-section-row__commentary">{section.hubCommentary}</p>
                    </div>
                  </div>
                )}
                <div class="report-section-row__content">
                  {section.keyFindings && section.keyFindings.filter(Boolean).length > 0 ? (
                    <ul class="report-section__findings prose">
                      {section.keyFindings.filter(Boolean).map((finding) => <li>{finding}</li>)}
                    </ul>
                  ) : (
                    <p class="report-section__summary prose">{section.summary}</p>
                  )}
                  <a href={`${report.data.canonicalPath}/${section.id}`} class="report-section__link">
                    Read section
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}

        {sentimentSections.length > 0 && (
          <div class="report-section-bucket">
            <h3 class="report-section-bucket__heading label-mono">Sentiment and perceptions</h3>
            {sentimentSections.map((section) => (
              <article class="report-section-row" id={section.id}>
                <h4 class="report-section-row__title t-h2">{section.title}</h4>
                {section.hubCommentary && (
                  <div class="report-section-row__intro">
                    <div class="report-section-row__commentary-block">
                      <p class="report-section-row__commentary">{section.hubCommentary}</p>
                    </div>
                  </div>
                )}
                <div class="report-section-row__content">
                  {section.keyFindings && section.keyFindings.filter(Boolean).length > 0 ? (
                    <ul class="report-section__findings prose">
                      {section.keyFindings.filter(Boolean).map((finding) => <li>{finding}</li>)}
                    </ul>
                  ) : (
                    <p class="report-section__summary prose">{section.summary}</p>
                  )}
                  <a href={`${report.data.canonicalPath}/${section.id}`} class="report-section__link">
                    Read section
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}

        {otherSections.length > 0 && (
          <div class="report-section-bucket">
            {otherSections.map((section) => (
              <article class="report-section-row" id={section.id}>
                <h4 class="report-section-row__title t-h2">{section.title}</h4>
                {section.hubCommentary && (
                  <div class="report-section-row__intro">
                    <div class="report-section-row__commentary-block">
                      <p class="report-section-row__commentary">{section.hubCommentary}</p>
                    </div>
                  </div>
                )}
                <div class="report-section-row__content">
                  {section.keyFindings && section.keyFindings.filter(Boolean).length > 0 ? (
                    <ul class="report-section__findings prose">
                      {section.keyFindings.filter(Boolean).map((finding) => <li>{finding}</li>)}
                    </ul>
                  ) : (
                    <p class="report-section__summary prose">{section.summary}</p>
                  )}
                  <a href={`${report.data.canonicalPath}/${section.id}`} class="report-section__link">
                    Read section
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}

        {closingSection && (
          <div class="report-invitation">
            <p class="report-invitation__q t-h2">Where do you sit in this data, <span class="signal-word">and does it match</span> how you feel about the value of your work?</p>
            <a href={`${report.data.canonicalPath}/${closingSection.id}`} class="report-invitation__eyebrow">
              {closingSection.title} &rarr;
            </a>
          </div>
        )}
      </div>

      {(methodologySection || methodologyStrip) && (
        <aside class="report-methodology" aria-labelledby="report-methodology-title">
          <h2 id="report-methodology-title" class="report-methodology__heading t-h2">Methodology</h2>
          {methodologyStrip ? (
            <>
              <p class="report-methodology__intro prose">{methodologyStrip.intro}</p>
              <p class="report-methodology__subheading label-mono">Our process</p>
              <ul class="report-methodology__list prose">
                {methodologyStrip.process.map((step) => <li>{step}</li>)}
              </ul>
              <div class="report-methodology__note">
                <p class="report-methodology__note-heading label-mono">A note on data and bias</p>
                <p class="report-methodology__note-intro prose">{methodologyStrip.biasIntro}</p>
                <ul class="report-methodology__list prose">
                  {methodologyStrip.biasPoints.map((point) => <li>{point}</li>)}
                </ul>
              </div>
              <p class="report-methodology__caveat prose">{methodologyStrip.caveat}</p>
            </>
          ) : methodologyFallbackParagraphs.length > 0 ? (
            <ul class="report-methodology__list prose">
              {methodologyFallbackParagraphs.map((para) => <li>{para}</li>)}
            </ul>
          ) : (
            <p class="report-methodology__summary prose">{methodologySection?.summary}</p>
          )}
        </aside>
      )}
    </div>
  </section>

  {(report.data.team || report.data.communityPartners) && (
    <section class="report-human" data-theme="dark">
      <div class="report-human__inner">

        <header class="report-human__header">
          <p class="report-human__eyebrow label-mono">Thank you</p>
          <h2 class="report-human__title t-h2">Built by the community, for the community</h2>
        </header>

        {report.data.team && report.data.team.length > 0 && (
          <div class="report-team">
            <p class="report-team__intro prose">Special thanks to our volunteers this year who put this together:</p>
            <TeamGrid
              members={report.data.team}
            />
          </div>
        )}

        {report.data.communityPartners && report.data.communityPartners.length > 0 && (
          <div class="report-community">
            <h3 class="report-community__heading">Our community partners and participants</h3>
            <p class="prose">
              This report was built through a regional community effort. Our partners helped extend the survey's reach, and every participant added lived experience that made the findings stronger.
            </p>
            <p class="prose">For suggestions or feedback, please reach out to our team.</p>
            <ul class="partner-chips" role="list">
              {report.data.communityPartners.map((partner) => (
                <li class="partner-chip">{partner}</li>
              ))}
            </ul>
          </div>
        )}

      </div>
    </section>
  )}

  {report.data.support && (
    <div class="report-support">
      <div class="report-support__inner">
        <h2 class="t-h2">{report.data.support.heading}</h2>
        <p class="prose">{report.data.support.body}</p>
        <a
          href={report.data.support.ctaUrl}
          class="btn btn--primary report-support__cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          {report.data.support.ctaLabel}
        </a>
      </div>
    </div>
  )}
</Base>

<style>

  .report-hero {
    padding-block: var(--space-24) var(--space-16);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .report-hero__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-16);
    align-items: start;
  }

  .report-stats__inner,
  .report-body__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .report-hero__copy h1 {
    margin-block: var(--space-6);
    max-width: 12ch;
  }

  .report-hero__meta {
    margin-top: var(--space-6);
    color: var(--color-ink-muted);
  }

  .report-hero__lede-p {
    margin: 0 0 var(--space-4);
    font-size: var(--font-size-lg);
    line-height: 1.55;
    color: var(--color-ink-subtle);
  }

  .report-hero__lede-p:last-child {
    margin-bottom: 0;
  }

  .report-hero .prose + .prose {
    margin-top: var(--space-4);
  }

  .report-stats {
    padding-block: var(--space-16);
  }

  .report-stats__inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .report-body {
    padding-block: 0 var(--space-24);
  }

  .report-body--findings {
    padding-block: var(--space-16) var(--space-32);
    border-top: 1px solid var(--color-border-subtle);
  }

  .report-body__inner {
    display: grid;
    gap: var(--space-16);
  }

  .report-copy,
  .report-charts {
    max-width: var(--zone-editorial);
  }

  .report-copy.prose p {
    margin-block: 0 var(--space-4);
  }

  .report-copy.prose p:last-child {
    margin-block-end: 0;
  }

  .report-charts {
    display: grid;
    gap: var(--space-16);
  }

  /* Key findings heading */
  .report-findings-header {
    margin-bottom: var(--space-8);
  }

  .report-findings-title {
    margin: 0 0 var(--space-3);
  }

  .report-findings-header__lede {
    margin: 0;
    font-size: var(--font-size-sm);
    line-height: 1.55;
    color: var(--color-ink-subtle);
  }

  /* Section buckets — constrained to editorial column */
  .report-section-bucket {
    margin-top: var(--space-16);
    max-width: var(--zone-editorial);
  }

  .report-section-bucket:first-of-type {
    margin-top: 0;
  }

  .report-section-bucket__heading {
    margin-bottom: var(--space-6);
    color: var(--color-ink-muted);
  }

  /* Section rows are single-column stacks. */
  .report-section-row {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "title"
      "intro"
      "content";
    gap: var(--space-6);
    padding-block: var(--space-8);
  }

  .report-section-row__title {
    grid-area: title;
  }

  .report-section-row__intro,
  .report-section-row__content {
    display: grid;
    gap: var(--space-4);
    align-content: start;
  }

  .report-section-row__intro {
    grid-area: intro;
  }

  .report-section-row__content {
    grid-area: content;
  }

  .report-section-row + .report-section-row {
    border-top: 1px solid var(--color-border-subtle);
  }



  .report-section-row__title {
    margin-bottom: 0;
    color: var(--color-workhorse);
  }

  .report-section__summary {
    margin: 0;
    color: var(--color-ink-muted);
  }

  .report-section__findings {
    margin: 0;
    padding-left: var(--space-5);
    display: grid;
    gap: var(--space-2);
  }

  .report-section-row__commentary-block {
    padding-left: var(--space-6);
    border-left: 3px solid var(--color-signal-text);
  }

  .report-section-row__commentary {
    margin: 0;
    max-width: var(--zone-prose);
    color: var(--color-ink-subtle);
    font-size: var(--font-size-lg);
    line-height: var(--leading-editorial);
  }

  .report-section-row__commentary:last-child {
    margin-bottom: 0;
  }

  .report-section__link {
    display: inline-flex;
    margin-top: var(--space-4);
    color: var(--color-action);
    font-weight: 700;
    text-decoration: none;
  }

  .report-section__link:hover {
    text-decoration: underline;
  }

  @media (min-width: 960px) {
    .report-section-row {
      grid-template-columns: 8fr 4fr;
      grid-template-areas:
        "title title"
        "content intro";
      column-gap: var(--space-10);
      row-gap: var(--space-4);
      align-items: start;
    }
  }

  .report-invitation {
    padding-block: var(--space-32);
    text-align: center;
    border-top: 1px solid var(--color-border-subtle);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .report-invitation__eyebrow {
    display: inline-block;
    margin: var(--space-6) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-ink-muted);
    text-decoration: none;
  }

  .report-invitation__eyebrow:visited {
    color: var(--color-ink-muted);
  }

  .report-invitation__eyebrow:hover {
    color: var(--color-signal-text);
  }

  .report-invitation__q {
    max-width: 24ch;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* Methodology — no box, lean on spacing over borders */
  .report-methodology {
    padding-block: var(--space-8);
    background: transparent;
  }

  .report-methodology__heading {
    margin: 0 0 var(--space-4);
    color: var(--color-ink);
  }

  .report-methodology__intro {
    margin: 0 0 var(--space-6);
    color: var(--color-ink-muted);
    line-height: var(--leading-editorial);
  }

  .report-methodology__subheading {
    margin: 0 0 var(--space-3);
    color: var(--color-ink);
    letter-spacing: 0.06em;
  }

  .report-methodology__list {
    margin: 0;
    padding-left: var(--space-6);
    display: grid;
    gap: var(--space-3);
    color: var(--color-ink-muted);
    line-height: var(--leading-editorial);
  }

  .report-methodology__list li {
    padding-left: var(--space-2);
  }

  .report-methodology__note {
    margin-top: var(--space-8);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface-muted);
    border-radius: 6px;
    display: inline-block;
    max-width: 60ch;
    width: auto;
  }

  .report-methodology__note-heading {
    margin: 0 0 var(--space-3);
    color: var(--color-ink);
    letter-spacing: 0.06em;
  }

  .report-methodology__note-intro {
    margin: 0 0 var(--space-4);
    color: var(--color-ink-muted);
    line-height: var(--leading-editorial);
  }

  .report-methodology__note .report-methodology__list {
    padding-left: var(--space-5);
  }

  .report-methodology__caveat {
    margin: var(--space-6) 0 0;
    color: var(--color-ink-muted);
    font-size: var(--type-caption);
    line-height: var(--leading-editorial);
  }

  .report-methodology__summary {
    margin: 0;
    color: var(--color-ink-muted);
  }

  /* Human layer — dark beat section (team + community partners) */
  .report-human {
    background: var(--color-inverse-surface);
    color: var(--color-inverse-text);
    padding-block: var(--space-24);
  }

  .report-human__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
    display: grid;
    gap: var(--space-16);
  }

  .report-human__header {
    display: grid;
    gap: var(--space-3);
  }

  .report-human__eyebrow {
    margin: 0;
    color: var(--color-inverse-signal-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .report-human__title {
    margin: 0;
    max-width: 22ch;
    color: var(--color-inverse-text);
  }

  .report-team {
    max-width: var(--zone-editorial);
    --team-link-color: var(--color-inverse-text);
    --team-hover-bg: color-mix(in srgb, var(--color-inverse-text) 8%, transparent);
    --team-name-color: var(--color-inverse-text);
    --team-photo-bg: var(--color-inverse-surface);
  }

  .report-team__intro {
    margin-bottom: var(--space-8);
    color: var(--color-inverse-text);
  }

  .report-community {
    max-width: var(--zone-editorial);
  }

  .report-community__heading {
    margin-bottom: var(--space-6);
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: var(--weight-regular);
    color: var(--color-inverse-text);
  }

  .report-human .prose {
    color: color-mix(in srgb, var(--color-inverse-text) 80%, transparent);
    margin-top: var(--space-4);
  }

  .partner-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin-top: var(--space-6);
  }

  /* Inverse chip variant — readable on dark background */
  .partner-chip {
    padding: var(--space-2) var(--space-4);
    border: 1px solid color-mix(in srgb, var(--color-inverse-text) 35%, transparent);
    border-radius: 999px;
    font-size: var(--type-caption);
    color: var(--color-inverse-text);
    background: color-mix(in srgb, var(--color-inverse-text) 10%, transparent);
    white-space: nowrap;
  }

  /* Support block — light, centred, separate from dark beat */
  .report-support {
    padding-block: var(--space-16) var(--space-24);
    text-align: center;
  }

  .report-support__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: var(--zone-editorial);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .report-support__inner h2 {
    margin: 0;
  }

  .report-support__inner .prose {
    text-align: center;
  }

  .report-support__cta {
    margin-top: var(--space-2);
    text-decoration: none;
  }

  @media (max-width: 767px) {
    .report-hero {
      padding-block: var(--space-16) var(--space-8);
    }

    .report-hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .report-stats__inner {
      grid-template-columns: 1fr;
    }

    .report-copy,
    .report-charts,
    .report-sections,
    .report-section-bucket,
    .report-methodology,
    .report-team,
    .report-community,
    .report-support {
      max-width: none;
    }
  }
</style>
