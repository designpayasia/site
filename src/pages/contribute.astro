---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contribute - Design Pay Asia"
  description="Contribution route for future survey participation, data support, and publication help."
>
  <section class="stub-page">
    <div class="stub-page__inner">
      <p class="label-mono">Contribute</p>
      <h1 class="t-h2">Help strengthen salary evidence across the region.</h1>
      <p class="prose">
        This stub keeps the route canonical while contribution workflow, survey ops,
        and editorial intake are still being formalised.
      </p>
      <a href="/ops" class="btn btn--primary">
        View operations
      </a>
    </div>
  </section>
</Base>

<style>
  .stub-page {
    padding-block: var(--space-24);
  }

  .stub-page__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .stub-page__inner h1 {
    margin-block: var(--space-6);
    max-width: 14ch;
  }

  .stub-page__inner .btn {
    margin-top: var(--space-8);
  }

  @media (max-width: 767px) {
    .stub-page {
      padding-inline: var(--space-4);
      padding-block: var(--space-16);
    }
  }
</style>
