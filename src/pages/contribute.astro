---
import Base from '../layouts/Base.astro';
import ConversationBlock from '../components/ConversationBlock.astro';
import Invitation from '../components/Invitation.astro';
---

<Base
  title="Contribute - Design Pay Asia"
  description="Share your salary anonymously and help build a fairer, more transparent picture of design pay in Southeast Asia."
>
  <section class="contribute-page">
    <div class="contribute-page__inner">
      <p class="label-mono">Contribute</p>
      <h1 class="t-h2">Add your pay to the evidence.</h1>
      <p class="prose">
        The more designers share, the fairer the picture gets.
      </p>
    </div>
  </section>

  <ConversationBlock
    id="contribute"
    eyebrow="Why share"
    title="Pay talk makes pay fair"
    paragraphs={[
      "We can't fix inequality we can't see. Talking about pay openly is how it gets fairer.",
      'Curious how you compare? Share your salary anonymously. Your input sharpens the picture for every designer in the region.',
    ]}
    metaEyebrow="The form"
    metaTitle="Anonymous"
    metaItems={[
      { label: 'Time', value: '~5 minutes' },
      { label: 'Privacy', value: 'No names, no emails' },
      { label: 'Feeds', value: 'The next report' },
    ]}
    metaNote="Responses go straight into the next report."
    draftState="final"
  />

  <Invitation
    question="Ready to put your number in?"
    questionDraft={false}
    ctaLabel="Share your pay"
    ctaHref="https://tally.so/r/3EDeGX"
  />
</Base>

<style>
  .contribute-page {
    padding-block: var(--space-24);
  }

  .contribute-page__inner {
    max-width: var(--site-max-width);
    margin-inline: auto;
    padding-inline: var(--space-8);
  }

  .contribute-page__inner h1 {
    margin-block: var(--space-6);
    max-width: 14ch;
  }

  @media (max-width: 767px) {
    .contribute-page {
      padding-inline: var(--space-4);
      padding-block: var(--space-16);
    }
  }
</style>
